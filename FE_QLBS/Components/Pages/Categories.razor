                })
                {
                    <div class="flex items-center gap-2 mb-2 text-xs" style="color:rgba(255,255,255,.3);">
                        <i class="bi bi-@ico" style="color:var(--amber-lt);font-size:.62rem;flex-shrink:0;"></i>@txt
                    </div>
