                @foreach (var l in new[] { "Hướng dẫn mua hàng", "Chính sách đổi trả", "Vận chuyển", "Thanh toán", "Liên hệ chúng tôi" })
                {
                    <a href="#" class="ft-a"><i class="bi bi-chevron-right"></i>@l</a>
                }
            </div>
        </div>
        <div class="flex flex-wrap justify-between items-center py-5 border-t gap-3" style="border-color:rgba(255,255,255,.06);">
            <p class="text-xs m-0" style="color:rgba(255,255,255,.2);">&copy; @DateTime.Now.Year BookStore. Tất cả quyền được bảo lưu.</p>
            <div class="flex gap-5">
                <a href="/terms" class="no-underline text-xs" style="color:rgba(255,255,255,.2);">Điều khoản</a>
                <a href="/privacy" class="no-underline text-xs" style="color:rgba(255,255,255,.2);">Bảo mật</a>
            </div>
        </div>
    </div>
</footer>

@code {
    private List<CategoryVm> categories = new();
    private bool isLoading = true;
    private string searchText = "";
    private string sortBy = "name-asc";
    private bool isGridView = true;

    private static readonly string[] Icons = { "📖", "📈", "💻", "🧠", "🌟", "🏛️", "🎨", "🔬", "⚖️", "🍳", "🏃", "🌍", "💡", "🎭", "🗺️", "❤️" };
    private static readonly string[] Bgs = {
        "linear-gradient(135deg,#FFF0E6,#FFD6BB)",
        "linear-gradient(135deg,#E8F4FF,#C8E4FF)",
        "linear-gradient(135deg,#E8FFE8,#C8F0C8)",
        "linear-gradient(135deg,#FFF0FA,#FFD6F0)",
        "linear-gradient(135deg,#FFFBE6,#FFF0B3)",
        "linear-gradient(135deg,#F0EDFF,#DDD6FF)",
        "linear-gradient(135deg,#E6FFF8,#CCFFF0)",
        "linear-gradient(135deg,#FFF0F0,#FFD6D6)",
        "linear-gradient(135deg,#EEF6FF,#D6ECFF)",
        "linear-gradient(135deg,#F5FFE6,#E6FFB3)",
        "linear-gradient(135deg,#FFF5E6,#FFE6B3)",
        "linear-gradient(135deg,#E6FFFA,#B3FFF0)",
        "linear-gradient(135deg,#FFF0FF,#FFD6FF)",
        "linear-gradient(135deg,#F0FFFF,#CCFFFF)",
        "linear-gradient(135deg,#FFF8F0,#FFE6CC)",
        "linear-gradient(135deg,#F0FFF0,#CCFFCC)",
    };

    protected override async Task OnInitializedAsync() => await LoadCategories();

    private async Task LoadCategories()
    {
        isLoading = true;
        try
        {
            var result = await Http.GetFromJsonAsync<List<ApiCategoryDto>>("api/Category");
            if (result != null)
            {
                categories = result.Select((c, i) => new CategoryVm
                    {
                        CategoryId = c.CategoryId,
                        Name = c.CategoryName,
                        Description = c.Description,
                        Icon = Icons[i % Icons.Length],
                        BgColor = Bgs[i % Bgs.Length],
                        Slug = Slugify(c.CategoryName),
                    }).ToList();
            }
        }
        catch { }
        finally { isLoading = false; }
    }

    private IEnumerable<CategoryVm> FilteredCategories
    {
        get
        {
            var q = categories.AsEnumerable();
            if (!string.IsNullOrEmpty(searchText))
                q = q.Where(c =>
                    c.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    (c.Description ?? "").Contains(searchText, StringComparison.OrdinalIgnoreCase));
            return sortBy switch
            {
                "name-desc" => q.OrderByDescending(c => c.Name),
                "id-asc" => q.OrderByDescending(c => c.CategoryId),
                _ => q.OrderBy(c => c.Name),
            };
        }
    }

    private static string Slugify(string name)
    {
        if (string.IsNullOrEmpty(name)) return "";
        var map = new Dictionary<char, string>
        {
            {'đ',"d"},{'à',"a"},{'á',"a"},{'ả',"a"},{'ã',"a"},{'ạ',"a"},
            {'ă',"a"},{'ằ',"a"},{'ắ',"a"},{'ẳ',"a"},{'ẵ',"a"},{'ặ',"a"},
            {'â',"a"},{'ầ',"a"},{'ấ',"a"},{'ẩ',"a"},{'ẫ',"a"},{'ậ',"a"},
            {'è',"e"},{'é',"e"},{'ẻ',"e"},{'ẽ',"e"},{'ẹ',"e"},
            {'ê',"e"},{'ề',"e"},{'ế',"e"},{'ể',"e"},{'ễ',"e"},{'ệ',"e"},
            {'ì',"i"},{'í',"i"},{'ỉ',"i"},{'ĩ',"i"},{'ị',"i"},
            {'ò',"o"},{'ó',"o"},{'ỏ',"o"},{'õ',"o"},{'ọ',"o"},
            {'ô',"o"},{'ồ',"o"},{'ố',"o"},{'ổ',"o"},{'ỗ',"o"},{'ộ',"o"},
            {'ơ',"o"},{'ờ',"o"},{'ớ',"o"},{'ở',"o"},{'ỡ',"o"},{'ợ',"o"},
            {'ù',"u"},{'ú',"u"},{'ủ',"u"},{'ũ',"u"},{'ụ',"u"},
            {'ư',"u"},{'ừ',"u"},{'ứ',"u"},{'ử',"u"},{'ữ',"u"},{'ự',"u"},
            {'ỳ',"y"},{'ý',"y"},{'ỷ',"y"},{'ỹ',"y"},{'ỵ',"y"},
        };
        var sb = new System.Text.StringBuilder();
        foreach (var ch in name.ToLower())
        {
            if (map.TryGetValue(ch, out var r)) sb.Append(r);
            else if (ch == ' ') sb.Append('-');
            else if (char.IsLetterOrDigit(ch)) sb.Append(ch);
        }
        return sb.ToString().Replace("--", "-").Trim('-');
    }

    private class CategoryVm
    {
        public int CategoryId { get; set; }
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public string Icon { get; set; } = "📖";
        public string BgColor { get; set; } = "linear-gradient(135deg,#FFF0E6,#FFD6BB)";
        public string Slug { get; set; } = "";
    }

    private class ApiCategoryDto
    {
        public int CategoryId { get; set; }
        public string CategoryName { get; set; } = "";
        public string? Description { get; set; }
    }
}
