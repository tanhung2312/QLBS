@page "/admin/authors"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Quản lý Tác giả - BookStore Admin</PageTitle>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap');

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    :root {
        --bg: #F4F2EE;
        --surface: #FFFFFF;
        --surface2: #FAFAF8;
        --brown: #6B4C2A;
        --amber: #D4860B;
        --amber-lt: #F5A623;
        --amber-dim: rgba(212,134,11,0.10);
        --ink: #1A1208;
        --text-pri: #1A1208;
        --text-sec: #6B5A46;
        --text-muted: #A8947A;
        --border: #E8E2D9;
        --border2: #DDD7CE;
        --sidebar-w: 252px;
        --green: #2E7D52;
        --green-dim: rgba(46,125,82,0.09);
        --red: #C0392B;
        --red-dim: rgba(192,57,43,0.09);
        --blue: #2563A8;
        --blue-dim: rgba(37,99,168,0.09);
        --shadow-sm: 0 1px 3px rgba(26,18,8,0.06), 0 1px 8px rgba(26,18,8,0.04);
        --shadow-md: 0 6px 24px rgba(26,18,8,0.10);
        --radius: 14px;
    }

    body {
        background: var(--bg);
        color: var(--text-pri);
        font-family: 'DM Sans', sans-serif;
    }

    .adm-shell {
        display: flex;
        min-height: 100vh;
    }

    /* SIDEBAR */
    .adm-sidebar {
        width: var(--sidebar-w);
        background: var(--surface);
        border-right: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        z-index: 100;
    }

    .adm-logo {
        padding: 22px 20px 18px;
        display: flex;
        align-items: center;
        gap: 10px;
        border-bottom: 1px solid var(--border);
    }

    .adm-logo-icon {
        width: 38px;
        height: 38px;
        background: var(--brown);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        color: #fff;
        flex-shrink: 0;
        box-shadow: 0 3px 10px rgba(107,76,42,.22);
    }

    .adm-logo-text {
        font-family: 'Playfair Display', serif;
        font-size: 1.22rem;
        font-weight: 800;
        color: var(--ink);
    }

        .adm-logo-text span {
            color: var(--amber);
        }

    .adm-logo-badge {
        margin-left: auto;
        font-size: .58rem;
        font-weight: 800;
        letter-spacing: .1em;
        background: var(--amber-dim);
        color: var(--amber);
        border: 1px solid rgba(212,134,11,.25);
        border-radius: 5px;
        padding: 2px 7px;
    }

    .adm-nav {
        flex: 1;
        overflow-y: auto;
        padding: 14px 12px;
        scrollbar-width: none;
    }

        .adm-nav::-webkit-scrollbar {
            width: 0;
        }

    .adm-nav-section {
        margin-bottom: 22px;
    }

    .adm-nav-label {
        font-size: .67rem;
        font-weight: 700;
        letter-spacing: .1em;
        color: var(--text-muted);
        padding: 0 10px 6px;
        text-transform: uppercase;
    }

    .adm-nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 10px;
        border-radius: 9px;
        cursor: pointer;
        color: var(--text-sec);
        font-size: .875rem;
        font-weight: 500;
        margin-bottom: 1px;
        text-decoration: none;
        transition: all .15s;
    }

        .adm-nav-item:hover {
            background: var(--bg);
            color: var(--text-pri);
        }

        .adm-nav-item.active {
            background: var(--amber-dim);
            color: var(--brown);
            font-weight: 600;
        }

    .adm-nav-icon {
        width: 18px;
        text-align: center;
        font-size: .92rem;
        flex-shrink: 0;
    }

    .adm-nav-badge-cnt {
        margin-left: auto;
        background: var(--amber);
        color: #fff;
        font-size: .63rem;
        font-weight: 800;
        border-radius: 20px;
        padding: 1px 7px;
    }

    .adm-sidebar-footer {
        padding: 12px;
        border-top: 1px solid var(--border);
    }

    .adm-user-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 10px;
        border-radius: 9px;
        cursor: pointer;
        transition: background .15s;
    }

        .adm-user-row:hover {
            background: var(--bg);
        }

    .adm-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--brown), var(--amber));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .75rem;
        font-weight: 800;
        color: #fff;
        flex-shrink: 0;
    }

    .adm-user-name {
        font-size: .84rem;
        font-weight: 600;
        color: var(--text-pri);
    }

    .adm-user-role {
        font-size: .71rem;
        color: var(--text-muted);
        margin-top: 1px;
    }

    /* MAIN */
    .adm-main {
        margin-left: var(--sidebar-w);
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    .adm-topbar {
        height: 60px;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        padding: 0 28px;
        gap: 14px;
        position: sticky;
        top: 0;
        z-index: 50;
        box-shadow: var(--shadow-sm);
    }

    .adm-topbar-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.12rem;
        font-weight: 700;
        color: var(--ink);
    }

    .adm-breadcrumb {
        font-size: .77rem;
        color: var(--text-muted);
        margin-left: 2px;
    }

        .adm-breadcrumb span {
            color: var(--amber);
        }

    .adm-search {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 8px;
        background: var(--bg);
        border: 1px solid var(--border2);
        border-radius: 9px;
        padding: 7px 14px;
        transition: all .18s;
    }

        .adm-search:focus-within {
            border-color: var(--amber);
            box-shadow: 0 0 0 3px var(--amber-dim);
            background: var(--surface);
        }

        .adm-search i {
            color: var(--text-muted);
            font-size: .85rem;
        }

        .adm-search input {
            background: none;
            border: none;
            outline: none;
            color: var(--text-pri);
            font-family: 'DM Sans', sans-serif;
            font-size: .85rem;
            width: 210px;
        }

            .adm-search input::placeholder {
                color: var(--text-muted);
            }

    .adm-topbar-actions {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .adm-icon-btn {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        background: var(--bg);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--text-sec);
        font-size: .88rem;
        transition: all .15s;
        position: relative;
    }

        .adm-icon-btn:hover {
            border-color: var(--amber);
            color: var(--amber);
            background: var(--amber-dim);
        }

    .adm-notif-dot {
        position: absolute;
        top: 7px;
        right: 7px;
        width: 6px;
        height: 6px;
        background: var(--amber);
        border-radius: 50%;
        border: 1.5px solid var(--surface);
    }

    /* BODY */
    .adm-body {
        padding: 24px 28px;
        flex: 1;
    }

    .page-hd {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 22px;
        animation: fadeUp .3s ease both;
    }

    .page-hd-left h2 {
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--ink);
        margin-bottom: 3px;
    }

    .page-hd-left p {
        font-size: .84rem;
        color: var(--text-muted);
    }

    .author-stats {
        display: flex;
        gap: 12px;
        margin-bottom: 20px;
        animation: fadeUp .3s .05s ease both;
    }

    .astat {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 11px;
        padding: 14px 18px;
        display: flex;
        align-items: center;
        gap: 12px;
        flex: 1;
        box-shadow: var(--shadow-sm);
    }

    .astat-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .astat-val {
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--ink);
        line-height: 1;
    }

    .astat-lbl {
        font-size: .76rem;
        color: var(--text-muted);
        margin-top: 2px;
    }

    .main-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        animation: fadeUp .3s .1s ease both;
    }

    .toolbar {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .tb-search {
        display: flex;
        align-items: center;
        gap: 8px;
        background: var(--bg);
        border: 1px solid var(--border2);
        border-radius: 9px;
        padding: 7px 13px;
        transition: all .15s;
        flex: 1;
        min-width: 200px;
    }

        .tb-search:focus-within {
            border-color: var(--amber);
            box-shadow: 0 0 0 3px var(--amber-dim);
            background: var(--surface);
        }

        .tb-search i {
            color: var(--text-muted);
            font-size: .85rem;
        }

        .tb-search input {
            background: none;
            border: none;
            outline: none;
            color: var(--text-pri);
            font-family: 'DM Sans', sans-serif;
            font-size: .84rem;
            width: 100%;
        }

            .tb-search input::placeholder {
                color: var(--text-muted);
            }

    .tb-select {
        background: var(--bg);
        border: 1px solid var(--border2);
        border-radius: 9px;
        padding: 7px 13px;
        font-family: 'DM Sans', sans-serif;
        font-size: .84rem;
        color: var(--text-sec);
        outline: none;
        cursor: pointer;
        transition: border-color .15s;
    }

        .tb-select:focus {
            border-color: var(--amber);
        }

    /* BUTTONS */
    .btn {
        padding: 7px 16px;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 600;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        border: 1px solid transparent;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all .15s;
        white-space: nowrap;
    }

    .btn-primary {
        background: var(--brown);
        color: #fff;
        box-shadow: 0 2px 8px rgba(107,76,42,.2);
    }

        .btn-primary:hover {
            background: var(--amber);
            box-shadow: 0 3px 12px rgba(212,134,11,.3);
        }

    .btn-amber {
        background: var(--amber);
        color: #fff;
        box-shadow: 0 2px 8px rgba(212,134,11,.2);
    }

        .btn-amber:hover {
            background: var(--amber-lt);
        }

    .btn-outline {
        background: var(--bg);
        color: var(--text-sec);
        border-color: var(--border2);
    }

        .btn-outline:hover {
            border-color: var(--amber);
            color: var(--amber);
        }

    .btn-danger {
        background: var(--red-dim);
        color: var(--red);
        border-color: rgba(192,57,43,.2);
    }

        .btn-danger:hover {
            background: var(--red);
            color: #fff;
        }

    .btn-ghost-sm {
        background: none;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        font-size: .8rem;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 5px 9px;
        border-radius: 7px;
        transition: all .15s;
    }

        .btn-ghost-sm.edit {
            color: var(--blue);
        }

            .btn-ghost-sm.edit:hover {
                background: var(--blue-dim);
            }

        .btn-ghost-sm.del {
            color: var(--red);
        }

            .btn-ghost-sm.del:hover {
                background: var(--red-dim);
            }

    .btn:disabled {
        opacity: .5;
        cursor: not-allowed;
    }

    /* TABLE */
    .tbl-wrap {
        overflow-x: auto;
    }

    .adm-tbl {
        width: 100%;
        border-collapse: collapse;
    }

        .adm-tbl th {
            padding: 10px 18px;
            text-align: left;
            font-size: .69rem;
            font-weight: 700;
            letter-spacing: .07em;
            color: var(--text-muted);
            text-transform: uppercase;
            background: var(--surface2);
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }

            .adm-tbl th.sortable {
                cursor: pointer;
                user-select: none;
            }

                .adm-tbl th.sortable:hover {
                    color: var(--amber);
                }

        .adm-tbl td {
            padding: 13px 18px;
            font-size: .84rem;
            color: var(--text-sec);
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
        }

        .adm-tbl tr:last-child td {
            border-bottom: none;
        }

        .adm-tbl tbody tr:hover td {
            background: var(--surface2);
        }

        .adm-tbl tbody tr {
            transition: background .12s;
        }

    .author-ava {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .85rem;
        font-weight: 800;
        color: #fff;
        flex-shrink: 0;
    }

    .author-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .author-name {
        font-weight: 600;
        color: var(--text-pri);
        font-size: .85rem;
    }

    .author-id {
        font-size: .72rem;
        color: var(--text-muted);
        margin-top: 1px;
    }

    .nat-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 10px;
        border-radius: 20px;
        background: var(--bg);
        border: 1px solid var(--border);
        font-size: .76rem;
        color: var(--text-sec);
        font-weight: 500;
    }

    .act-cell {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
    }

    .empty-icon {
        font-size: 3rem;
        margin-bottom: 14px;
        opacity: .4;
    }

    .empty-state h3 {
        font-family: 'Playfair Display', serif;
        font-size: 1.1rem;
        color: var(--text-sec);
        margin-bottom: 6px;
    }

    .empty-state p {
        font-size: .84rem;
        color: var(--text-muted);
    }

    .pagination {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 20px;
        border-top: 1px solid var(--border);
    }

    .pagination-info {
        font-size: .8rem;
        color: var(--text-muted);
    }

    .page-btns {
        display: flex;
        gap: 4px;
    }

    .page-btn {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: 1px solid var(--border);
        background: var(--surface);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .8rem;
        font-family: 'DM Sans', sans-serif;
        color: var(--text-sec);
        transition: all .15s;
    }

        .page-btn:hover {
            border-color: var(--amber);
            color: var(--amber);
        }

        .page-btn.active {
            background: var(--brown);
            border-color: var(--brown);
            color: #fff;
            font-weight: 700;
        }

        .page-btn:disabled {
            opacity: .4;
            cursor: not-allowed;
        }

    /* MODAL — dùng teleport vào body để tránh stacking context */
    .bk-modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(26,18,8,.5);
        z-index: 9998;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        backdrop-filter: blur(3px);
        animation: fadeIn .18s ease;
    }

    .bk-modal-box {
        background: var(--surface);
        border-radius: 18px;
        width: 100%;
        max-width: 480px;
        box-shadow: 0 20px 60px rgba(26,18,8,.22), 0 4px 20px rgba(26,18,8,.12);
        animation: slideUp .22s ease;
        overflow: hidden;
        position: relative;
        z-index: 9999;
    }

    .bk-modal-header {
        padding: 22px 24px 18px;
        display: flex;
        align-items: center;
        gap: 12px;
        border-bottom: 1px solid var(--border);
    }

    .bk-modal-header-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .bk-modal-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--ink);
    }

    .bk-modal-sub {
        font-size: .78rem;
        color: var(--text-muted);
        margin-top: 2px;
    }

    .bk-modal-close {
        margin-left: auto;
        width: 30px;
        height: 30px;
        border-radius: 8px;
        background: var(--bg);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--text-muted);
        transition: all .15s;
    }

        .bk-modal-close:hover {
            border-color: var(--red);
            color: var(--red);
        }

    .bk-modal-body {
        padding: 22px 24px;
    }

    .form-field {
        margin-bottom: 16px;
    }

        .form-field label {
            display: block;
            font-size: .8rem;
            font-weight: 600;
            color: var(--ink);
            margin-bottom: 6px;
        }

            .form-field label span {
                color: var(--red);
                margin-left: 2px;
            }

    .form-input {
        width: 100%;
        padding: .72rem 1rem .72rem 2.6rem;
        border: 1.5px solid var(--border);
        border-radius: 10px;
        font-family: 'DM Sans', sans-serif;
        font-size: .88rem;
        color: var(--text-pri);
        background: var(--surface);
        transition: all .15s;
    }

        .form-input:focus {
            outline: none;
            border-color: var(--amber);
            box-shadow: 0 0 0 3px var(--amber-dim);
        }

        .form-input::placeholder {
            color: var(--text-muted);
        }

    .form-input-wrap {
        position: relative;
    }

    .form-input-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        font-size: .9rem;
        pointer-events: none;
    }

    .form-error {
        font-size: .75rem;
        color: var(--red);
        margin-top: 4px;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    .bk-modal-footer {
        padding: 16px 24px;
        border-top: 1px solid var(--border);
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        background: var(--surface2);
    }

    .bk-del-modal {
        max-width: 400px;
    }

    .del-icon {
        width: 56px;
        height: 56px;
        background: var(--red-dim);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin: 0 auto 16px;
    }

    .del-body {
        padding: 28px 24px 20px;
        text-align: center;
    }

        .del-body h3 {
            font-family: 'Playfair Display', serif;
            font-size: 1.1rem;
            font-weight: 800;
            color: var(--ink);
            margin-bottom: 8px;
        }

        .del-body p {
            font-size: .85rem;
            color: var(--text-muted);
            line-height: 1.6;
        }

    .del-name {
        color: var(--red);
        font-weight: 700;
    }

    /* ALERT */
    .alert-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        border-radius: 10px;
        margin-bottom: 18px;
        font-size: .84rem;
        animation: fadeUp .25s ease both;
    }

    .alert-success {
        background: var(--green-dim);
        color: var(--green);
        border: 1px solid rgba(46,125,82,.2);
    }

    .alert-error {
        background: var(--red-dim);
        color: var(--red);
        border: 1px solid rgba(192,57,43,.2);
    }

    .spinner {
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255,255,255,.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin .7s linear infinite;
    }

    .spinner-dark {
        border-color: rgba(26,18,8,.15);
        border-top-color: var(--brown);
    }

    .skel {
        background: linear-gradient(90deg, var(--border) 25%, var(--surface2) 50%, var(--border) 75%);
        background-size: 200% 100%;
        animation: shimmer 1.3s infinite;
        border-radius: 6px;
    }

    @@keyframes shimmer {
        to {
            background-position: -200% 0;
        }
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px) scale(.97);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    ::-webkit-scrollbar {
        width: 4px;
    }

    ::-webkit-scrollbar-thumb {
        background: var(--border2);
        border-radius: 10px;
    }
</style>

<div class="adm-shell">

    <!-- SIDEBAR -->
    <aside class="adm-sidebar">
        <div class="adm-logo">
            <div class="adm-logo-icon"><i class="bi bi-book-half"></i></div>
            <span class="adm-logo-text">Book<span>Store</span></span>
            <span class="adm-logo-badge">ADMIN</span>
        </div>
        <nav class="adm-nav">
            <div class="adm-nav-section">
                <div class="adm-nav-label">Tổng quan</div>
                <a href="/admin" class="adm-nav-item"><span class="adm-nav-icon"><i class="bi bi-grid-fill"></i></span>Dashboard</a>
                <a href="/admin/analytics" class="adm-nav-item"><span class="adm-nav-icon"><i class="bi bi-bar-chart-line-fill"></i></span>Thống kê</a>
            </div>
            <div class="adm-nav-section">
                <div class="adm-nav-label">Quản lý</div>
                <a href="/admin/orders" class="adm-nav-item"><span class="adm-nav-icon"><i class="bi bi-bag-fill"></i></span>Đơn hàng<span class="adm-nav-badge-cnt">12</span></a>
                <a href="/admin/books" class="adm-nav-item"><span class="adm-nav-icon"><i class="bi bi-journals"></i></span>Sách</a>
                <a href="/admin/authors" class="adm-nav-item active"><span class="adm-nav-icon"><i class="bi bi-person-lines-fill"></i></span>Tác giả</a>
                <a href="/admin/categories" class="adm-nav-item"><span class="adm-nav-icon"><i class="bi bi-tags-fill"></i></span>Danh mục</a>
                <a href="/admin/customers" class="adm-nav-item"><span class="adm-nav-icon"><i class="bi bi-people-fill"></i></span>Khách hàng</a>
                <a href="/admin/reviews" class="adm-nav-item"><span class="adm-nav-icon"><i class="bi bi-star-fill"></i></span>Đánh giá<span class="adm-nav-badge-cnt">3</span></a>
            </div>
            <div class="adm-nav-section">
                <div class="adm-nav-label">Hệ thống</div>
                <a href="/admin/promotions" class="adm-nav-item"><span class="adm-nav-icon"><i class="bi bi-gift-fill"></i></span>Khuyến mãi</a>
                <a href="/admin/settings" class="adm-nav-item"><span class="adm-nav-icon"><i class="bi bi-gear-fill"></i></span>Cài đặt</a>
            </div>
        </nav>
        <div class="adm-sidebar-footer">
            <div class="adm-user-row">
                <div class="adm-avatar">AD</div>
                <div><div class="adm-user-name">Admin</div><div class="adm-user-role">Super Admin</div></div>
                <div style="margin-left:auto;color:var(--text-muted)"><i class="bi bi-three-dots-vertical"></i></div>
            </div>
        </div>
    </aside>

    <!-- MAIN -->
    <div class="adm-main">
        <header class="adm-topbar">
            <div>
                <div class="adm-topbar-title">Tác giả</div>
                <div class="adm-breadcrumb">Admin / Quản lý / <span>Tác giả</span></div>
            </div>
            <div class="adm-search">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Tìm kiếm..." />
            </div>
            <div class="adm-topbar-actions">
                <div class="adm-icon-btn"><i class="bi bi-bell"></i><span class="adm-notif-dot"></span></div>
                <div class="adm-avatar" style="width:34px;height:34px;font-size:.75rem;cursor:pointer;">AD</div>
            </div>
        </header>

        <div class="adm-body">

            <!-- Page header -->
            <div class="page-hd">
                <div class="page-hd-left">
                    <h2>Quản lý Tác giả</h2>
                    <p>Danh sách tất cả tác giả trong hệ thống</p>
                </div>
                <button class="btn btn-primary" @onclick="OpenCreateModal">
                    <i class="bi bi-plus-lg"></i> Thêm tác giả
                </button>
            </div>

            <!-- Alert -->
            @if (!string.IsNullOrEmpty(alertMsg))
            {
                <div class="alert-bar @(alertIsError ? "alert-error" : "alert-success")">
                    <i class="bi @(alertIsError ? "bi-exclamation-circle-fill" : "bi-check-circle-fill")"></i>
                    @alertMsg
                </div>
            }

            <!-- Stats -->
            <div class="author-stats">
                <div class="astat">
                    <div class="astat-icon" style="background:var(--amber-dim);color:var(--amber)"><i class="bi bi-people-fill"></i></div>
                    <div><div class="astat-val">@authors.Count</div><div class="astat-lbl">Tổng tác giả</div></div>
                </div>
                <div class="astat">
                    <div class="astat-icon" style="background:var(--green-dim);color:var(--green)"><i class="bi bi-globe2"></i></div>
                    <div><div class="astat-val">@authors.Select(a => a.Nationality).Distinct().Count()</div><div class="astat-lbl">Quốc tịch</div></div>
                </div>
                <div class="astat">
                    <div class="astat-icon" style="background:var(--blue-dim);color:var(--blue)"><i class="bi bi-search"></i></div>
                    <div><div class="astat-val">@FilteredAuthors.Count()</div><div class="astat-lbl">Kết quả hiện tại</div></div>
                </div>
            </div>

            <!-- Main card -->
            <div class="main-card">
                <div class="toolbar">
                    <div class="tb-search">
                        <i class="bi bi-search"></i>
                        <input type="text" placeholder="Tìm theo tên tác giả..."
                               @bind="searchText" @bind:event="oninput" />
                    </div>
                    <select class="tb-select" @bind="filterNationality">
                        <option value="">Tất cả quốc tịch</option>
                        @foreach (var nat in authors.Select(a => a.Nationality).Where(n => !string.IsNullOrEmpty(n)).Distinct().OrderBy(n => n))
                        {
                            <option value="@nat">@nat</option>
                        }
                    </select>
                    <select class="tb-select" @bind="pageSize">
                        <option value="10">10 / trang</option>
                        <option value="25">25 / trang</option>
                        <option value="50">50 / trang</option>
                    </select>
                    <button class="btn btn-outline" @onclick="LoadAuthors" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner spinner-dark"></span>
                        }
                        else
                        {
                            <i class="bi bi-arrow-clockwise"></i>
                        }
                        Làm mới
                    </button>
                </div>

                <div class="tbl-wrap">
                    @if (isLoading)
                    {
                        <table class="adm-tbl">
                            <thead><tr><th>Tác giả</th><th>Năm sinh</th><th>Quốc tịch</th><th>Thao tác</th></tr></thead>
                            <tbody>
                                @for (int s = 0; s < 6; s++)
                                {
                                    <tr>
                                        <td><div class="skel" style="height:18px;width:180px"></div></td>
                                        <td><div class="skel" style="height:18px;width:60px"></div></td>
                                        <td><div class="skel" style="height:24px;width:100px;border-radius:20px"></div></td>
                                        <td><div class="skel" style="height:18px;width:80px"></div></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else if (!PagedAuthors.Any())
                    {
                        <div class="empty-state">
                            <div class="empty-icon">✍️</div>
                            <h3>@(string.IsNullOrEmpty(searchText) ? "Chưa có tác giả nào" : "Không tìm thấy kết quả")</h3>
                            <p>@(string.IsNullOrEmpty(searchText) ? "Hãy thêm tác giả đầu tiên vào hệ thống." : $"Không có tác giả nào khớp với \"{searchText}\".")</p>
                        </div>
                    }
                    else
                    {
                        <table class="adm-tbl">
                            <thead>
                                <tr>
                                    <th class="sortable" @onclick="@(() => SetSort("name"))">
                                        Tác giả <i class="bi bi-@(sortCol=="name"?(sortAsc?"sort-up":"sort-down"):"chevron-expand")"></i>
                                    </th>
                                    <th class="sortable" @onclick="@(() => SetSort("year"))">
                                        Năm sinh <i class="bi bi-@(sortCol=="year"?(sortAsc?"sort-up":"sort-down"):"chevron-expand")"></i>
                                    </th>
                                    <th>Quốc tịch</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in PagedAuthors)
                                {
                                    <tr>
                                        <td>
                                            <div class="author-cell">
                                                <div class="author-ava" style="background:@GetAvaColor(a.AuthorName)">@GetInitials(a.AuthorName)</div>
                                                <div>
                                                    <div class="author-name">@a.AuthorName</div>
                                                    <div class="author-id">#@a.AuthorId</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>@(a.BirthYear.HasValue ? a.BirthYear.Value.ToString() : "—")</td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(a.Nationality))
                                            {
                                                <span class="nat-badge"><i class="bi bi-geo-alt-fill" style="font-size:.65rem;color:var(--amber)"></i>@a.Nationality</span>
                                            }
                                            else
                                            {
                                                <span style="color:var(--text-muted)">—</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="act-cell">
                                                <button class="btn-ghost-sm edit" @onclick="@(() => OpenEditModal(a))"><i class="bi bi-pencil-fill"></i> Sửa</button>
                                                <button class="btn-ghost-sm del" @onclick="@(() => OpenDeleteModal(a))"><i class="bi bi-trash3-fill"></i> Xoá</button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>

                @if (TotalPages > 1)
                {
                    <div class="pagination">
                        <span class="pagination-info">
                            Hiển thị @(((currentPage - 1) * pageSize) + 1)–@(Math.Min(currentPage * pageSize, FilteredAuthors.Count())) trong @FilteredAuthors.Count() kết quả
                        </span>
                        <div class="page-btns">
                            <button class="page-btn" @onclick="PrevPage" disabled="@(currentPage<=1)"><i class="bi bi-chevron-left"></i></button>
                            @for (int p = 1; p <= TotalPages; p++)
                            {
                                var pg = p;
                                <button class="page-btn @(pg==currentPage?"active":"")" @onclick="@(() => GoPage(pg))">@pg</button>
                            }
                            <button class="page-btn" @onclick="NextPage" disabled="@(currentPage>=TotalPages)"><i class="bi bi-chevron-right"></i></button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

