@if (showFormModal)
{
    <div class="bk-modal-backdrop" @onclick="CloseFormModal">
        <div class="bk-modal-box" @onclick:stopPropagation>
            <div class="bk-modal-header">
                <div class="bk-modal-header-icon" style="background:@(isEditMode?"var(--blue-dim)":"var(--green-dim)");color:@(isEditMode?"var(--blue)":"var(--green)")">
                    <i class="bi bi-@(isEditMode ? "pencil-fill" : "person-plus-fill")"></i>
                </div>
                <div>
                    <div class="bk-modal-title">@(isEditMode ? "Chỉnh sửa tác giả" : "Thêm tác giả mới")</div>
                    <div class="bk-modal-sub">@(isEditMode ? $"Đang sửa: {formModel.AuthorName}" : "Điền đầy đủ thông tin bên dưới")</div>
                </div>
                <button class="bk-modal-close" @onclick="CloseFormModal"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="bk-modal-body">
                @if (!string.IsNullOrEmpty(modalError))
                {
                    <div class="alert-bar alert-error" style="margin-bottom:14px">
                        <i class="bi bi-exclamation-circle-fill"></i> @modalError
                    </div>
                }
                <div class="form-field">
                    <label>Tên tác giả <span>*</span></label>
                    <div class="form-input-wrap">
                        <i class="bi bi-person form-input-icon"></i>
                        <input class="form-input" placeholder="Nguyễn Văn A" @bind="formModel.AuthorName" @bind:event="oninput" />
                    </div>
                    @if (submitted && string.IsNullOrWhiteSpace(formModel.AuthorName))
                    {
                        <div class="form-error"><i class="bi bi-exclamation-circle"></i> Tên tác giả không được để trống.</div>
                    }
                </div>
                <div class="form-row">
                    <div class="form-field">
                        <label>Năm sinh</label>
                        <div class="form-input-wrap">
                            <i class="bi bi-calendar3 form-input-icon"></i>
                            <input class="form-input" type="number" placeholder="1950" min="1" max="2010"
                                   @bind="formModel.BirthYear" @bind:event="oninput" />
                        </div>
                        @if (submitted && formModel.BirthYear.HasValue && (formModel.BirthYear < 1 || formModel.BirthYear > 2010))
                        {
                            <div class="form-error"><i class="bi bi-exclamation-circle"></i> Năm sinh không hợp lệ.</div>
                        }
                    </div>
                    <div class="form-field">
                        <label>Quốc tịch</label>
                        <div class="form-input-wrap">
                            <i class="bi bi-globe2 form-input-icon"></i>
                            <input class="form-input" placeholder="Việt Nam" @bind="formModel.Nationality" @bind:event="oninput" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="bk-modal-footer">
                <button class="btn btn-outline" @onclick="CloseFormModal">Huỷ</button>
                <button class="btn @(isEditMode?"btn-amber":"btn-primary")" @onclick="SubmitForm" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span class="spinner"></span>
                        <span>Đang lưu...</span>
                    }
                    else if (isEditMode)
                    {
                        <i class="bi bi-check-lg"></i>
                        <span>Cập nhật</span>
                    }
                    else
                    {
                        <i class="bi bi-plus-lg"></i>
                        <span>Thêm tác giả</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@if (showDeleteModal && authorToDelete != null)
{
    <div class="bk-modal-backdrop" @onclick="CloseDeleteModal">
        <div class="bk-modal-box bk-del-modal" @onclick:stopPropagation>
            <div class="del-body">
                <div class="del-icon">🗑️</div>
                <h3>Xác nhận xoá?</h3>
                <p>
                    Bạn có chắc muốn xoá tác giả<br />
                    <span class="del-name">"@authorToDelete.AuthorName"</span>?<br />
                    Hành động này không thể hoàn tác.
                </p>
            </div>
            @if (!string.IsNullOrEmpty(modalError))
            {
                <div style="padding:0 24px 16px">
                    <div class="alert-bar alert-error">
                        <i class="bi bi-exclamation-circle-fill"></i> @modalError
                    </div>
                </div>
            }
            <div class="bk-modal-footer">
                <button class="btn btn-outline" @onclick="CloseDeleteModal">Không, giữ lại</button>
                <button class="btn btn-danger" @onclick="ConfirmDelete" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span class="spinner" style="border-top-color:var(--red)"></span>
                        <span>Đang xoá...</span>
                    }
                    else
                    {
                        <i class="bi bi-trash3-fill"></i>
                        <span>Xoá tác giả</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<AuthorDto> authors = new();
    private bool isLoading = true;
    private bool isSaving = false;

    private string searchText = "";
    private string filterNationality = "";
    private string sortCol = "name";
    private bool sortAsc = true;
    private int currentPage = 1;
    private int pageSize = 10;

    private string alertMsg = "";
    private bool alertIsError = false;

    private bool showFormModal = false;
    private bool isEditMode = false;
    private bool submitted = false;
    private string modalError = "";
    private AuthorFormModel formModel = new();
    private int editingId = 0;

    private bool showDeleteModal = false;
    private AuthorDto? authorToDelete = null;

    protected override async Task OnInitializedAsync() => await LoadAuthors();

    private async Task SetAuthorizationHeader()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "accessToken");
        if (!string.IsNullOrEmpty(token))
        {
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
    }

    private async Task LoadAuthors()
    {
        isLoading = true; alertMsg = "";
        try
        {
            await SetAuthorizationHeader();
            var result = await Http.GetFromJsonAsync<List<AuthorDto>>("api/Author");
            authors = result ?? new();
        }
        catch { ShowAlert("Không thể tải danh sách tác giả. Vui lòng thử lại.", true); }
        finally { isLoading = false; }
    }

    private IEnumerable<AuthorDto> FilteredAuthors =>
        authors.Where(a =>
            (string.IsNullOrEmpty(searchText) || a.AuthorName.Contains(searchText, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(filterNationality) || a.Nationality == filterNationality));

    private IEnumerable<AuthorDto> SortedFiltered =>
        sortAsc
            ? (sortCol == "year" ? FilteredAuthors.OrderBy(a => a.BirthYear ?? 0) : FilteredAuthors.OrderBy(a => a.AuthorName))
            : (sortCol == "year" ? FilteredAuthors.OrderByDescending(a => a.BirthYear ?? 0) : FilteredAuthors.OrderByDescending(a => a.AuthorName));

    private int TotalPages => (int)Math.Ceiling(FilteredAuthors.Count() / (double)pageSize);

    private IEnumerable<AuthorDto> PagedAuthors =>
        SortedFiltered.Skip((currentPage - 1) * pageSize).Take(pageSize);

    private void SetSort(string col)
    {
        if (sortCol == col) sortAsc = !sortAsc;
        else { sortCol = col; sortAsc = true; }
        currentPage = 1;
    }

    private void GoPage(int p) => currentPage = p;
    private void PrevPage() { if (currentPage > 1) currentPage--; }
    private void NextPage() { if (currentPage < TotalPages) currentPage++; }

    private async Task OpenCreateModal()
    {
        isEditMode = false; submitted = false; modalError = "";
        formModel = new();
        showFormModal = true;
        await Task.Yield(); // đảm bảo Blazor re-render trước khi JS chạy
        await JS.InvokeVoidAsync("document.body.style.setProperty", "overflow", "hidden");
    }

    private async Task OpenEditModal(AuthorDto a)
    {
        isEditMode = true; submitted = false; modalError = "";
        editingId = a.AuthorId;
        formModel = new AuthorFormModel { AuthorName = a.AuthorName, BirthYear = a.BirthYear, Nationality = a.Nationality };
        showFormModal = true;
        await Task.Yield();
        await JS.InvokeVoidAsync("document.body.style.setProperty", "overflow", "hidden");
    }

    private async Task CloseFormModal()
    {
        showFormModal = false; modalError = "";
        await JS.InvokeVoidAsync("document.body.style.removeProperty", "overflow");
    }

    private async Task SubmitForm()
    {
        submitted = true;
        if (string.IsNullOrWhiteSpace(formModel.AuthorName)) return;
        if (formModel.BirthYear.HasValue && (formModel.BirthYear < 1 || formModel.BirthYear > 2010)) return;

        isSaving = true; modalError = "";
        try
        {
            await SetAuthorizationHeader();
            var payload = new { authorName = formModel.AuthorName, birthYear = formModel.BirthYear, nationality = formModel.Nationality };
            if (isEditMode)
            {
                var resp = await Http.PutAsJsonAsync($"api/Author/{editingId}", payload);
                if (resp.IsSuccessStatusCode) { await CloseFormModal(); ShowAlert($"Cập nhật \"{formModel.AuthorName}\" thành công!", false); await LoadAuthors(); }
                else { modalError = "Cập nhật thất bại. Vui lòng thử lại."; }
            }
            else
            {
                var resp = await Http.PostAsJsonAsync("api/Author", payload);
                if (resp.IsSuccessStatusCode || resp.StatusCode == System.Net.HttpStatusCode.Created)
                { await CloseFormModal(); ShowAlert($"Thêm \"{formModel.AuthorName}\" thành công!", false); await LoadAuthors(); }
                else { modalError = "Thêm tác giả thất bại. Vui lòng thử lại."; }
            }
        }
        catch { modalError = "Lỗi kết nối. Vui lòng thử lại."; }
        finally { isSaving = false; }
    }

    private async Task OpenDeleteModal(AuthorDto a)
    {
        authorToDelete = a; showDeleteModal = true; modalError = "";
        await Task.Yield();
        await JS.InvokeVoidAsync("document.body.style.setProperty", "overflow", "hidden");
    }

    private async Task CloseDeleteModal()
    {
        showDeleteModal = false; authorToDelete = null; modalError = "";
        await JS.InvokeVoidAsync("document.body.style.removeProperty", "overflow");
    }

    private async Task ConfirmDelete()
    {
        if (authorToDelete == null) return;
        isSaving = true; modalError = "";
        try
        {
            await SetAuthorizationHeader();
            var resp = await Http.DeleteAsync($"api/Author/{authorToDelete.AuthorId}");
            if (resp.IsSuccessStatusCode)
            {
                var name = authorToDelete.AuthorName;
                await CloseDeleteModal();
                ShowAlert($"Đã xoá \"{name}\" thành công.", false);
                await LoadAuthors();
            }
            else { modalError = "Xoá thất bại. Tác giả có thể đang được dùng."; }
        }
        catch { modalError = "Lỗi kết nối. Vui lòng thử lại."; }
        finally { isSaving = false; }
    }

    private void ShowAlert(string msg, bool isError)
    {
        alertMsg = msg; alertIsError = isError;
        _ = Task.Delay(4000).ContinueWith(_ => { alertMsg = ""; InvokeAsync(StateHasChanged); });
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2 ? $"{parts[0][0]}{parts[^1][0]}".ToUpper() : name[0].ToString().ToUpper();
    }

    private string GetAvaColor(string name)
    {
        var colors = new[] { "#D4860B", "#2563A8", "#2E7D52", "#7B3F7B", "#C0392B", "#6B4C2A", "#1A6B5A", "#8B5A2B" };
        return colors[Math.Abs(name?.GetHashCode() ?? 0) % colors.Length];
    }

    public class AuthorDto
    {
        public int AuthorId { get; set; }
        public string AuthorName { get; set; } = "";
        public int? BirthYear { get; set; }
        public string? Nationality { get; set; }
    }

    public class AuthorFormModel
    {
        public string AuthorName { get; set; } = "";
        public int? BirthYear { get; set; }
        public string? Nationality { get; set; }
    }
}
