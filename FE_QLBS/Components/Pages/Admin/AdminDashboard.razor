                                                    {
                                                        <span class="badge bg-ok" style="margin-left:4px;font-size:.62rem">Hôm nay</span>
                                                    }
                                                </span>
                                            </td>
                                            <td><span class="rev-orders">@r.OrderCount.ToString("N0")</span></td>
                                            <td><span class="rev-books">@r.SoldBookCount.ToString("N0")</span></td>
                                            <td><span class="tbl-amt">@FormatRevenue(r.TotalRevenue)</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div style="text-align:center;padding:40px;color:var(--text-muted);font-size:.85rem">
                                <i class="bi bi-file-earmark-bar-graph" style="font-size:2rem;display:block;margin-bottom:8px"></i>
                                Chưa có báo cáo doanh thu nào.
                            </div>
                        }
                    </div>

                    <!-- Inventory & quick stats -->
                    <div class="adm-act-card">
                        <div class="card-hd" style="margin-bottom:16px">
                            <div>
                                <div class="card-title">Tình trạng kho</div>
                                <div class="card-sub">Cập nhật tự động</div>
                            </div>
                        </div>

                        <div class="act-item">
                            <div class="act-dot act-stock">📦</div>
                            <div>
                                <div class="act-text"><b>Hết hàng</b> — @_dashboard.OutOfStockBooks đầu sách</div>
                                <div class="act-time">
                                    <span class="badge @(_dashboard.OutOfStockBooks > 0 ? "bg-x" : "bg-ok")">
                                        @(_dashboard.OutOfStockBooks > 0 ? "Cần nhập thêm" : "Không có")
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="act-item">
                            <div class="act-dot act-order">⚠️</div>
                            <div>
                                <div class="act-text"><b>Sắp hết hàng</b> — @_dashboard.LowStockBooks đầu sách</div>
                                <div class="act-time">
                                    <span class="badge @(_dashboard.LowStockBooks > 5 ? "bg-pnd" : "bg-ok")">
                                        @(_dashboard.LowStockBooks > 5 ? "Cảnh báo" : "Bình thường")
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="act-item">
                            <div class="act-dot act-user">📈</div>
                            <div>
                                <div class="act-text">
                                    <b>Tăng trưởng doanh thu</b>
                                    @if (_dashboard.RevenueGrowthPercent > 0)
                                    {
                                        <span style="color:var(--green)"> +@_dashboard.RevenueGrowthPercent%</span>
                                    }
                                    else if (_dashboard.RevenueGrowthPercent < 0)
                                    {
                                        <span style="color:var(--red)"> @_dashboard.RevenueGrowthPercent%</span>
                                    }
                                    else
                                    {
                                        <span style="color:var(--text-muted)"> Không đổi</span>
                                    }
                                </div>
                                <div class="act-time"><i class="bi bi-calendar-month"></i> So với tháng trước</div>
                            </div>
                        </div>
                        <div class="act-item">
                            <div class="act-dot act-review">💰</div>
                            <div>
                                <div class="act-text"><b>Tháng trước</b> — @FormatRevenue(_dashboard.TotalRevenueLastMonth)</div>
                                <div class="act-time">
                                    <i class="bi bi-clock"></i>
                                    Tháng @DateTime.Now.AddMonths(-1).Month/@DateTime.Now.AddMonths(-1).Year
                                </div>
                            </div>
                        </div>
                        <div class="act-item" style="border-bottom:none">
                            <div class="act-dot act-order">📚</div>
                            <div>
                                <div class="act-text"><b>Sách bán tháng này</b> — @_dashboard.TotalBooksSoldThisMonth.ToString("N0") cuốn</div>
                                <div class="act-time"><i class="bi bi-graph-up"></i> @_dashboard.TotalOrdersThisMonth.ToString("N0") đơn hàng</div>
                            </div>
                        </div>

                        @if (_generateMessage != null)
                        {
                            <div style="margin-top:12px;padding:10px 12px;background:var(--green-dim);border-radius:8px;font-size:.78rem;color:var(--green);display:flex;align-items:center;gap:6px">
                                <i class="bi bi-check-circle-fill"></i> @_generateMessage
                            </div>
                        }
                    </div>
                </div>
            }

        </div>
    </div>
</div>

@code {
    // ── Models ───────────────────────────────────────────────
    private class DashboardSummaryDto
    {
        public decimal TotalRevenueThisMonth { get; set; }
        public decimal TotalRevenueLastMonth { get; set; }
        public decimal RevenueGrowthPercent { get; set; }
        public int TotalOrdersThisMonth { get; set; }
        public int TotalBooksSoldThisMonth { get; set; }
        public int OutOfStockBooks { get; set; }
        public int LowStockBooks { get; set; }
        public List<BestSellingBookDto> TopSellingBooks { get; set; } = new();
        public List<RevenueReportDto> RecentRevenueReports { get; set; } = new();
    }

    private class RevenueSummaryDto
    {
        public DateTime FromDate { get; set; }
        public DateTime ToDate { get; set; }
        public int TotalOrders { get; set; }
        public int TotalBooksSold { get; set; }
        public decimal TotalRevenue { get; set; }
        public decimal AverageRevenuePerDay { get; set; }
        public List<RevenueReportDto> Details { get; set; } = new();
    }

    private class RevenueReportDto
    {
        public int RevenueReportId { get; set; }
        public DateTime ReportDate { get; set; }
        public int OrderCount { get; set; }
        public int SoldBookCount { get; set; }
        public decimal TotalRevenue { get; set; }
    }

    private class BestSellingBookDto
    {
        public int BookId { get; set; }
        public string BookTitle { get; set; } = "";
        public string? CategoryName { get; set; }
        public int TotalSold { get; set; }
    }

    // ── State ────────────────────────────────────────────────
    private DashboardSummaryDto? _dashboard;
    private RevenueSummaryDto? _monthSummary;
    private bool _loading = true;
    private bool _loadingChart = false;
    private bool _generating = false;
    private string? _error;
    private string? _generateMessage;
    private int _selectedMonth = DateTime.Now.Month;
    private int _selectedYear = DateTime.Now.Year;
    private string _accessToken = "";

    // ── Lifecycle ────────────────────────────────────────────

    // KHÔNG dùng OnInitializedAsync vì JS chưa sẵn sàng lúc prerender
    protected override Task OnInitializedAsync() => Task.CompletedTask;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // 1. Đọc token từ localStorage
        _accessToken = await JS.InvokeAsync<string?>("localStorage.getItem", "accessToken") ?? "";

        // 2. Nếu chưa login → redirect về trang login
        if (string.IsNullOrEmpty(_accessToken))
        {
            await JS.InvokeVoidAsync("eval", "window.location.href='/admin/login'");
            return;
        }

        // 3. Gắn Bearer token vào tất cả request của HttpClient
        Http.DefaultRequestHeaders.Authorization =
            new AuthenticationHeaderValue("Bearer", _accessToken);

        // 4. Load dữ liệu dashboard
        await LoadDashboard();
    }

    // ── Data loading ─────────────────────────────────────────
    private async Task LoadDashboard()
    {
        _loading = true;
        _error = null;
        StateHasChanged();
        try
        {
            _dashboard = await Http.GetFromJsonAsync<DashboardSummaryDto>("api/ReportDashboard");
            await LoadMonthSummary(_selectedMonth, _selectedYear);
        }
        catch (Exception ex)
        {
            _error = $"Không thể tải dữ liệu dashboard: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    // Nút refresh — token đã được set sẵn trong DefaultRequestHeaders
    private async Task RefreshDashboard() => await LoadDashboard();

    private async Task LoadMonthSummary(int month, int year)
    {
        _loadingChart = true;
        StateHasChanged();
        try
        {
            _monthSummary = await Http.GetFromJsonAsync<RevenueSummaryDto>(
                $"api/RevenueReport/summary/month?month={month}&year={year}");
        }
        catch
        {
            _monthSummary = null;
        }
        finally
        {
            _loadingChart = false;
            StateHasChanged();
        }
    }

    private async Task OnMonthChanged()
    {
        await LoadMonthSummary(_selectedMonth, _selectedYear);
    }

    private async Task GenerateTodayReport()
    {
        _generating = true;
        _generateMessage = null;
        StateHasChanged();
        try
        {
            var result = await Http.PostAsync(
                $"api/RevenueReport/generate?date={DateTime.Today:yyyy-MM-dd}", null);
            if (result.IsSuccessStatusCode)
            {
                _generateMessage = "Đã tạo/cập nhật báo cáo hôm nay thành công!";
                await LoadDashboard();
            }
            else
            {
                _error = $"Không thể tạo báo cáo. (HTTP {(int)result.StatusCode})";
            }
        }
        catch (Exception ex)
        {
            _error = $"Lỗi tạo báo cáo: {ex.Message}";
        }
        finally
        {
            _generating = false;
            StateHasChanged();
            await Task.Delay(4000);
            _generateMessage = null;
            StateHasChanged();
        }
    }

    // ── Helpers ──────────────────────────────────────────────
    private static string FormatRevenue(decimal value)
    {
        if (value >= 1_000_000_000) return $"{value / 1_000_000_000:0.##}tỷ";
        if (value >= 1_000_000) return $"{value / 1_000_000:0.##}tr";
        if (value >= 1_000) return $"{value / 1_000:0.##}k";
        return value.ToString("N0") + "đ";
    }

    private static string GetGreeting()
    {
        var h = DateTime.Now.Hour;
        return h < 12 ? "sáng" : h < 18 ? "chiều" : "tối";
    }
}
