    <!-- ══ MAIN ══ -->
    <div class="adm-main">

        <header class="adm-topbar">
            <div>
                <div class="adm-topbar-title">Dashboard</div>
                <div class="adm-breadcrumb">Admin / <span>Tổng quan</span></div>
            </div>
            <div class="adm-search">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Tìm kiếm sách, đơn hàng..." />
            </div>
            <div class="adm-topbar-actions">
                <div class="adm-icon-btn">
                    <i class="bi bi-bell"></i><span class="adm-notif-dot"></span>
                </div>
                <div class="adm-icon-btn"><i class="bi bi-question-circle"></i></div>
                <div class="adm-avatar" style="width:34px;height:34px;font-size:.75rem;cursor:pointer;">AD</div>
            </div>
        </header>

        <div class="adm-body">

            <!-- Welcome -->
            <div class="adm-welcome">
                <div>
                    <h2>Chào buổi sáng, Admin 👋</h2>
                    <p>Tổng quan hoạt động của BookStore hôm nay.</p>
                </div>
                <div class="adm-date-chip">
                    <i class="bi bi-calendar3"></i> Thứ Tư, 11 tháng 3, 2026
                </div>
            </div>

            <!-- Stats -->
            <div class="adm-stats">
                <div class="stat-card s-amber">
                    <div class="stat-top">
                        <div class="stat-icon"><i class="bi bi-wallet2"></i></div>
                        <span class="stat-badge up"><i class="bi bi-arrow-up-short"></i>+18.4%</span>
                    </div>
                    <div class="stat-value">142.5tr</div>
                    <div class="stat-label">Doanh thu tháng này</div>
                    <div class="stat-sub">So với tháng trước: <b>120.4tr</b></div>
                </div>
                <div class="stat-card s-green">
                    <div class="stat-top">
                        <div class="stat-icon"><i class="bi bi-bag-check-fill"></i></div>
                        <span class="stat-badge up"><i class="bi bi-arrow-up-short"></i>+12.1%</span>
                    </div>
                    <div class="stat-value">1,284</div>
                    <div class="stat-label">Đơn hàng tháng này</div>
                    <div class="stat-sub">Đang xử lý: <b>47 đơn</b></div>
                </div>
                <div class="stat-card s-blue">
                    <div class="stat-top">
                        <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
                        <span class="stat-badge up"><i class="bi bi-arrow-up-short"></i>+8.6%</span>
                    </div>
                    <div class="stat-value">8,941</div>
                    <div class="stat-label">Khách hàng</div>
                    <div class="stat-sub">Mới tháng này: <b>+342</b></div>
                </div>
                <div class="stat-card s-red">
                    <div class="stat-top">
                        <div class="stat-icon"><i class="bi bi-journals"></i></div>
                        <span class="stat-badge down"><i class="bi bi-arrow-down-short"></i>-5.2%</span>
                    </div>
                    <div class="stat-value">3,672</div>
                    <div class="stat-label">Sách tồn kho</div>
                    <div class="stat-sub">Sắp hết hàng: <b>14 đầu sách</b></div>
                </div>
            </div>

            <!-- Mid -->
            <div class="adm-mid">
                <!-- Chart -->
                <div class="adm-card" style="animation-delay:.20s">
                    <div class="adm-card-body">
                        <div class="card-hd">
                            <div>
                                <div class="card-title">Doanh thu theo tháng</div>
                                <div class="card-sub">Năm 2025 — đơn vị: triệu đồng</div>
                            </div>
                            <div class="tab-row">
                                <button class="tab-btn on">Năm</button>
                                <button class="tab-btn">Quý</button>
                                <button class="tab-btn">Tháng</button>
                            </div>
                        </div>
                        <div class="bar-chart">
                            @{
                                var months = new[] { "T1", "T2", "T3", "T4", "T5", "T6", "T7", "T8", "T9", "T10", "T11", "T12" };
                                var vals = new[] { 68, 82, 74, 95, 88, 110, 102, 120, 108, 130, 118, 143 };
                                var maxV = vals.Max();
                            }
                            @for (int i = 0; i < 12; i++)
                            {
                                var pct = (int)((double)vals[i] / maxV * 100);
                                <div class="bar-col">
                                    <div class="bar @(i == 11 ? "hi" : "lo")" style="height:@(pct)%" title="@months[i]: @vals[i]tr đ"></div>
                                    <span class="bar-lbl">@months[i]</span>
                                </div>
                            }
                        </div>
                        <div class="chart-leg">
                            <div class="leg-item"><div class="leg-dot" style="background:var(--amber)"></div>Tháng hiện tại</div>
                            <div class="leg-item"><div class="leg-dot" style="background:var(--border2)"></div>Các tháng trước</div>
                        </div>
                    </div>
                </div>

                <!-- Top books -->
                <div class="adm-card" style="animation-delay:.25s">
                    <div class="adm-card-body">
                        <div class="card-hd">
                            <div>
                                <div class="card-title">Sách bán chạy</div>
                                <div class="card-sub">Tháng 3/2026</div>
                            </div>
                            <button class="btn btn-outline" style="font-size:.72rem;padding:4px 10px">Tất cả</button>
                        </div>
                        @{
                            var books = new[] {
                        ("Đắc Nhân Tâm","Kỹ năng sống","482","#D4860B"),
                        ("Nhà Giả Kim","Văn học","391","#2563A8"),
                        ("Atomic Habits","Phát triển bản thân","337","#2E7D52"),
                        ("Sapiens","Lịch sử","284","#7B3F7B"),
                        ("Tư Duy Nhanh & Chậm","Tâm lý học","241","#C0392B"),
                        };
                            var rkCls = new[] { "rk1", "rk2", "rk3", "rkn", "rkn" };
                        }
                        @for (int i = 0; i < books.Length; i++)
                        {
                            var (bname, bcat, bsold, bcol) = books[i];
                            <div class="top-item">
                                <div class="top-rank @rkCls[i]">@(i + 1)</div>
                                <div class="top-cover" style="background:@(bcol)18;">📖</div>
                                <div style="flex:1;min-width:0">
                                    <div class="top-name">@bname</div>
                                    <div class="top-cat">@bcat</div>
                                </div>
                                <div class="top-sold">@bsold</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Bottom -->
            <div class="adm-bottom">

                <!-- Table -->
                <div class="adm-tbl-card">
                    <div class="tbl-hd">
                        <div>
                            <div class="card-title">Đơn hàng gần đây</div>
                            <div class="card-sub">12 đơn đang chờ xử lý</div>
                        </div>
                        <div style="display:flex;gap:7px">
                            <button class="btn btn-outline"><i class="bi bi-funnel"></i> Lọc</button>
                            <button class="btn btn-primary"><i class="bi bi-arrow-right"></i> Xem tất cả</button>
                        </div>
                    </div>
                    <table class="adm-tbl">
                        <thead>
                            <tr>
                                <th>Mã đơn</th>
                                <th>Khách hàng</th>
                                <th>Sản phẩm</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                                <th>Ngày đặt</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var orders = new[] {
                            ("#DH-8821","Nguyễn Văn A","NA","3 cuốn","680.000đ","ok","Hoàn thành","10/03","#D4860B"),
                            ("#DH-8820","Trần Thị B",  "TB","1 cuốn","149.000đ","pnd","Chờ xử lý","10/03","#2563A8"),
                            ("#DH-8819","Lê Minh C",   "LM","5 cuốn","1.250.000đ","shp","Đang giao","09/03","#2E7D52"),
                            ("#DH-8818","Phạm Thu D",  "PT","2 cuốn","390.000đ","ok","Hoàn thành","09/03","#7B3F7B"),
                            ("#DH-8817","Hoàng Văn E", "HV","4 cuốn","820.000đ","x","Đã huỷ","08/03","#C0392B"),
                            ("#DH-8816","Vũ Thị F",    "VT","1 cuốn","220.000đ","pnd","Chờ xử lý","08/03","#D4860B"),
                            };
                            }
                            @foreach (var (oid, oname, oinit, oitem, oamt, ost, ostxt, odate, ocol) in orders)
                            {
                                var bc = ost switch { "ok" => "bg-ok", "pnd" => "bg-pnd", "x" => "bg-x", _ => "bg-shp" };
                                <tr>
                                    <td><span class="tbl-id">@oid</span></td>
                                    <td>
                                        <div class="tbl-cust">
                                            <div class="mini-av" style="background:@ocol">@oinit</div>
                                            @oname
                                        </div>
                                    </td>
                                    <td>@oitem</td>
                                    <td><span class="tbl-amt">@oamt</span></td>
                                    <td><span class="badge @bc">@ostxt</span></td>
                                    <td>@odate</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Activity -->
                <div class="adm-act-card">
                    <div class="card-hd" style="margin-bottom:16px">
                        <div>
                            <div class="card-title">Hoạt động</div>
                            <div class="card-sub">Cập nhật gần nhất</div>
                        </div>
                    </div>
                    @{
                        var acts = new[] {
                    ("act-order","🛍️","Đơn hàng mới","#DH-8821 từ Nguyễn Văn A","2 phút trước"),
                    ("act-user","👤","Khách hàng mới","Trần Thị B vừa đăng ký","15 phút trước"),
                    ("act-review","⭐","Đánh giá 5★","Cho cuốn Đắc Nhân Tâm","1 giờ trước"),
                    ("act-stock","⚠️","Cảnh báo kho","Nhà Giả Kim còn 3 cuốn","2 giờ trước"),
                    ("act-order","🛍️","Giao thành công","#DH-8815 đã hoàn tất","3 giờ trước"),
                    ("act-user","💬","Phản hồi mới","Hỏi về chính sách đổi trả","5 giờ trước"),
                    };
                    }
                    @foreach (var (atype, aemo, atitle, adesc, atime) in acts)
                    {
                        <div class="act-item">
                            <div class="act-dot @atype">@aemo</div>
                            <div>
                                <div class="act-text"><b>@atitle</b> — @adesc</div>
                                <div class="act-time"><i class="bi bi-clock"></i> @atime</div>
                            </div>
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>
</div>

@code { }
