                    </div>

                    <div class="stat-card s-blue">
                        <div class="stat-top">
                            <div class="stat-icon"><i class="bi bi-box-seam-fill"></i></div>
                            <span class="stat-badge @(_dashboard.LowStockBooks > 0 ? "down" : "up")">
                                <i class="bi @(_dashboard.LowStockBooks > 0 ? "bi-exclamation-triangle" : "bi-check-circle")"></i>
                                @(_dashboard.LowStockBooks > 0 ? "Cảnh báo" : "Tốt")
                            </span>
                        </div>
                        <div class="stat-value">@_dashboard.LowStockBooks</div>
                        <div class="stat-label">Sách sắp hết hàng</div>
                        <div class="stat-sub">Hết hàng hoàn toàn: <b>@_dashboard.OutOfStockBooks đầu sách</b></div>
                    </div>

                    <div class="stat-card s-red">
                        <div class="stat-top">
                            <div class="stat-icon"><i class="bi bi-journals"></i></div>
                            <span class="stat-badge neutral"><i class="bi bi-book"></i>Tháng này</span>
                        </div>
                        <div class="stat-value">@_dashboard.TotalBooksSoldThisMonth.ToString("N0")</div>
                        <div class="stat-label">Sách bán ra tháng này</div>
                        <div class="stat-sub">TB/ngày: <b>@FormatRevenue(_dashboard.TotalRevenueThisMonth / Math.Max(1, DateTime.Now.Day))</b></div>
                    </div>
                </div>

                <!-- ══ MID ROW ══ -->
                <div class="adm-mid">

                    <!-- Revenue chart -->
                    <div class="adm-card" style="animation-delay:.20s">
                        <div class="adm-card-body">
                            <div class="card-hd">
                                <div>
                                    <div class="card-title">Doanh thu theo ngày</div>
                                    <div class="card-sub">
                                        Tháng @_selectedMonth/@_selectedYear
                                        @if (_monthSummary != null)
                                        {
                                            <span> — Tổng: <b style="color:var(--amber)">@FormatRevenue(_monthSummary.TotalRevenue)</b></span>
                                        }
                                    </div>
                                </div>
                                <div class="month-selector">
                                    <i class="bi bi-calendar2-month" style="color:var(--amber)"></i>
                                    <select @bind="_selectedMonth" @bind:after="OnMonthChanged">
                                        @for (int m = 1; m <= 12; m++)
                                        {
                                            <option value="@m">T@m</option>
                                        }
                                    </select>
                                    <select @bind="_selectedYear" @bind:after="OnMonthChanged">
                                        @for (int y = DateTime.Now.Year - 2; y <= DateTime.Now.Year; y++)
                                        {
                                            <option value="@y">@y</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            @if (_monthSummary?.Details != null && _monthSummary.Details.Any())
                            {
                                var details = _monthSummary.Details.OrderBy(d => d.ReportDate).ToList();
                                var maxRev = details.Max(d => (double)d.TotalRevenue);

                                <div class="summary-strip">
                                    <div class="sum-pill">
                                        <div class="sum-pill-val">@_monthSummary.TotalOrders.ToString("N0")</div>
                                        <div class="sum-pill-lbl">Đơn hàng</div>
                                    </div>
                                    <div class="sum-pill">
                                        <div class="sum-pill-val">@_monthSummary.TotalBooksSold.ToString("N0")</div>
                                        <div class="sum-pill-lbl">Sách bán</div>
                                    </div>
                                    <div class="sum-pill">
                                        <div class="sum-pill-val">@FormatRevenue(_monthSummary.AverageRevenuePerDay)</div>
                                        <div class="sum-pill-lbl">TB/ngày</div>
                                    </div>
                                    <div class="sum-pill">
                                        <div class="sum-pill-val">@details.Count</div>
                                        <div class="sum-pill-lbl">Ngày có DT</div>
                                    </div>
                                </div>

                                <div class="bar-chart">
                                    @foreach (var d in details)
                                    {
                                        var pct = maxRev > 0 ? (int)((double)d.TotalRevenue / maxRev * 100) : 0;
                                        var isToday = d.ReportDate.Date == DateTime.Today;
                                        <div class="bar-col">
                                            <div class="bar @(isToday ? "hi" : "lo")"
                                                 style="height:@(pct)%"
                                                 title="@d.ReportDate.ToString("dd/MM"): @FormatRevenue(d.TotalRevenue) | @d.OrderCount đơn"></div>
                                            <span class="bar-lbl">@d.ReportDate.Day</span>
                                        </div>
                                    }
                                </div>
                                <div class="chart-leg">
                                    <div class="leg-item"><div class="leg-dot" style="background:var(--amber)"></div>Hôm nay</div>
                                    <div class="leg-item"><div class="leg-dot" style="background:var(--border2)"></div>Các ngày khác</div>
                                </div>
                            }
                            else if (_loadingChart)
                            {
                                <div class="loading-overlay" style="padding:30px">
                                    <div class="spinner"></div>
                                    <span>Đang tải biểu đồ...</span>
                                </div>
                            }
                            else
                            {
                                <div style="text-align:center;padding:40px;color:var(--text-muted);font-size:.85rem">
                                    <i class="bi bi-bar-chart" style="font-size:2rem;display:block;margin-bottom:8px"></i>
                                    Chưa có dữ liệu doanh thu cho tháng này.
                                    <br />
                                    <button class="btn btn-primary btn-sm" style="margin-top:10px" @onclick="GenerateTodayReport">
                                        <i class="bi bi-lightning-fill"></i> Tạo báo cáo hôm nay
                                    </button>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Top selling books -->
                    <div class="adm-card" style="animation-delay:.25s">
                        <div class="adm-card-body">
                            <div class="card-hd">
                                <div>
                                    <div class="card-title">Sách bán chạy</div>
                                    <div class="card-sub">Tháng @DateTime.Now.Month/@DateTime.Now.Year</div>
                                </div>
                                <button class="btn btn-outline" style="font-size:.72rem;padding:4px 10px">Tất cả</button>
                            </div>
                            @{
                                var rkCls = new[] { "rk1", "rk2", "rk3", "rkn", "rkn" };
                                var coverColors = new[] { "#D4860B", "#2563A8", "#2E7D52", "#7B3F7B", "#C0392B" };
                            }
                            @if (_dashboard.TopSellingBooks != null && _dashboard.TopSellingBooks.Any())
                            {
                                @for (int i = 0; i < Math.Min(5, _dashboard.TopSellingBooks.Count); i++)
                                {
                                    var book = _dashboard.TopSellingBooks[i];
                                    <div class="top-item">
                                        <div class="top-rank @rkCls[i]">@(i + 1)</div>
                                        <div class="top-cover" style="background:@(coverColors[i % coverColors.Length])18;">📖</div>
                                        <div style="flex:1;min-width:0">
                                            <div class="top-name" title="@book.BookTitle">@book.BookTitle</div>
                                            <div class="top-cat">@(book.CategoryName ?? "—")</div>
                                        </div>
                                        <div class="top-sold">@book.TotalSold</div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div style="text-align:center;padding:30px;color:var(--text-muted);font-size:.82rem">
                                    <i class="bi bi-book" style="font-size:1.5rem;display:block;margin-bottom:6px"></i>
                                    Chưa có dữ liệu sách bán chạy.
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- ══ BOTTOM ROW ══ -->
                <div class="adm-bottom">

                    <!-- Revenue reports table -->
                    <div class="adm-tbl-card">
                        <div class="tbl-hd">
                            <div>
                                <div class="card-title">Báo cáo doanh thu gần đây</div>
                                <div class="card-sub">
                                    @if (_monthSummary != null)
                                    {
                                        <span>@_monthSummary.Details?.Count báo cáo trong tháng</span>
                                    }
                                </div>
                            </div>
                            <div style="display:flex;gap:7px">
                                <a href="/admin/analytics" class="btn btn-outline">
                                    <i class="bi bi-bar-chart-line"></i> Thống kê đầy đủ
                                </a>
                                <button class="btn btn-primary" @onclick="GenerateTodayReport" disabled="@_generating">
                                    <i class="bi bi-lightning-fill"></i> @(_generating ? "Đang tạo..." : "Tạo hôm nay")
                                </button>
                            </div>
                        </div>
                        @if (_dashboard.RecentRevenueReports != null && _dashboard.RecentRevenueReports.Any())
                        {
                            <table class="adm-tbl">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Ngày báo cáo</th>
                                        <th>Số đơn hàng</th>
                                        <th>Sách bán ra</th>
                                        <th>Doanh thu</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in _dashboard.RecentRevenueReports.OrderByDescending(x => x.ReportDate))
                                    {
                                        var isToday = r.ReportDate.Date == DateTime.Today;
                                        <tr>
                                            <td><span class="tbl-id">#@r.RevenueReportId</span></td>
                                            <td>
                                                <span class="rev-date">
                                                    @r.ReportDate.ToString("dd/MM/yyyy")
