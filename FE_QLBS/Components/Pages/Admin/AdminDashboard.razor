                </div>
                <div class="loading-overlay">
                    <div class="spinner"></div>
                    <span>Đang tải dữ liệu dashboard...</span>
                </div>
            }
            else if (_dashboard != null)
            {
                <!-- ══ STATS ══ -->
                <div class="adm-stats">
                    <div class="stat-card s-amber">
                        <div class="stat-top">
                            <div class="stat-icon"><i class="bi bi-wallet2"></i></div>
