@code {
    private List<BookVm> books = new();
    private List<string> categoryOptions = new();
    private HashSet<int> wishlist = new();
    private int cartCount = 0;

    private bool isLoading = true;
    private bool isGridView = true;
    private string searchText = "";
    private string globalSearch = "";
    private string filterCategory = "";
    private string sortBy = "newest";

    private bool showToast = false;
    private string toastMessage = "";
    private string newsletterEmail = "";
    private string newsletterMsg = "";

    protected override void OnInitialized() => isLoading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await LoadBooks();
        StateHasChanged();
    }

    private async Task LoadBooks()
    {
        isLoading = true;
        try
        {
            var result = await Http.GetFromJsonAsync<List<ApiBookDto>>("api/book");
            if (result != null)
            {
                books = result
                    .OrderByDescending(b => b.BookId)
                    .Select(b => new BookVm
                        {
                            BookId = b.BookId,
                            Title = b.BookTitle ?? "Không rõ tên",
                            AuthorName = b.AuthorName ?? "Không rõ tác giả",
                            CategoryName = b.CategoryName ?? "Chưa phân loại",
                            Price = b.Price,
                            ImageUrl = !string.IsNullOrEmpty(b.ImageUrl)
                                            ? b.ImageUrl
                                            : "https://images.unsplash.com/photo-1544947950-fa07a98d237f?w=300&h=400&fit=crop",
                            IsBestSeller = b.IsBestSeller,
                        }).ToList();

                categoryOptions = books.Select(b => b.CategoryName).Distinct().OrderBy(c => c).ToList();
            }
        }
        catch { }
        finally { isLoading = false; }
    }

    private IEnumerable<BookVm> FilteredBooks
    {
        get
        {
            var q = books.AsEnumerable();
            var kw = !string.IsNullOrWhiteSpace(globalSearch) ? globalSearch.Trim()
                   : !string.IsNullOrWhiteSpace(searchText) ? searchText.Trim() : "";

            if (!string.IsNullOrEmpty(kw))
                q = q.Where(b =>
                    b.Title.Contains(kw, StringComparison.OrdinalIgnoreCase) ||
                    b.AuthorName.Contains(kw, StringComparison.OrdinalIgnoreCase) ||
                    b.CategoryName.Contains(kw, StringComparison.OrdinalIgnoreCase));

            if (!string.IsNullOrEmpty(filterCategory))
                q = q.Where(b => b.CategoryName == filterCategory);

            return sortBy switch
            {
                "oldest" => q.OrderBy(b => b.BookId),
                "price_asc" => q.OrderBy(b => b.Price),
                "price_desc" => q.OrderByDescending(b => b.Price),
                "name" => q.OrderBy(b => b.Title),
                _ => q.OrderByDescending(b => b.BookId),
            };
        }
    }

    private void ToggleWishlist(int bookId)
    {
        if (wishlist.Contains(bookId)) wishlist.Remove(bookId);
        else wishlist.Add(bookId);
    }

    private async Task AddToCart(int bookId, string title)
    {
        cartCount++;
        await ShowToast($"Đã thêm \"{(title.Length > 30 ? title[..30] + "…" : title)}\" vào giỏ hàng");
    }

    private async Task ShowToast(string msg)
    {
        toastMessage = msg; showToast = true; StateHasChanged();
        await Task.Delay(3000);
        showToast = false; StateHasChanged();
    }

    private async Task SubscribeNewsletter()
    {
        if (string.IsNullOrWhiteSpace(newsletterEmail)) return;
        newsletterMsg = "Đăng ký thành công! Cảm ơn bạn.";
        newsletterEmail = "";
        await Task.CompletedTask;
    }

    private class BookVm
    {
        public int BookId { get; set; }
        public string Title { get; set; } = "";
        public string AuthorName { get; set; } = "";
        public string CategoryName { get; set; } = "";
        public decimal Price { get; set; }
        public string ImageUrl { get; set; } = "";
        public bool IsBestSeller { get; set; }
    }

    private class ApiBookDto
    {
        public int BookId { get; set; }
        public string? BookTitle { get; set; }
        public string? AuthorName { get; set; }
        public string? CategoryName { get; set; }
        public decimal Price { get; set; }
        public string? ImageUrl { get; set; }
        public bool IsBestSeller { get; set; }
    }
}
