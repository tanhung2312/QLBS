<!-- FILTER BAR -->
<div class="filter-bar">
    <div class="max-w-7xl mx-auto px-5 flex items-center gap-3 flex-wrap">
        <div class="filter-search">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Tìm tên sách, tác giả..."
                   @bind="searchText" @bind:event="oninput" />
        </div>

        <select class="filter-select" @bind="filterCategory">
            <option value="">Tất cả danh mục</option>
            @foreach (var cat in categoryOptions)
            {
                <option value="@cat">@cat</option>
            }
        </select>

        <select class="filter-select" @bind="sortBy">
            <option value="newest">Mới nhất</option>
            <option value="oldest">Cũ nhất</option>
            <option value="price_asc">Giá thấp → cao</option>
            <option value="price_desc">Giá cao → thấp</option>
            <option value="name">Tên A → Z</option>
        </select>

        <div class="ml-auto flex items-center gap-3 flex-shrink-0">
            <span style="font-size:.82rem;color:var(--text-muted);">
                <b style="color:var(--text-sec);">@FilteredBooks.Count()</b> kết quả
            </span>
            <div class="view-toggle">
                <button class="view-btn @(isGridView?"on":"")" @onclick="@(()=>isGridView=true)" title="Lưới">
                    <i class="bi bi-grid-3x3-gap-fill"></i>
                </button>
                <button class="view-btn @(!isGridView?"on":"")" @onclick="@(()=>isGridView=false)" title="Danh sách">
                    <i class="bi bi-list-ul"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- MAIN CONTENT -->
<section style="padding:40px 0 64px;background:var(--bg);">
    <div class="max-w-7xl mx-auto px-5">

        @if (isLoading)
        {
            <div class="book-grid">
                @for (int s = 0; s < 8; s++)
                {
                    <div style="background:var(--surface);border:1px solid var(--border);border-radius:18px;overflow:hidden;">
                        <div class="skel" style="height:220px;border-radius:0;"></div>
                        <div style="padding:14px 16px;">
                            <div class="skel" style="height:11px;width:40%;margin-bottom:8px;"></div>
                            <div class="skel" style="height:16px;width:85%;margin-bottom:5px;"></div>
                            <div class="skel" style="height:16px;width:60%;margin-bottom:10px;"></div>
                            <div class="skel" style="height:12px;width:50%;margin-bottom:14px;"></div>
                            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                                <div class="skel" style="height:22px;width:80px;"></div>
                                <div class="skel" style="height:14px;width:60px;"></div>
                            </div>
                            <div class="skel" style="height:38px;border-radius:12px;margin-top:12px;"></div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (!FilteredBooks.Any())
        {
            <div class="empty-state">
                <div style="font-size:4rem;opacity:.45;margin-bottom:16px;">📭</div>
                <h3>@(string.IsNullOrEmpty(searchText) ? "Chưa có sách nào" : "Không tìm thấy kết quả")</h3>
                <p>@(string.IsNullOrEmpty(searchText) ? "Hệ thống chưa có sách mới nào." : $"Không có sách nào khớp với \"{searchText}\".")</p>
            </div>
        }
        else if (isGridView)
        {
            <div class="book-grid">
                @foreach (var (book, idx) in FilteredBooks.Select((b, i) => (b, i)))
                {
                    <div class="book-card" style="animation-delay:@(idx * 0.05)s;">
                        <div class="book-cover">
                            <img src="@book.ImageUrl" alt="@book.Title" loading="lazy" />
                            <div class="cover-gradient"></div>
                            <span class="book-badge-new">Mới</span>
                            @if (book.IsBestSeller)
                            {
                                <span class="book-badge-bs"><i class="bi bi-trophy-fill" style="font-size:.55rem;"></i>Best Seller</span>
                            }
                            <div class="book-actions">
                                <button class="action-btn @(wishlist.Contains(book.BookId)?"wishlisted":"")"
                                        @onclick="()=>ToggleWishlist(book.BookId)" title="Yêu thích">
                                    <i class="bi @(wishlist.Contains(book.BookId)?"bi-heart-fill":"bi-heart")"></i>
                                </button>
                                <a href="/book/@book.BookId" class="action-btn" title="Xem chi tiết">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </div>
                        </div>
                        <div class="book-body">
                            <div class="book-cat">@book.CategoryName</div>
                            <div class="book-title">@book.Title</div>
                            <div class="book-author">
                                <i class="bi bi-person" style="font-size:.7rem;"></i>@book.AuthorName
                            </div>
                            <div class="book-footer">
                                <div class="book-price">@book.Price.ToString("#,##0")<sub>đ</sub></div>
                                <div class="book-stars">
                                    @for (int r = 0; r < 5; r++)
                                    {
                                        <i class="bi bi-star-fill"></i>
                                    }
                                </div>
                            </div>
                            <button class="btn-cart" @onclick="()=>AddToCart(book.BookId, book.Title)">
                                <i class="bi bi-bag-plus"></i> Thêm vào giỏ
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="book-list">
                @foreach (var (book, idx) in FilteredBooks.Select((b, i) => (b, i)))
                {
                    <div class="book-list-item" style="animation-delay:@(idx * 0.04)s;">
                        <div class="list-cover">
                            <img src="@book.ImageUrl" alt="@book.Title" loading="lazy" />
                        </div>
                        <div class="list-body">
                            <div class="list-title">@book.Title</div>
                            <div class="list-author"><i class="bi bi-person me-1" style="font-size:.72rem;"></i>@book.AuthorName</div>
                            <span class="list-cat">@book.CategoryName</span>
                        </div>
                        <div class="list-right">
                            <div class="list-price">@book.Price.ToString("#,##0")đ</div>
                            <div style="display:flex;gap:8px;justify-content:flex-end;">
                                <button class="action-btn" style="width:34px;height:34px;border-radius:9px;background:var(--bg);border:1.5px solid var(--border);"
                                        @onclick="()=>ToggleWishlist(book.BookId)">
                                    <i class="bi @(wishlist.Contains(book.BookId)?"bi-heart-fill":"bi-heart")"
                                       style="@(wishlist.Contains(book.BookId)?"color:var(--red)":"")"></i>
                                </button>
                                <button class="list-btn" @onclick="()=>AddToCart(book.BookId, book.Title)">
                                    <i class="bi bi-bag-plus"></i> Thêm giỏ
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

