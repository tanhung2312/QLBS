            <a href="/login" class="flex items-center gap-2 text-white rounded-full px-5 py-2 text-sm font-semibold no-underline transition-colors"
               style="background:var(--brown);font-family:'Plus Jakarta Sans',sans-serif;box-shadow:0 2px 10px rgba(107,76,42,.2);"
               onmouseover="this.style.background='var(--amber)'"
               onmouseout="this.style.background='var(--brown)'">
