@page "/books/bestseller"
@rendermode InteractiveServer
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Sách Bán Chạy - BookStore</PageTitle>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<script src="https://cdn.tailwindcss.com"></script>

<style>
    :root {
        --ink: #0D0B08;
        --gold: #C9960A;
        --gold2: #E8AF1A;
        --sand: #EAE3D9;
        --surface: #F9F6F1;
        --card: #FFFFFF;
        --muted: #7C6F5E;
        --pale: #B0A496;
        --coral: #C94444;
        --forest: #2D6A4F;
        --fog: rgba(249,246,241,0.96);
    }

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        font-family: 'Outfit', sans-serif;
        background: var(--surface);
        color: var(--ink);
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
    }

    ::-webkit-scrollbar {
        width: 4px;
    }

    ::-webkit-scrollbar-track {
        background: var(--surface);
    }

    ::-webkit-scrollbar-thumb {
        background: var(--sand);
        border-radius: 8px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--gold);
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(20px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    @@keyframes shimmer {
        0% {
            background-position: -600px 0
        }

        100% {
            background-position: 600px 0
        }
    }

    @@keyframes dropIn {
        from {
            opacity: 0;
            transform: translateY(-8px) scale(.97)
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1)
        }
    }

    @@keyframes glowPulse {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(201,150,10,.3)
        }

        50% {
            box-shadow: 0 0 0 8px rgba(201,150,10,0)
        }
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0)
        }

        50% {
            transform: translateY(-8px)
        }
    }

    @@keyframes rankIn {
        from {
            opacity: 0;
            transform: scale(.6) rotate(-10deg)
        }

        to {
            opacity: 1;
            transform: scale(1) rotate(0deg)
        }
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(24px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    @@keyframes toastIn {
        from {
            opacity: 0;
            transform: translateY(12px) scale(.96)
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1)
        }
    }

    .a1 {
        animation: fadeUp .5s cubic-bezier(.22,1,.36,1) .04s both
    }

    .a2 {
        animation: fadeUp .5s cubic-bezier(.22,1,.36,1) .10s both
    }

    .skel {
        background: linear-gradient(90deg, #EAE3D9 25%, #F5F0EA 50%, #EAE3D9 75%);
        background-size: 600px 100%;
        animation: shimmer 1.5s infinite;
        border-radius: 10px;
    }

    /* ── Nav ── */
    .nav-a {
        color: rgba(13,11,8,.5);
        text-decoration: none;
        font-size: .85rem;
        font-weight: 500;
        padding: 6px 14px;
        border-radius: 8px;
        transition: all .15s;
    }

        .nav-a:hover {
            color: var(--ink);
            background: rgba(13,11,8,.05);
        }

        .nav-a.active {
            color: var(--gold);
        }

    /* ── Hero ── */
    .hero-bg {
        position: relative;
        overflow: hidden;
        background: linear-gradient(145deg, #0D0B08 0%, #1E1408 45%, #2E1E0A 100%);
    }

        .hero-bg::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 55% 70% at 90% 40%, rgba(201,150,10,.2) 0%, transparent 65%), radial-gradient(ellipse 30% 40% at 5% 90%, rgba(201,150,10,.08) 0%, transparent 60%);
            pointer-events: none;
        }

        .hero-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(255,255,255,.022) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.022) 1px, transparent 1px);
            background-size: 52px 52px;
            pointer-events: none;
        }

    /* Floating trophy deco */
    .deco {
        position: absolute;
        border-radius: 50%;
        animation: float 7s ease-in-out infinite;
        pointer-events: none;
    }

    /* ── Filter chip ── */
    .chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 7px 16px;
        border-radius: 50px;
        font-size: .78rem;
        font-weight: 600;
        border: 1.5px solid var(--sand);
        background: var(--card);
        color: var(--muted);
        cursor: pointer;
        transition: all .18s;
        white-space: nowrap;
    }

        .chip:hover {
            border-color: var(--gold);
            color: #8C6A00;
            background: rgba(201,150,10,.06);
        }

        .chip.active {
            border-color: var(--gold);
            color: #8C6A00;
            background: rgba(201,150,10,.11);
        }

    /* ── View toggle ── */
    .vtog {
        display: flex;
        gap: 3px;
        background: var(--surface);
        border: 1.5px solid var(--sand);
        border-radius: 10px;
        padding: 3px;
    }

    .vbtn {
        width: 32px;
        height: 32px;
        border: none;
        border-radius: 7px;
        cursor: pointer;
        color: var(--pale);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .85rem;
        background: transparent;
        transition: all .15s;
    }

        .vbtn.on {
            background: var(--card);
            color: var(--ink);
            box-shadow: 0 1px 4px rgba(13,11,8,.1);
        }

    /* ── Book CARD (grid) ── */
    .bk-card {
        background: var(--card);
        border: 1px solid var(--sand);
        border-radius: 18px;
        overflow: hidden;
        transition: all .28s cubic-bezier(.22,1,.36,1);
        position: relative;
        cursor: pointer;
        animation: slideUp .45s cubic-bezier(.22,1,.36,1) both;
    }

        .bk-card:hover {
            transform: translateY(-7px);
            box-shadow: 0 22px 52px rgba(13,11,8,.13);
            border-color: rgba(201,150,10,.35);
        }

    .bk-img {
        position: relative;
        overflow: hidden;
    }

        .bk-img img {
            width: 100%;
            aspect-ratio: 3/4;
            object-fit: cover;
            display: block;
            transition: transform .5s;
        }

    .bk-card:hover .bk-img img {
        transform: scale(1.06);
    }

    /* Gradient overlay */
    .bk-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 40%, rgba(13,11,8,.72) 100%);
    }

    /* ── Rank badge ── */
    .rank-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .78rem;
        font-weight: 800;
        z-index: 3;
        animation: rankIn .4s cubic-bezier(.22,1,.36,1) both;
    }

    .rank-1 {
        background: linear-gradient(135deg,#FFD700,#FFA500);
        color: #3D2000;
        box-shadow: 0 4px 14px rgba(255,165,0,.5);
    }

    .rank-2 {
        background: linear-gradient(135deg,#C0C0C0,#A8A8A8);
        color: #2A2A2A;
        box-shadow: 0 4px 12px rgba(160,160,160,.4);
    }

    .rank-3 {
        background: linear-gradient(135deg,#CD7F32,#A0522D);
        color: #fff;
        box-shadow: 0 4px 12px rgba(160,100,50,.4);
    }

    .rank-n {
        background: rgba(13,11,8,.55);
        backdrop-filter: blur(6px);
        color: rgba(255,255,255,.8);
        border: 1px solid rgba(255,255,255,.15);
    }

    /* Price on image */
    .price-tag {
        position: absolute;
        bottom: 10px;
        left: 12px;
        font-family: 'Playfair Display', serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: #fff;
        z-index: 2;
        text-shadow: 0 2px 8px rgba(0,0,0,.5);
    }

    /* Wishlist btn */
    .wish-btn {
        position: absolute;
        bottom: 10px;
        right: 10px;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: rgba(255,255,255,.15);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,.25);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: .8rem;
        cursor: pointer;
        transition: all .2s;
        z-index: 3;
    }

        .wish-btn:hover, .wish-btn.on {
            background: rgba(201,68,68,.85);
            border-color: transparent;
        }

        .wish-btn.on {
            animation: glowPulse .4s ease;
        }

    /* Card body */
    .bk-body {
        padding: 14px 16px 16px;
    }

    .bk-cat {
        font-size: .63rem;
        font-weight: 800;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 5px;
    }

    .bk-title {
        font-family: 'Playfair Display', serif;
        font-size: .97rem;
        font-weight: 700;
        color: var(--ink);
        line-height: 1.25;
        margin-bottom: 5px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .bk-author {
        font-size: .73rem;
        color: var(--muted);
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .btn-cart {
        width: 100%;
        height: 40px;
        border-radius: 10px;
        border: none;
        background: var(--ink);
        color: #fff;
        font-family: 'Outfit', sans-serif;
        font-size: .8rem;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        transition: all .2s;
    }

        .btn-cart:hover {
            background: var(--gold);
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(201,150,10,.35);
        }

    /* ── LIST row ── */
    .bk-row {
        display: flex;
        gap: 16px;
        align-items: center;
        background: var(--card);
        border: 1px solid var(--sand);
        border-radius: 16px;
        padding: 14px;
        cursor: pointer;
        transition: all .22s cubic-bezier(.22,1,.36,1);
        position: relative;
        overflow: hidden;
        animation: slideUp .4s cubic-bezier(.22,1,.36,1) both;
    }

        .bk-row::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 3px;
            background: linear-gradient(180deg, var(--gold), var(--gold2));
            border-radius: 0 2px 2px 0;
            transform: scaleY(0);
            transition: transform .22s;
        }

        .bk-row:hover {
            border-color: rgba(201,150,10,.35);
            box-shadow: 0 6px 24px rgba(13,11,8,.08);
            transform: translateX(4px);
        }

            .bk-row:hover::before {
                transform: scaleY(1);
            }

    .bk-row-img {
        width: 70px;
        flex-shrink: 0;
        border-radius: 10px;
        overflow: hidden;
        aspect-ratio: 3/4;
        position: relative;
    }

        .bk-row-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform .3s;
        }

    .bk-row:hover .bk-row-img img {
        transform: scale(1.06);
    }

    .bk-row-rank {
        flex-shrink: 0;
        width: 28px;
        text-align: center;
        font-family: 'Playfair Display', serif;
        font-size: 1.2rem;
        font-weight: 700;
    }

    .bk-row-price {
        font-family: 'Playfair Display', serif;
        font-size: 1rem;
        font-weight: 700;
        color: var(--coral);
    }

    .btn-row-cart {
        flex-shrink: 0;
        height: 38px;
        padding: 0 18px;
        border-radius: 10px;
        border: none;
        background: var(--ink);
        color: #fff;
        font-family: 'Outfit', sans-serif;
        font-size: .78rem;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 5px;
        transition: all .2s;
    }

        .btn-row-cart:hover {
            background: var(--gold);
        }

    /* ── Toast ── */
    .toast-wrap {
        position: fixed;
        bottom: 24px;
        right: 24px;
        padding: 13px 20px;
        border-radius: 14px;
        font-size: .84rem;
        font-weight: 500;
        z-index: 10000;
        display: flex;
        align-items: center;
        gap: 10px;
        backdrop-filter: blur(16px);
        background: rgba(26,21,17,.92);
        color: #fff;
        border: 1px solid rgba(255,255,255,.1);
        box-shadow: 0 10px 32px rgba(13,11,8,.22);
        animation: toastIn .25s cubic-bezier(.22,1,.36,1) both;
    }

    /* ── Stat chip ── */
    .stat-glass {
        background: rgba(255,255,255,.07);
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 14px;
        padding: 14px 22px;
        text-align: center;
        backdrop-filter: blur(10px);
        transition: all .2s;
    }

        .stat-glass:hover {
            background: rgba(255,255,255,.11);
            border-color: rgba(201,150,10,.4);
        }

    .pdot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--gold2);
        display: inline-block;
        animation: glowPulse 2.5s ease-in-out infinite;
    }

    /* ── Footer ── */
    .ft-a {
        display: flex;
        align-items: center;
        gap: 6px;
        color: rgba(255,255,255,.3);
        text-decoration: none;
        font-size: .8rem;
        margin-bottom: 9px;
        transition: color .14s;
    }

        .ft-a:hover {
            color: var(--gold2);
        }

    /* ── Tag ── */
    .tag-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 13px;
        border-radius: 50px;
        background: rgba(201,150,10,.15);
        border: 1px solid rgba(201,150,10,.3);
        color: #E8AF1A;
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    /* Pagination */
    .pg-btn {
        width: 36px;
        height: 36px;
        border-radius: 9px;
        border: 1.5px solid var(--sand);
        background: var(--card);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .82rem;
        font-weight: 600;
        color: var(--muted);
        cursor: pointer;
        transition: all .15s;
    }

        .pg-btn:hover {
            border-color: var(--gold);
            color: #8C6A00;
            background: rgba(201,150,10,.07);
        }

        .pg-btn.active {
            border-color: var(--gold);
            background: var(--gold);
            color: #fff;
        }
</style>

<!-- TOP STRIP -->
<div class="py-1.5" style="background:#0D0B08;">
    <div class="max-w-7xl mx-auto px-5 flex justify-between items-center flex-wrap gap-2">
        <div class="flex items-center gap-4" style="color:rgba(255,255,255,.38);font-size:.73rem;">
            <span class="flex items-center gap-1.5"><i class="bi bi-telephone-fill" style="color:var(--gold2);font-size:.6rem;"></i>0901 234 567</span>
            <span class="hidden sm:flex items-center gap-1.5"><i class="bi bi-envelope-fill" style="color:var(--gold2);font-size:.6rem;"></i>bookstore@gmail.com</span>
        </div>
        <a href="#" class="no-underline flex items-center gap-1.5" style="color:rgba(255,255,255,.3);font-size:.73rem;">
            <i class="bi bi-box-seam" style="font-size:.6rem;"></i>Theo dõi đơn hàng
        </a>
    </div>
</div>

<!-- NAVBAR -->
<nav class="py-3 sticky top-0 z-50" style="background:var(--fog);border-bottom:1px solid var(--sand);backdrop-filter:blur(24px);">
    <div class="max-w-7xl mx-auto px-5 flex items-center gap-4">
        <a href="/" class="no-underline flex items-center gap-2.5 mr-auto lg:mr-0 flex-shrink-0"
           style="font-family:'Playfair Display',serif;font-size:1.48rem;color:var(--ink);">
            <div class="w-9 h-9 rounded-[11px] flex items-center justify-center text-white text-sm flex-shrink-0"
                 style="background:linear-gradient(135deg,var(--gold),var(--gold2));box-shadow:0 3px 10px rgba(201,150,10,.35);">
                <i class="bi bi-book-half"></i>
            </div>
            Book<span style="color:var(--gold);">Store</span>
        </a>
        <div class="hidden lg:flex items-center gap-0.5 mx-auto">
            <a href="/" class="nav-a">Trang Chủ</a>
            <a href="/categories" class="nav-a">Danh Mục</a>
            <a href="/books/new" class="nav-a">Sách Mới</a>
            <a href="/books/bestseller" class="nav-a active">Bán Chạy</a>
        </div>
        <div class="flex items-center gap-2 flex-shrink-0">
            <a href="/cart" class="relative w-9 h-9 rounded-[10px] flex items-center justify-center text-sm no-underline"
               style="background:var(--surface);border:1px solid var(--sand);color:var(--ink);">
                <i class="bi bi-bag"></i>
                @if (cartCount > 0)
                {
                    <span class="absolute -top-1.5 -right-1.5 text-white text-[.5rem] w-4 h-4 rounded-full flex items-center justify-center font-bold" style="background:var(--coral);">@cartCount</span>
                }
            </a>
            @if (!isLoggedIn)
            {
                <a href="/login" class="flex items-center gap-2 text-white rounded-[10px] px-4 py-[8px] text-sm font-semibold no-underline" style="background:var(--ink);">
                    <i class="bi bi-person text-sm"></i><span class="hidden sm:inline">Đăng nhập</span>
                </a>
            }
            else
            {
                <div class="w-9 h-9 rounded-[10px] flex items-center justify-center text-white text-[.72rem] font-bold cursor-pointer"
                     style="background:linear-gradient(135deg,var(--gold),var(--gold2));">
                    @GetInitials(userFullName)
                </div>
            }
        </div>
    </div>
</nav>

<!-- ══ HERO ══ -->
<section class="hero-bg py-16 sm:py-20">
    <!-- Deco blobs -->
    <div class="deco" style="width:180px;height:180px;background:rgba(201,150,10,.12);filter:blur(50px);top:10%;right:8%;animation-delay:.3s;"></div>
    <div class="deco" style="width:120px;height:120px;background:rgba(201,150,10,.08);filter:blur(40px);bottom:15%;right:20%;animation-delay:1.1s;"></div>
    <div class="deco" style="width:80px;height:80px;background:rgba(255,255,255,.04);filter:blur(30px);top:40%;left:3%;animation-delay:.7s;"></div>

    <div class="max-w-7xl mx-auto px-5 relative" style="z-index:10;">
        <div class="flex flex-col lg:flex-row items-start lg:items-end justify-between gap-8">
            <div class="a1">
                <div class="tag-pill mb-5">
                    <span class="pdot"></span>Nổi bật · Bán chạy
                </div>
                <h1 class="mb-4" style="font-family:'Playfair Display',serif;font-size:clamp(2.2rem,5vw,3.5rem);font-weight:700;color:#fff;line-height:1.1;letter-spacing:-.02em;">
                    Sách bán chạy<br />
                    <em class="not-italic" style="background:linear-gradient(135deg,var(--gold2),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">nhất tháng này</em>
                </h1>
                <p class="text-base leading-relaxed mb-8" style="color:rgba(255,255,255,.5);max-width:400px;">
                    Những cuốn sách được yêu thích bởi hàng nghìn độc giả — cập nhật theo doanh số thực tế mỗi tháng.
                </p>
                <!-- Stats -->
                <div class="flex gap-3 flex-wrap">
                    @foreach (var (num, lbl) in new[] { ($"{books.Count}", "Đầu sách"), ("200K+", "Độc giả"), ("4.8★", "Đánh giá") })
                    {
                        <div class="stat-glass">
                            <div class="font-bold mb-0.5" style="font-family:'Playfair Display',serif;font-size:1.35rem;background:linear-gradient(135deg,var(--gold2),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">@num</div>
                            <div style="color:rgba(255,255,255,.38);font-size:.66rem;letter-spacing:.06em;text-transform:uppercase;">@lbl</div>
                        </div>
                    }
                </div>
            </div>

            <!-- Top 3 podium preview (desktop) -->
            <div class="hidden lg:flex items-end gap-3 a2" style="flex-shrink:0;">
                @foreach (var (rank, height, delay, medal) in new[] { (2, "130px", "0s", "🥈"), (1, "160px", ".08s", "🥇"), (3, "110px", ".16s", "🥉") })
                {
                    var b = books.Count >= rank ? books[rank - 1] : null;
                    <div class="flex flex-col items-center gap-2" style="animation-delay:@delay;">
                        <div class="text-xl">@medal</div>
                        <div class="rounded-xl overflow-hidden border-2 shadow-2xl flex-shrink-0"
                             style="width:@(rank==1?"84px":"70px");height:@height;border-color:@(rank==1?"var(--gold2)":"rgba(255,255,255,.2)");">
                            @if (b != null)
                            {
                                <img src="@GetSafeUrl(b.ImageUrl, FallbackImg)" class="w-full h-full object-cover" alt="@b.BookTitle" />
                            }
                            else
                            {
                                <div style="width:100%;height:100%;background:rgba(255,255,255,.08);"></div>
                            }
                        </div>
                        <div class="text-xs font-semibold text-center max-w-[80px] leading-tight" style="color:rgba(255,255,255,.6);">
                            @(b?.BookTitle?.Length > 18 ? b.BookTitle[..18] + "…" : b?.BookTitle ?? "—")
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- ══ FILTER BAR ══ -->
<div class="py-3.5 sticky z-40" style="top:61px;background:var(--fog);border-bottom:1px solid var(--sand);backdrop-filter:blur(20px);">
    <div class="max-w-7xl mx-auto px-5">
        <div class="flex items-center gap-3 flex-wrap">
            <!-- Search -->
            <div class="flex items-center gap-2 px-3.5 py-2 rounded-[10px] flex-1 max-w-xs"
                 style="background:var(--card);border:1.5px solid var(--sand);transition:border-color .15s;"
                 onfocusin="this.style.borderColor='var(--gold)'" onfocusout="this.style.borderColor='var(--sand)'">
                <i class="bi bi-search flex-shrink-0" style="color:var(--pale);font-size:.82rem;"></i>
                <input type="text" @bind="search" @bind:event="oninput"
                       placeholder="Tìm sách bán chạy..."
                       style="background:none;border:none;outline:none;font-family:'Outfit',sans-serif;font-size:.83rem;color:var(--ink);width:100%;" />
                @if (!string.IsNullOrEmpty(search))
                {
                    <button @onclick="@(()=>search="")" style="background:none;border:none;cursor:pointer;color:var(--pale);font-size:.75rem;flex-shrink:0;">
                        <i class="bi bi-x-lg"></i>
                    </button>
                }
            </div>

            <div class="w-px h-5 flex-shrink-0" style="background:var(--sand);"></div>

            <!-- Category filter -->
            <div class="flex gap-2 flex-wrap flex-1">
                <button class="chip @(activeCat==""?"active":"")" @onclick='()=>activeCat=""'>Tất cả</button>
                @foreach (var cat in allCats)
                {
                    var c = cat;
                    <button class="chip @(activeCat==c?"active":"")" @onclick="()=>activeCat=c">@c</button>
                }
            </div>

            <!-- Count + View -->
            <div class="flex items-center gap-3 flex-shrink-0">
                <span class="text-sm" style="color:var(--muted);">
                    <strong style="color:var(--ink);">@Filtered.Count()</strong> sách
                </span>
                <div class="vtog">
                    <button class="vbtn @(isGrid?"on":"")" @onclick="@(()=>isGrid=true)" title="Lưới"><i class="bi bi-grid-3x3-gap-fill"></i></button>
                    <button class="vbtn @(!isGrid?"on":"")" @onclick="@(()=>isGrid=false)" title="Danh sách"><i class="bi bi-list-ul"></i></button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ══ CONTENT ══ -->
<section class="py-10 pb-16" style="background:var(--surface);">
    <div class="max-w-7xl mx-auto px-5">

        @if (isLoading)
        {
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-5">
                @for (int i = 0; i < 10; i++)
                {
                    <div style="background:var(--card);border:1px solid var(--sand);border-radius:18px;overflow:hidden;">
                        <div class="skel" style="height:220px;border-radius:0;"></div>
                        <div style="padding:14px 16px;">
                            <div class="skel" style="height:12px;width:50%;margin-bottom:8px;"></div>
                            <div class="skel" style="height:16px;width:85%;margin-bottom:5px;"></div>
                            <div class="skel" style="height:12px;width:60%;margin-bottom:14px;"></div>
                            <div class="skel" style="height:40px;border-radius:10px;"></div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (!Filtered.Any())
        {
            <div class="text-center py-24">
                <div class="text-5xl mb-5 opacity-20">📚</div>
                <h3 class="mb-2" style="font-family:'Playfair Display',serif;font-size:1.5rem;color:var(--ink);">
                    @(string.IsNullOrEmpty(search) ? "Chưa có dữ liệu" : "Không tìm thấy kết quả")
                </h3>
                <p class="text-sm mb-5" style="color:var(--muted);">
                    @(string.IsNullOrEmpty(search) ? "Hệ thống chưa có sách bán chạy." : $"Không có sách nào khớp với \"{search}\".")
                </p>
                @if (!string.IsNullOrEmpty(search) || !string.IsNullOrEmpty(activeCat))
                {
                    <button @onclick="ResetFilter" class="px-5 py-2.5 rounded-xl text-sm font-semibold text-white border-0 cursor-pointer" style="background:var(--ink);">
                        Xóa bộ lọc
                    </button>
                }
            </div>
        }
        else if (isGrid)
        {
            <!-- ── GRID VIEW ── -->
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-5">
                @foreach (var (book, idx) in Filtered.Select((b, i) => (b, i)))
                {
                    var bid = book.BookId;
                    var rank = idx + 1;
                    <div class="bk-card" style="animation-delay:@(Math.Min(idx*.06,.5))s;"
                         @onclick="()=>GoBook(bid)">
                        <div class="bk-img">
                            <img src="@GetSafeUrl(book.ImageUrl, FallbackImg)" alt="@book.BookTitle" loading="lazy" />
                            <div class="bk-overlay"></div>

                            <!-- Rank badge -->
                            <div class="rank-badge @(rank==1?"rank-1":rank==2?"rank-2":rank==3?"rank-3":"rank-n")"
                                 style="animation-delay:@(idx*.06+.2)s;">
                                @(rank <= 3 ? rank.ToString() : $"#{rank}")
                            </div>

                            <!-- Price -->
                            <div class="price-tag">
                                @book.Price.ToString("#,##0")<span style="font-size:.62em;font-weight:400;margin-left:2px;">đ</span>
                            </div>

                            <!-- Wishlist -->
                            <button class="wish-btn @(wishlist.Contains(bid)?"on":"")"
                                    @onclick="()=>ToggleWish(bid)" @onclick:stopPropagation="true">
                                <i class="bi @(wishlist.Contains(bid)?"bi-heart-fill":"bi-heart")"></i>
                            </button>
                        </div>
                        <div class="bk-body">
                            <div class="bk-cat">@book.CategoryName</div>
                            <div class="bk-title">@book.BookTitle</div>
                            <div class="bk-author"><i class="bi bi-person-fill" style="font-size:.65rem;"></i>@book.AuthorName</div>
                            <button class="btn-cart" @onclick="()=>AddToCart(bid)" @onclick:stopPropagation="true">
                                <i class="bi bi-bag-plus" style="font-size:.82rem;"></i>Thêm vào giỏ
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <!-- ── LIST VIEW ── -->
            <div class="flex flex-col gap-3">
                @foreach (var (book, idx) in Filtered.Select((b, i) => (b, i)))
                {
                    var bid = book.BookId;
                    var rank = idx + 1;
                    <div class="bk-row" style="animation-delay:@(Math.Min(idx*.04,.4))s;" @onclick="()=>GoBook(bid)">
                        <!-- Rank -->
                        <div class="bk-row-rank" style="color:@(rank==1?"#D4940A":rank==2?"#888":rank==3?"#CD7F32":"var(--pale)");">
                            @(rank <= 3 ? (rank == 1 ? "🥇" : rank == 2 ? "🥈" : "🥉") : $"#{rank}")
                        </div>
                        <!-- Image -->
                        <div class="bk-row-img">
                            <img src="@GetSafeUrl(book.ImageUrl, FallbackImg)" alt="@book.BookTitle" loading="lazy" />
                        </div>
                        <!-- Info -->
                        <div class="flex-1 min-w-0">
                            <div class="bk-cat">@book.CategoryName</div>
                            <div class="bk-title" style="-webkit-line-clamp:1;margin-bottom:3px;">@book.BookTitle</div>
                            <div class="bk-author" style="margin-bottom:0;"><i class="bi bi-person-fill" style="font-size:.62rem;"></i>@book.AuthorName</div>
                        </div>
                        <!-- Price + btn -->
                        <div class="flex items-center gap-3 flex-shrink-0">
                            <div class="bk-row-price hidden sm:block">@book.Price.ToString("#,##0")đ</div>
                            <button class="btn-row-cart" @onclick="()=>AddToCart(bid)" @onclick:stopPropagation="true">
                                <i class="bi bi-bag-plus" style="font-size:.78rem;"></i>
                                <span class="hidden sm:inline">Thêm</span>
                            </button>
                            <button class="wish-btn" style="position:static;width:36px;height:36px;border-radius:9px;background:var(--surface);border:1.5px solid var(--sand);color:var(--pale);"
                                    @onclick="()=>ToggleWish(bid)" @onclick:stopPropagation="true">
                                <i class="bi @(wishlist.Contains(bid)?"bi-heart-fill text-red-400":"bi-heart")"></i>
                            </button>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Pagination placeholder -->
        @if (Filtered.Count() > 0 && !isLoading)
        {
            <div class="flex justify-center gap-2 mt-10">
                <button class="pg-btn"><i class="bi bi-chevron-left" style="font-size:.75rem;"></i></button>
                <button class="pg-btn active">1</button>
                <button class="pg-btn">2</button>
                <button class="pg-btn">3</button>
                <button class="pg-btn"><i class="bi bi-chevron-right" style="font-size:.75rem;"></i></button>
            </div>
        }
    </div>
</section>

<!-- ══ FOOTER ══ -->
<footer class="pt-12" style="background:#0D0B08;">
    <div class="max-w-7xl mx-auto px-5">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 pb-12">
            <div>
                <a href="/" class="flex items-center gap-2.5 no-underline mb-5"
                   style="font-family:'Playfair Display',serif;font-size:1.45rem;color:#fff;">
                    <div class="w-9 h-9 rounded-[11px] flex items-center justify-center text-white text-sm"
                         style="background:linear-gradient(135deg,var(--gold),var(--gold2));">
                        <i class="bi bi-book-half"></i>
                    </div>BookStore
                </a>
                <p class="text-xs leading-loose mb-5" style="color:rgba(255,255,255,.28);">Nơi quy tụ kho tàng tri thức nhân loại.</p>
                @foreach (var (ico, txt) in new[] { ("bi-geo-alt-fill", "123 Nguyễn Huệ, Q1, TP.HCM"), ("bi-telephone-fill", "0901 234 567"), ("bi-envelope-fill", "bookstore@gmail.com") })
                {
                    <div class="flex items-center gap-2 mb-2 text-xs" style="color:rgba(255,255,255,.28);">
                        <i class="bi @ico" style="color:var(--gold2);font-size:.62rem;flex-shrink:0;"></i>@txt
                    </div>
                }
            </div>
            <div>
                <div class="text-xs font-bold uppercase tracking-widest mb-5" style="color:rgba(255,255,255,.2);">Danh mục</div>
                @foreach (var l in new[] { "Tiểu Thuyết", "Kinh Tế", "Công Nghệ", "Tâm Lý Học", "Thiếu Nhi", "Lịch Sử" })
                {
                    <a href="#" class="ft-a"><i class="bi bi-chevron-right" style="font-size:.48rem;"></i>@l</a>
                }
            </div>
            <div>
                <div class="text-xs font-bold uppercase tracking-widest mb-5" style="color:rgba(255,255,255,.2);">Hỗ trợ</div>
                @foreach (var l in new[] { "Hướng dẫn mua hàng", "Chính sách đổi trả", "Vận chuyển", "Thanh toán", "Liên hệ chúng tôi" })
                {
                    <a href="#" class="ft-a"><i class="bi bi-chevron-right" style="font-size:.48rem;"></i>@l</a>
                }
            </div>
            <div>
                <div class="text-xs font-bold uppercase tracking-widest mb-5" style="color:rgba(255,255,255,.2);">Bản tin sách</div>
                <p class="text-xs mb-4 leading-loose" style="color:rgba(255,255,255,.28);">Nhận thông báo sách mới và ưu đãi độc quyền.</p>
                <div class="flex rounded-[12px] overflow-hidden" style="border:1px solid rgba(255,255,255,.1);">
                    <input type="email" placeholder="Email của bạn..." class="flex-1 px-3 py-2.5 text-xs outline-none"
                           style="background:rgba(255,255,255,.05);color:#fff;border:none;" />
                    <button class="px-3.5 py-2.5 border-0 cursor-pointer text-sm"
                            style="background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--ink);">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
            </div>
        </div>
        <div class="flex flex-wrap justify-between items-center py-5 border-t gap-3" style="border-color:rgba(255,255,255,.06);">
            <p class="text-xs m-0" style="color:rgba(255,255,255,.18);">&copy; @DateTime.Now.Year BookStore. Tất cả quyền được bảo lưu.</p>
            <div class="flex gap-5">
                <a href="/terms" class="no-underline text-xs" style="color:rgba(255,255,255,.18);">Điều khoản</a>
                <a href="/privacy" class="no-underline text-xs" style="color:rgba(255,255,255,.18);">Bảo mật</a>
            </div>
        </div>
    </div>
</footer>

<!-- TOAST -->
@if (showToast)
{
    <div class="toast-wrap">
        <i class="bi bi-check-circle-fill flex-shrink-0" style="color:#6EE7B7;font-size:.9rem;"></i>
        @toastMsg
    </div>
}

@code {
    private const string FallbackImg = "https://images.unsplash.com/photo-1544947950-fa07a98d237f?w=400&h=533&fit=crop";

    private bool isLoading = true, isGrid = true, showToast = false;
    private bool isLoggedIn = false;
    private string userFullName = "", accessToken = "";
    private string search = "", activeCat = "", toastMsg = "";
    private int cartCount = 0;
    private HashSet<int> wishlist = new();
    private List<BookVm> books = new();

    private IEnumerable<string> allCats => books.Select(b => b.CategoryName).Distinct().OrderBy(c => c);

    private IEnumerable<BookVm> Filtered
    {
        get
        {
            var q = books.AsEnumerable();
            if (!string.IsNullOrEmpty(activeCat)) q = q.Where(b => b.CategoryName == activeCat);
            if (!string.IsNullOrEmpty(search)) q = q.Where(b => b.BookTitle.Contains(search, StringComparison.OrdinalIgnoreCase) || b.AuthorName.Contains(search, StringComparison.OrdinalIgnoreCase));
            return q;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        accessToken = await JS.InvokeAsync<string?>("localStorage.getItem", "accessToken") ?? "";
        userFullName = await JS.InvokeAsync<string?>("localStorage.getItem", "userFullName") ?? "";
        isLoggedIn = !string.IsNullOrEmpty(accessToken) && !string.IsNullOrEmpty(userFullName);
        await LoadBooks();
        StateHasChanged();
    }

    private async Task LoadBooks()
    {
        isLoading = true;
        try
        {
            var result = await Http.GetFromJsonAsync<List<ApiBookDto>>("api/book/top-selling?top=20");
            if (result != null)
                books = result.Select(b => new BookVm
                    {
                        BookId = b.BookId,
                        BookTitle = b.BookTitle ?? "Không rõ",
                        AuthorName = b.AuthorName ?? "Không rõ",
                        CategoryName = b.CategoryName ?? "Khác",
                        Price = b.Price,
                        ImageUrl = b.ImageUrl,
                    }).ToList();
        }
        catch { }
        finally { isLoading = false; }
    }

    private void ResetFilter() { search = ""; activeCat = ""; }
    private void GoBook(int id) => Nav.NavigateTo($"/book/{id}");
    private void ToggleWish(int id) { if (!wishlist.Add(id)) wishlist.Remove(id); }

    private async Task AddToCart(int bookId)
    {
        if (!isLoggedIn) { Nav.NavigateTo("/login"); return; }
        try
        {
            var req = new HttpRequestMessage(HttpMethod.Post, "api/cart/add");
            req.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", accessToken);
            req.Content = System.Net.Http.Json.JsonContent.Create(new { bookId, quantity = 1 });
            var resp = await Http.SendAsync(req);
            if (resp.IsSuccessStatusCode) { cartCount++; await ShowToast("Đã thêm vào giỏ hàng!"); }
            else await ShowToast("Thêm vào giỏ thất bại.");
        }
        catch { await ShowToast("Đã xảy ra lỗi."); }
    }

    private async Task ShowToast(string msg)
    {
        toastMsg = msg; showToast = true; StateHasChanged();
        await Task.Delay(3000);
        showToast = false; StateHasChanged();
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        var p = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return p.Length == 1 ? p[0][..1].ToUpper() : $"{p[0][..1]}{p[^1][..1]}".ToUpper();
    }

    private static string GetSafeUrl(string? url, string fallback)
    {
        if (string.IsNullOrWhiteSpace(url)) return fallback;
        if (!Uri.TryCreate(url, UriKind.Absolute, out var uri)) return fallback;
        return uri.Scheme is "http" or "https" ? url : fallback;
    }

    private class BookVm
    {
        public int BookId { get; set; }
        public string BookTitle { get; set; } = "";
        public string AuthorName { get; set; } = "";
        public string CategoryName { get; set; } = "";
        public decimal Price { get; set; }
        public string? ImageUrl { get; set; }
    }
    private class ApiBookDto { public int BookId { get; set; } public string? BookTitle { get; set; } public string? AuthorName { get; set; } public string? CategoryName { get; set; } public decimal Price { get; set; } public string? ImageUrl { get; set; } }
}
