@page "/forgot-password"
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@implements IDisposable
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Quên mật khẩu - BookStore</PageTitle>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap');

    :root {
        --cream: #FAF7F2;
        --warm-white: #FFFDF8;
        --ink: #1A1208;
        --brown: #6B4C2A;
        --amber: #D4860B;
        --amber-light: #F5A623;
        --rust: #C0392B;
        --border: #EDE8DF;
        --sage: #5A8A5E;
    }

    * {
        box-sizing: border-box;
    }

    .fp-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--cream);
        font-family: 'DM Sans', sans-serif;
        padding: 24px;
        position: relative;
        overflow: hidden;
    }

        /* Background decoration */
        .fp-page::before {
            content: '';
            position: fixed;
            top: -200px;
            right: -200px;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(212,134,11,0.08) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .fp-page::after {
            content: '';
            position: fixed;
            bottom: -150px;
            left: -150px;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(107,76,42,0.06) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

    .fp-card {
        width: 100%;
        max-width: 480px;
        background: var(--warm-white);
        border-radius: 24px;
        padding: 48px 44px;
        box-shadow: 0 20px 60px rgba(26,18,8,0.12), 0 4px 16px rgba(26,18,8,0.06);
        position: relative;
        z-index: 1;
        border: 1px solid rgba(237,232,223,0.8);
    }

    /* Logo */
    .fp-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        margin-bottom: 36px;
        justify-content: center;
    }

    .fp-logo-icon {
        width: 40px;
        height: 40px;
        background: var(--amber);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        color: #fff;
        box-shadow: 0 4px 12px rgba(212,134,11,0.3);
    }

    .fp-logo-text {
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--ink);
        letter-spacing: -.5px;
    }

        .fp-logo-text span {
            color: var(--amber);
        }

    /* ── Step Indicator ── */
    .fp-steps {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0;
        margin-bottom: 36px;
    }

    .fp-step-wrap {
        display: flex;
        align-items: center;
        gap: 0;
    }

    .fp-step-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
    }

    .fp-step-circle {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .8rem;
        font-weight: 700;
        border: 2px solid var(--border);
        color: #B0A090;
        background: #fff;
        transition: all .4s ease;
        position: relative;
    }

        .fp-step-circle.active {
            background: var(--amber);
            border-color: var(--amber);
            color: #fff;
            box-shadow: 0 4px 16px rgba(212,134,11,0.4);
            transform: scale(1.1);
        }

        .fp-step-circle.done {
            background: var(--brown);
            border-color: var(--brown);
            color: #fff;
        }

    .fp-step-label {
        font-size: .7rem;
        font-weight: 600;
        color: #B0A090;
        letter-spacing: .04em;
        white-space: nowrap;
        transition: color .3s;
    }

        .fp-step-label.active {
            color: var(--amber);
        }

        .fp-step-label.done {
            color: var(--brown);
        }

    .fp-step-line {
        width: 60px;
        height: 2px;
        background: var(--border);
        margin: 0 4px;
        margin-bottom: 22px;
        transition: background .4s;
        flex-shrink: 0;
    }

        .fp-step-line.done {
            background: var(--brown);
        }

    /* ── Header ── */
    .fp-header {
        text-align: center;
        margin-bottom: 28px;
    }

    .fp-header-icon {
        width: 64px;
        height: 64px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        margin: 0 auto 16px;
    }

    .fp-header h2 {
        font-family: 'Playfair Display', serif;
        font-size: 1.7rem;
        font-weight: 800;
        color: var(--ink);
        margin-bottom: 8px;
    }

    .fp-header p {
        color: #9B8B7A;
        font-size: .9rem;
        line-height: 1.6;
    }

    /* ── Alerts ── */
    .fp-alert {
        padding: 12px 16px;
        border-radius: 12px;
        margin-bottom: 20px;
        font-size: .85rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .fp-alert-error {
        background: #fce8e6;
        color: #b71c1c;
        border: 1px solid #f5c6cb;
    }

    .fp-alert-success {
        background: #e8f5e9;
        color: #1b5e20;
        border: 1px solid #c8e6c9;
    }

    /* ── Fields ── */
    .fp-field {
        margin-bottom: 18px;
    }

        .fp-field label {
            display: block;
            font-size: .82rem;
            font-weight: 600;
            color: var(--ink);
            margin-bottom: 7px;
        }

    .fp-input-wrap {
        position: relative;
    }

    .fp-input-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #B0A090;
        pointer-events: none;
        font-size: 1rem;
    }

    .fp-input {
        width: 100%;
        padding: .8rem 1rem .8rem 2.75rem;
        border: 2px solid var(--border);
        border-radius: 12px;
        font-family: 'DM Sans', sans-serif;
        font-size: .9rem;
        color: var(--ink);
        background: #fff;
        transition: border-color .2s, box-shadow .2s;
    }

        .fp-input::placeholder {
            color: #C4B8A8;
        }

        .fp-input:focus {
            outline: none;
            border-color: var(--amber);
            box-shadow: 0 0 0 3px rgba(212,134,11,.1);
        }

        .fp-input.has-toggle {
            padding-right: 2.75rem;
        }

    .fp-toggle-pw {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        color: #B0A090;
        padding: 4px;
    }

        .fp-toggle-pw:hover {
            color: var(--brown);
        }

    .fp-validation {
        color: var(--rust);
        font-size: .75rem;
        margin-top: 5px;
        display: block;
    }

    /* ── OTP Grid ── */
    .fp-email-badge {
        background: var(--cream);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 10px 16px;
        text-align: center;
        margin-bottom: 20px;
        font-size: .85rem;
        color: #9B8B7A;
    }

        .fp-email-badge strong {
            color: var(--ink);
        }

    .fp-otp-row {
        display: flex;
        gap: 10px;
        justify-content: center;
        margin-bottom: 4px;
    }

    .fp-otp-cell {
        width: 56px;
        height: 64px;
        text-align: center;
        font-size: 1.6rem;
        font-weight: 700;
        font-family: 'Playfair Display', serif;
        border: 2px solid var(--border);
        border-radius: 14px;
        background: #fff;
        color: var(--ink);
        transition: border-color .2s, box-shadow .2s, transform .1s;
    }

        .fp-otp-cell:focus {
            outline: none;
            border-color: var(--amber);
            box-shadow: 0 0 0 3px rgba(212,134,11,.12);
            transform: scale(1.05);
        }

        .fp-otp-cell.filled {
            border-color: var(--brown);
            background: rgba(107,76,42,.04);
        }

    .fp-timer {
        text-align: center;
        font-size: .82rem;
        color: #9B8B7A;
        margin: 14px 0 20px;
    }

        .fp-timer b {
            color: var(--amber);
            font-weight: 700;
        }

    .btn-resend {
        background: none;
        border: none;
        color: var(--amber);
        font-weight: 700;
        font-size: .82rem;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        padding: 0;
        text-decoration: underline;
    }

        .btn-resend:disabled {
            color: #C4B8A8;
            cursor: not-allowed;
            text-decoration: none;
        }

    /* ── Password Strength ── */
    .pw-strength {
        margin-top: 8px;
        display: flex;
        gap: 4px;
        align-items: center;
    }

    .pw-bar {
        flex: 1;
        height: 4px;
        border-radius: 2px;
        background: var(--border);
        transition: background .3s;
    }

        .pw-bar.weak {
            background: var(--rust);
        }

        .pw-bar.medium {
            background: var(--amber);
        }

        .pw-bar.strong {
            background: var(--sage);
        }

    .pw-label {
        font-size: .72rem;
        color: #9B8B7A;
        margin-left: 6px;
        white-space: nowrap;
    }

    /* ── Button ── */
    .fp-btn {
        width: 100%;
        padding: .9rem;
        background: var(--brown);
        color: #fff;
        border: none;
        border-radius: 50px;
        font-family: 'DM Sans', sans-serif;
        font-size: .95rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .25s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        box-shadow: 0 6px 20px rgba(107,76,42,.25);
        margin-top: 8px;
        text-decoration: none;
    }

        .fp-btn:hover:not(:disabled) {
            background: var(--amber);
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(212,134,11,.35);
        }

        .fp-btn:disabled {
            opacity: .55;
            cursor: not-allowed;
        }

    .fp-spinner {
        width: 18px;
        height: 18px;
        border: 2px solid rgba(255,255,255,.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin .8s linear infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .fp-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: none;
        border: none;
        cursor: pointer;
        color: #9B8B7A;
        font-size: .85rem;
        font-family: 'DM Sans', sans-serif;
        padding: 0;
        margin-bottom: 20px;
        transition: color .2s;
    }

        .fp-back:hover {
            color: var(--brown);
        }

    /* ── Success ── */
    .fp-success-wrap {
        text-align: center;
        padding: 8px 0;
    }

    .fp-success-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
        margin: 0 auto 20px;
        box-shadow: 0 8px 24px rgba(90,138,94,0.2);
    }

    .fp-success-wrap h3 {
        font-family: 'Playfair Display', serif;
        font-size: 1.4rem;
        font-weight: 800;
        color: var(--ink);
        margin-bottom: 8px;
    }

    .fp-success-wrap p {
        color: #9B8B7A;
        font-size: .9rem;
        line-height: 1.6;
        margin-bottom: 28px;
    }

    .fp-divider {
        height: 1px;
        background: var(--border);
        margin: 20px 0;
    }

    @@media (max-width: 520px) {
        .fp-card {
            padding: 32px 24px;
        }

        .fp-otp-cell {
            width: 44px;
            height: 52px;
            font-size: 1.3rem;
            border-radius: 10px;
        }

        .fp-otp-row {
            gap: 7px;
        }

        .fp-step-line {
            width: 36px;
        }
    }
</style>

<div class="fp-page">
    <div class="fp-card">

        <!-- Logo -->
        <a href="/" class="fp-logo">
            <div class="fp-logo-icon"><i class="bi bi-book-half"></i></div>
            <span class="fp-logo-text">Book<span>Store</span></span>
        </a>

        <!-- Step Indicator — 3 bước -->
        <div class="fp-steps">
            <div class="fp-step-item">
                <div class="fp-step-circle @(currentStep == 1 ? "active" : currentStep > 1 ? "done" : "")">
                    @if (currentStep > 1)
                    {
                        <i class="bi bi-check-lg"></i>
                    }
                    else
                    {
                        <span>1</span>
                    }
                </div>
                <span class="fp-step-label @(currentStep == 1 ? "active" : currentStep > 1 ? "done" : "")">Email</span>
            </div>
            <div class="fp-step-line @(currentStep > 1 ? "done" : "")"></div>
            <div class="fp-step-item">
                <div class="fp-step-circle @(currentStep == 2 ? "active" : currentStep > 2 ? "done" : "")">
                    @if (currentStep > 2)
                    {
                        <i class="bi bi-check-lg"></i>
                    }
                    else
                    {
                        <span>2</span>
                    }
                </div>
                <span class="fp-step-label @(currentStep == 2 ? "active" : currentStep > 2 ? "done" : "")">Xác nhận</span>
            </div>
            <div class="fp-step-line @(currentStep > 2 ? "done" : "")"></div>
            <div class="fp-step-item">
                <div class="fp-step-circle @(currentStep == 3 ? "active" : currentStep > 3 ? "done" : "")">
                    @if (currentStep > 3)
                    {
                        <i class="bi bi-check-lg"></i>
                    }
                    else
                    {
                        <span>3</span>
                    }
                </div>
                <span class="fp-step-label @(currentStep == 3 ? "active" : currentStep > 3 ? "done" : "")">Mật khẩu</span>
            </div>
        </div>

        <!-- Alerts -->
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="fp-alert fp-alert-error">
                <i class="bi bi-exclamation-circle-fill"></i> @errorMessage
            </div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="fp-alert fp-alert-success">
                <i class="bi bi-check-circle-fill"></i> @successMessage
            </div>
        }

        @* ════════ BƯỚC 1 — Nhập Email ════════ *@
        @if (currentStep == 1)
        {
            <div class="fp-header">
                <div class="fp-header-icon" style="background:rgba(212,134,11,0.1);">🔑</div>
                <h2>Quên mật khẩu?</h2>
                <p>Nhập email đã đăng ký để nhận mã OTP xác nhận 6 chữ số.</p>
            </div>
            <EditForm Model="@forgotModel" OnValidSubmit="@HandleSendOtp">
                <DataAnnotationsValidator />
                <div class="fp-field">
                    <label>Email đăng ký</label>
                    <div class="fp-input-wrap">
                        <i class="bi bi-envelope fp-input-icon"></i>
                        <InputText @bind-Value="forgotModel.Email"
                                   placeholder="name@company.com" class="fp-input" />
                    </div>
                    <ValidationMessage For="@(() => forgotModel.Email)" class="fp-validation" />
                </div>
                <button type="submit" class="fp-btn" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="fp-spinner"></span>

                        <span>Đang gửi OTP...</span>
                    }
                    else
                    {
                        <i class="bi bi-send-fill"></i>

                        <span>Gửi mã OTP</span>
                    }
                </button>
            </EditForm>
            <div class="fp-divider"></div>
            <div style="text-align:center;font-size:.85rem;color:#9B8B7A;">
                Nhớ mật khẩu rồi?
                <a href="/login" style="color:var(--amber);font-weight:700;text-decoration:none;">Đăng nhập →</a>
            </div>
        }
        @* ════════ BƯỚC 2 — Nhập OTP ════════ *@
        else if (currentStep == 2)
        {
            <div class="fp-header">
                <div class="fp-header-icon" style="background:rgba(107,76,42,0.08);">📩</div>
                <h2>Nhập mã OTP</h2>
                <p>Kiểm tra hộp thư của bạn (kể cả thư mục spam).</p>
            </div>
            <button class="fp-back" type="button" @onclick="@(() => GoToStep(1))">
                <i class="bi bi-arrow-left"></i> Đổi email
            </button>
            <div class="fp-email-badge">
                Mã đã gửi đến <strong>@forgotModel.Email</strong>
            </div>
            <div class="fp-otp-row">
                @for (int i = 0; i < 6; i++)
                {
                    var idx = i;
                    <input class="fp-otp-cell @(!string.IsNullOrEmpty(otpDigits[idx]) ? "filled" : "")"
                           maxlength="1" type="text" inputmode="numeric"
                           id="otp-@idx" value="@otpDigits[idx]"
                           @oninput="@(e => OnOtpInput(e, idx))"
                           @onkeydown="@(e => OnOtpKeyDown(e, idx))" />
                }
            </div>
            <div class="fp-timer">
                @if (otpSeconds > 0)
                {
                    <span>Mã hết hạn sau <b>@($"{otpSeconds / 60:D2}:{otpSeconds % 60:D2}")</b></span>
                }
                else
                {
                    <span>Mã đã hết hạn. </span>
                    <button class="btn-resend" type="button" disabled="@isLoading" @onclick="HandleResendOtp">Gửi lại</button>
                }
            </div>
            <button class="fp-btn" type="button"
                    disabled="@(isLoading || otpDigits.Any(d => string.IsNullOrEmpty(d)))"
                    @onclick="HandleVerifyOtp">
                @if (isLoading)
                {
                    <span class="fp-spinner"></span>

                    <span>Đang xác nhận...</span>
                }
                else
                {
                    <i class="bi bi-shield-check-fill"></i>

                    <span>Xác nhận OTP</span>
                }
            </button>
        }
        @* ════════ BƯỚC 3 — Đặt mật khẩu mới ════════ *@
        else if (currentStep == 3)
        {
            <div class="fp-header">
                <div class="fp-header-icon" style="background:rgba(90,138,94,0.1);">🔒</div>
                <h2>Đặt mật khẩu mới</h2>
                <p>Tạo mật khẩu mạnh để bảo vệ tài khoản của bạn.</p>
            </div>
            <EditForm Model="@resetModel" OnValidSubmit="@HandleResetPassword">
                <DataAnnotationsValidator />
                <div class="fp-field">
                    <label>Mật khẩu mới</label>
                    <div class="fp-input-wrap">
                        <i class="bi bi-lock fp-input-icon"></i>
                        <InputText type="@(showNewPw ? "text" : "password")"
                                   @bind-Value="resetModel.NewPassword"
                                   @oninput="@(e => { resetModel.NewPassword = e.Value?.ToString() ?? ""; CheckPasswordStrength(); })"
                                   placeholder="Tối thiểu 6 ký tự"
                                   class="fp-input has-toggle" />
                        <button type="button" class="fp-toggle-pw" @onclick="@(() => showNewPw = !showNewPw)">
                            <i class="bi @(showNewPw ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(resetModel.NewPassword))
                    {
                        <div class="pw-strength">
                            <div class="pw-bar @(pwStrength >= 1 ? (pwStrength == 1 ? "weak" : pwStrength == 2 ? "medium" : "strong") : "")"></div>
                            <div class="pw-bar @(pwStrength >= 2 ? (pwStrength == 2 ? "medium" : "strong") : "")"></div>
                            <div class="pw-bar @(pwStrength >= 3 ? "strong" : "")"></div>
                            <span class="pw-label">@(pwStrength == 1 ? "Yếu" : pwStrength == 2 ? "Trung bình" : pwStrength == 3 ? "Mạnh" : "")</span>
                        </div>
                    }
                    <ValidationMessage For="@(() => resetModel.NewPassword)" class="fp-validation" />
                </div>
                <div class="fp-field">
                    <label>Xác nhận mật khẩu</label>
                    <div class="fp-input-wrap">
                        <i class="bi bi-lock-fill fp-input-icon"></i>
                        <InputText type="password"
                                   @bind-Value="resetModel.ConfirmPassword"
                                   placeholder="Nhập lại mật khẩu"
                                   class="fp-input" />
                    </div>
                    <ValidationMessage For="@(() => resetModel.ConfirmPassword)" class="fp-validation" />
                </div>
                <button type="submit" class="fp-btn" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="fp-spinner"></span>

                        <span>Đang cập nhật...</span>
                    }
                    else
                    {
                        <i class="bi bi-check-circle-fill"></i>

                        <span>Đặt lại mật khẩu</span>
                    }
                </button>
            </EditForm>
        }
        @* ════════ BƯỚC 4 — Thành công ════════ *@
        else if (currentStep == 4)
        {
            <div class="fp-success-wrap">
                <div class="fp-success-icon">✅</div>
                <h3>Đặt lại thành công!</h3>
                <p>Mật khẩu của bạn đã được cập nhật.<br />Hãy đăng nhập với mật khẩu mới.</p>
                <a href="/login" class="fp-btn" style="display:inline-flex;text-decoration:none;width:auto;padding:.9rem 2.5rem;margin:0 auto;">
                    <i class="bi bi-box-arrow-in-right"></i>
                    <span>Đăng nhập ngay</span>
                </a>
            </div>
        }

    </div>
</div>

@code {
    private int currentStep = 1;
    private bool isLoading = false;
    private string errorMessage = "";
    private string successMessage = "";

    // Step 1
    private ForgotPasswordModel forgotModel = new();

    // Step 2
    private string[] otpDigits = new string[6];
    private string otpCode => string.Join("", otpDigits);
    private int otpSeconds = 0;
    private System.Threading.Timer? otpTimer;

    // Step 3
    private ResetPasswordModel resetModel = new();
    private bool showNewPw = false;
    private int pwStrength = 0;

    private void GoToStep(int step)
    {
        errorMessage = ""; successMessage = ""; currentStep = step;
    }

    private void CheckPasswordStrength()
    {
        var pw = resetModel.NewPassword ?? "";
        if (pw.Length < 6) { pwStrength = 1; return; }
        int score = 0;
        if (pw.Length >= 8) score++;
        if (pw.Any(char.IsUpper) && pw.Any(char.IsLower)) score++;
        if (pw.Any(char.IsDigit) || pw.Any(c => !char.IsLetterOrDigit(c))) score++;
        pwStrength = score == 0 ? 1 : score;
    }

    // Bước 1 — Gửi OTP
    private async Task HandleSendOtp()
    {
        try
        {
            isLoading = true; errorMessage = ""; successMessage = "";
            var response = await Http.PostAsJsonAsync("api/auth/forgot-password", new { email = forgotModel.Email });
            if (response.IsSuccessStatusCode)
            {
                otpDigits = new string[6];
                StartCountdown(15 * 60);
                GoToStep(2);
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                var err = await response.Content.ReadFromJsonAsync<ApiMsg>();
                errorMessage = err?.Message ?? "Không tìm thấy tài khoản với email này.";
            }
            else { errorMessage = "Lỗi server. Vui lòng thử lại sau."; }
        }
        catch (HttpRequestException) { errorMessage = "Không thể kết nối đến server."; }
        catch { errorMessage = "Đã xảy ra lỗi. Vui lòng thử lại."; }
        finally { isLoading = false; }
    }

    private async Task HandleResendOtp() => await HandleSendOtp();

    // Bước 2 — Xác nhận OTP
    private async Task HandleVerifyOtp()
    {
        try
        {
            isLoading = true; errorMessage = "";
            var response = await Http.PostAsJsonAsync("api/auth/verify-otp", new { email = forgotModel.Email, otpCode });
            if (response.IsSuccessStatusCode)
            {
                StopCountdown(); GoToStep(3);
            }
            else
            {
                var err = await response.Content.ReadFromJsonAsync<ApiMsg>();
                errorMessage = err?.Message ?? "Mã OTP không hợp lệ hoặc đã hết hạn.";
                otpDigits = new string[6];
            }
        }
        catch (HttpRequestException) { errorMessage = "Không thể kết nối đến server."; }
        catch { errorMessage = "Đã xảy ra lỗi. Vui lòng thử lại."; }
        finally { isLoading = false; }
    }

    // Bước 3 — Đặt lại mật khẩu
    private async Task HandleResetPassword()
    {
        try
        {
            isLoading = true; errorMessage = ""; successMessage = "";
            var response = await Http.PostAsJsonAsync("api/auth/reset-password", new
            {
                email = forgotModel.Email,
                otpCode,
                newPassword = resetModel.NewPassword,
                confirmPassword = resetModel.ConfirmPassword
            });
            if (response.IsSuccessStatusCode)
            {
                GoToStep(4);
            }
            else
            {
                var err = await response.Content.ReadFromJsonAsync<ApiMsg>();
                errorMessage = err?.Message ?? "Không thể đặt lại mật khẩu. Vui lòng thử lại.";
            }
        }
        catch (HttpRequestException) { errorMessage = "Không thể kết nối đến server."; }
        catch { errorMessage = "Đã xảy ra lỗi. Vui lòng thử lại."; }
        finally { isLoading = false; }
    }

    // OTP Input handlers
    private async void OnOtpInput(ChangeEventArgs e, int idx)
    {
        var raw = e.Value?.ToString() ?? "";
        raw = new string(raw.Where(char.IsDigit).ToArray());
        otpDigits[idx] = raw.Length > 0 ? raw[^1].ToString() : "";
        if (!string.IsNullOrEmpty(otpDigits[idx]) && idx < 5)
            await JS.InvokeVoidAsync("eval", $"document.getElementById('otp-{idx + 1}')?.focus()");
        StateHasChanged();
    }

    private async void OnOtpKeyDown(KeyboardEventArgs e, int idx)
    {
        if (e.Key == "Backspace" && string.IsNullOrEmpty(otpDigits[idx]) && idx > 0)
        {
            otpDigits[idx - 1] = "";
            await JS.InvokeVoidAsync("eval", $"document.getElementById('otp-{idx - 1}')?.focus()");
            StateHasChanged();
        }
    }

    // Countdown
    private void StartCountdown(int seconds)
    {
        StopCountdown();
        otpSeconds = seconds;
        otpTimer = new System.Threading.Timer(_ =>
        {
            if (otpSeconds > 0) otpSeconds--;
            InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    private void StopCountdown() { otpTimer?.Dispose(); otpTimer = null; }
    public void Dispose() => StopCountdown();

    // Models
    public class ForgotPasswordModel
    {
        [Required(ErrorMessage = "Email là bắt buộc")]
        [EmailAddress(ErrorMessage = "Email không hợp lệ")]
        public string Email { get; set; } = "";
    }

    public class ResetPasswordModel
    {
        [Required(ErrorMessage = "Mật khẩu mới là bắt buộc")]
        [MinLength(6, ErrorMessage = "Mật khẩu phải có ít nhất 6 ký tự")]
        public string NewPassword { get; set; } = "";

        [Required(ErrorMessage = "Xác nhận mật khẩu là bắt buộc")]
        [Compare(nameof(NewPassword), ErrorMessage = "Mật khẩu xác nhận không khớp")]
        public string ConfirmPassword { get; set; } = "";
    }

    public class ApiMsg { public string Message { get; set; } = ""; }
}
