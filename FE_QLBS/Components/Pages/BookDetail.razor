@code {
    [Parameter] public int BookId { get; set; }

    private const string FallbackImg = "https://images.unsplash.com/photo-1544947950-fa07a98d237f?w=400&h=533&fit=crop";

    // ── Auth / UI state ──
    private bool isLoggedIn = false, isLoading = true, isAddingCart = false;
    private bool isWishlisted = false, showDropdown = false, showToast = false;
    private string accessToken = "", userFullName = "", userEmail = "";
    private string activeTab = "desc", toastMessage = "";
    private int cartCount = 0, qty = 1, activeThumb = 0;
    private string currentImageUrl = "";
    private List<string> bookImages = new();
    private BookResponseDto? book;
    private List<BookResponseDto> relatedBooks = new();

    // ── Review state ──
    private List<ReviewResponseDto> reviews = new();
    private bool isLoadingReviews = false;
    private bool reviewsLoaded = false;          // chỉ gọi API 1 lần
    private double averageRating = 0;

    // ── Write review (đã chuyển sang trang Order detail) ──
    // Không cần state ở đây nữa

    // ── Lifecycle ──
    protected override async Task OnInitializedAsync() => await LoadBook();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        accessToken = await JS.InvokeAsync<string?>("localStorage.getItem", "accessToken") ?? "";
        userFullName = await JS.InvokeAsync<string?>("localStorage.getItem", "userFullName") ?? "";
        userEmail = await JS.InvokeAsync<string?>("localStorage.getItem", "userEmail") ?? "";
        isLoggedIn = !string.IsNullOrEmpty(accessToken) && !string.IsNullOrEmpty(userFullName);
        StateHasChanged();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!isLoading)
        {
            isLoading = true; qty = 1; activeTab = "desc";
            activeThumb = 0; reviewsLoaded = false; reviews = new();
            await LoadBook();
        }
    }

    // ── Book loading ──
    private async Task LoadBook()
    {
        try
        {
            book = await Http.GetFromJsonAsync<BookResponseDto>($"api/book/{BookId}");
            if (book != null)
            {
                var mainImg = book.ImageUrl ?? "";
                bookImages = new List<string> { mainImg, mainImg, mainImg, mainImg };
                currentImageUrl = mainImg;
                activeThumb = 0;
                await LoadRelated(book.CategoryId);
            }
        }
        catch { book = null; }
        finally { isLoading = false; StateHasChanged(); }
    }

    private async Task LoadRelated(int catId)
    {
        try
        {
            var list = await Http.GetFromJsonAsync<List<BookResponseDto>>($"api/book?categoryId={catId}&pageSize=6");
            if (list != null) relatedBooks = list.Where(b => b.BookId != BookId).Take(5).ToList();
        }
        catch { relatedBooks = new(); }
    }

    // ── Review loading (lazy — chỉ gọi khi mở tab) ──
    private async Task LoadReviews()
    {
        if (reviewsLoaded) return;
        isLoadingReviews = true; StateHasChanged();
        try
        {
            var result = await Http.GetFromJsonAsync<List<ReviewResponseDto>>($"api/Review/{BookId}");
            reviews = result ?? new();
            averageRating = reviews.Count > 0 ? reviews.Average(r => r.Rating) : 0;
            reviewsLoaded = true;
        }
        catch { reviews = new(); }
        finally { isLoadingReviews = false; StateHasChanged(); }
    }

    // ── Tab switching ──
    private async Task SwitchTab(string tab)
    {
        activeTab = tab;
        if (tab == "review") await LoadReviews();
    }

    // Render stars HTML từ rating số (hỗ trợ cả int và double)
    private void SelectThumb(int idx, string url) { activeThumb = idx; currentImageUrl = url; }

    private HttpRequestMessage BuildReq(HttpMethod m, string url)
    {
        var req = new HttpRequestMessage(m, url);
        if (!string.IsNullOrEmpty(accessToken))
            req.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", accessToken);
        return req;
    }

    private async Task AddToCart()
    {
        if (!isLoggedIn) { Navigation.NavigateTo("/login"); return; }
        if (book == null || book.Quantity == 0) return;
        isAddingCart = true; StateHasChanged();
        try
        {
            var req = BuildReq(HttpMethod.Post, "api/cart/add");
            req.Content = JsonContent.Create(new { bookId = book.BookId, quantity = qty });
            var resp = await Http.SendAsync(req);
            if (resp.IsSuccessStatusCode) { cartCount += qty; await ShowToast($"Đã thêm {qty} cuốn vào giỏ hàng!"); }
            else if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized) Navigation.NavigateTo("/login");
            else await ShowToast("Thêm vào giỏ thất bại.");
        }
        catch { await ShowToast("Đã xảy ra lỗi."); }
        finally { isAddingCart = false; StateHasChanged(); }
    }

    private async Task BuyNow() { await AddToCart(); if (isLoggedIn) Navigation.NavigateTo("/cart"); }
    private void IncreaseQty() { if (book != null && qty < book.Quantity) qty++; }
    private void DecreaseQty() { if (qty > 1) qty--; }
    private async Task ToggleWishlist() { isWishlisted = !isWishlisted; await ShowToast(isWishlisted ? "Đã thêm vào yêu thích!" : "Đã xóa khỏi yêu thích."); }
    private void ToggleDropdown() => showDropdown = !showDropdown;

    private async Task Logout()
    {
        foreach (var k in new[] { "accessToken", "refreshToken", "userEmail", "userFullName" })
            await JS.InvokeVoidAsync("localStorage.removeItem", k);
        isLoggedIn = false; userFullName = ""; userEmail = ""; showDropdown = false;
        Navigation.NavigateTo("/login");
    }

    // Render stars HTML từ rating số (hỗ trợ cả int và double)
    private static string RenderStars(double rating)
    {
        var full = (int)Math.Floor(rating);
        var empty = 5 - (int)Math.Ceiling(rating);
        var half = 5 - full - empty;
        return string.Concat(
            string.Concat(Enumerable.Repeat("<span class='stars'>★</span>", full)),
            string.Concat(Enumerable.Repeat("<span class='stars'>½</span>", half)),
            string.Concat(Enumerable.Repeat("<span class='stars-muted'>★</span>", empty))
        );
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        var p = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return p.Length == 1 ? p[0][..1].ToUpper() : $"{p[0][..1]}{p[^1][..1]}".ToUpper();
    }

    private static string GetSafeUrl(string? url, string fallback)
    {
        if (string.IsNullOrWhiteSpace(url)) return fallback;
        if (!Uri.TryCreate(url, UriKind.Absolute, out var uri)) return fallback;
        return (uri.Scheme == "http" || uri.Scheme == "https") ? url : fallback;
    }

    private async Task ShowToast(string msg)
    {
        toastMessage = msg; showToast = true; StateHasChanged();
        await Task.Delay(3000);
        showToast = false; StateHasChanged();
    }

    // ── DTOs ──
    private class BookResponseDto
    {
        public int BookId { get; set; }
        public string BookTitle { get; set; } = "";
        public int CategoryId { get; set; }
        public string CategoryName { get; set; } = "";
        public int AuthorId { get; set; }
        public string AuthorName { get; set; } = "";
        public int PublishYear { get; set; }
        public string? Publisher { get; set; }
        public decimal Price { get; set; }
        public int Quantity { get; set; }
        public string? Description { get; set; }
        public string? ImageUrl { get; set; }
    }

    private class ReviewResponseDto
    {
        public int ReviewId { get; set; }
        public string UserName { get; set; } = "";
        public int Rating { get; set; }
        public string? Comment { get; set; }
        public DateTime ReviewDate { get; set; }
    }

}
