@page "/book/{BookId:int}"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Net.Http.Headers
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>@(book?.BookTitle ?? "Chi tiết sách") - BookStore</PageTitle>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<script src="https://cdn.tailwindcss.com"></script>

<style>
    :root {
        --ink: #0D0B08;
        --off: #1A1511;
        --surface: #F9F6F1;
        --card: #FFFFFF;
        --gold: #C9960A;
        --gold2: #E8AF1A;
        --sand: #EAE3D9;
        --muted: #7C6F5E;
        --pale: #B0A496;
        --coral: #C94444;
        --forest: #2D6A4F;
        --fog: rgba(249,246,241,0.95);
    }

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        font-family: 'Outfit', sans-serif;
        background: var(--surface);
        color: var(--ink);
        -webkit-font-smoothing: antialiased;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(20px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0
        }

        to {
            opacity: 1
        }
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg)
        }
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1)
        }

        50% {
            transform: scale(1.15)
        }
    }

    @@keyframes shimmer {
        0% {
            background-position: -600px 0
        }

        100% {
            background-position: 600px 0
        }
    }

    @@keyframes toastIn {
        from {
            opacity: 0;
            transform: translateY(16px) scale(.96)
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1)
        }
    }

    @@keyframes dropIn {
        from {
            opacity: 0;
            transform: translateY(-10px) scale(.97)
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1)
        }
    }

    @@keyframes barIn {
        from {
            width: 0%
        }
    }

    @@keyframes imgZoom {
        from {
            opacity: 0;
            transform: scale(.96)
        }

        to {
            opacity: 1;
            transform: scale(1)
        }
    }

    @@keyframes glowPulse {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(201,150,10,.35)
        }

        50% {
            box-shadow: 0 0 0 10px rgba(201,150,10,0)
        }
    }

    .a1 {
        animation: fadeUp .55s cubic-bezier(.22,1,.36,1) .05s both
    }

    .a2 {
        animation: fadeUp .55s cubic-bezier(.22,1,.36,1) .13s both
    }

    .a3 {
        animation: fadeUp .55s cubic-bezier(.22,1,.36,1) .21s both
    }

    .skel {
        background: linear-gradient(90deg, #EAE3D9 25%, #F5F0EA 50%, #EAE3D9 75%);
        background-size: 600px 100%;
        animation: shimmer 1.6s infinite;
        border-radius: 12px;
    }

    .noise::after {
        content: '';
        position: absolute;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
        pointer-events: none;
        border-radius: inherit;
    }

    .img-stage {
        position: relative;
        border-radius: 20px;
        overflow: hidden;
        background: #fff;
        aspect-ratio: 3/4;
        box-shadow: 0 24px 60px rgba(13,11,8,.14), 0 4px 16px rgba(13,11,8,.08);
        border: 1px solid rgba(234,227,217,.6);
    }

        .img-stage img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            animation: imgZoom .35s cubic-bezier(.22,1,.36,1) both;
            transition: transform .5s ease;
        }

        .img-stage:hover img {
            transform: scale(1.03);
        }

    .float-badge {
        position: absolute;
        top: 14px;
        left: 14px;
        padding: 5px 12px;
        border-radius: 50px;
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        backdrop-filter: blur(10px);
        z-index: 2;
    }

    .thumb-strip {
        display: flex;
        gap: 8px;
        margin-top: 10px;
    }

    .thumb {
        flex: 1;
        border-radius: 12px;
        overflow: hidden;
        cursor: pointer;
        aspect-ratio: 3/4;
        border: 2px solid transparent;
        transition: all .2s cubic-bezier(.22,1,.36,1);
        background: #fff;
    }

        .thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .thumb.on {
            border-color: var(--gold);
            box-shadow: 0 4px 14px rgba(201,150,10,.3);
        }

        .thumb:not(.on) {
            opacity: .45;
            filter: grayscale(.3);
        }

        .thumb:hover {
            opacity: 1;
            filter: none;
            transform: translateY(-2px);
        }

    .qty {
        display: inline-flex;
        align-items: center;
        border: 1.5px solid var(--sand);
        border-radius: 50px;
        overflow: hidden;
        background: var(--card);
        gap: 0;
    }

    .qty-btn {
        width: 38px;
        height: 38px;
        border: none;
        background: transparent;
        cursor: pointer;
        color: var(--muted);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .9rem;
        transition: all .15s;
    }

        .qty-btn:hover:not(:disabled) {
            background: var(--ink);
            color: #fff;
        }

        .qty-btn:disabled {
            opacity: .25;
            cursor: not-allowed;
        }

    .qty-num {
        min-width: 46px;
        text-align: center;
        font-weight: 700;
        font-size: .92rem;
        border-inline: 1.5px solid var(--sand);
        color: var(--ink);
    }

    .btn-cart {
        height: 52px;
        flex: 1;
        border-radius: 14px;
        border: none;
        background: var(--ink);
        font-family: 'Outfit', sans-serif;
        font-size: .88rem;
        font-weight: 700;
        cursor: pointer;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all .22s cubic-bezier(.22,1,.36,1);
        letter-spacing: .01em;
        box-shadow: 0 6px 20px rgba(13,11,8,.22);
    }

        .btn-cart:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(13,11,8,.3);
            filter: brightness(1.12);
        }

        .btn-cart:disabled {
            opacity: .35;
            cursor: not-allowed;
        }

    .btn-buy {
        height: 52px;
        flex: 1;
        border-radius: 14px;
        border: none;
        background: linear-gradient(135deg, var(--gold) 0%, var(--gold2) 100%);
        font-family: 'Outfit', sans-serif;
        font-size: .88rem;
        font-weight: 700;
        cursor: pointer;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all .22s cubic-bezier(.22,1,.36,1);
        letter-spacing: .01em;
        box-shadow: 0 6px 20px rgba(201,150,10,.38);
        animation: glowPulse 2.5s ease-in-out 1s 2;
    }

        .btn-buy:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(201,150,10,.46);
            filter: brightness(1.04);
        }

        .btn-buy:disabled {
            opacity: .35;
            cursor: not-allowed;
            animation: none;
        }

    .btn-wish {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        border: 1.5px solid var(--sand);
        background: var(--card);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--pale);
        font-size: 1.05rem;
        transition: all .2s;
        flex-shrink: 0;
    }

        .btn-wish:hover, .btn-wish.on {
            border-color: var(--coral);
            color: var(--coral);
            background: #FDF2F2;
        }

            .btn-wish.on i {
                animation: pulse .3s ease;
            }

    .pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 12px;
        border-radius: 50px;
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .pill-cat {
        background: rgba(201,150,10,.1);
        border: 1.5px solid rgba(201,150,10,.25);
        color: #8C6A00;
    }

    .pill-ok {
        background: rgba(45,106,79,.08);
        border: 1.5px solid rgba(45,106,79,.22);
        color: var(--forest);
    }

    .pill-low {
        background: #FFF7EB;
        border: 1.5px solid #FAD580;
        color: #8C5500;
    }

    .pill-out {
        background: #FDF2F2;
        border: 1.5px solid #F5C2C2;
        color: var(--coral);
    }

    .price-main {
        font-family: 'Playfair Display', serif;
        font-size: 2.6rem;
        font-weight: 700;
        color: var(--gold);
        line-height: 1;
        letter-spacing: -.02em;
    }

    .info-card {
        background: var(--card);
        border: 1px solid var(--sand);
        border-radius: 18px;
        overflow: hidden;
    }

    .info-card-head {
        padding: 12px 20px;
        border-bottom: 1px solid var(--sand);
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        background: var(--surface);
    }

    .info-card-body {
        padding: 6px 20px 12px;
    }

    .dtable {
        width: 100%;
        border-collapse: collapse;
    }

        .dtable tr {
            border-bottom: 1px solid rgba(234,227,217,.7);
        }

            .dtable tr:last-child {
                border-bottom: none;
            }

        .dtable td {
            padding: 10px 0;
            font-size: .82rem;
            vertical-align: top;
        }

            .dtable td:first-child {
                color: var(--muted);
                width: 120px;
                font-weight: 500;
                padding-right: 14px;
            }

            .dtable td:last-child {
                color: var(--ink);
                font-weight: 600;
            }

    .policy-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 20px;
        border-bottom: 1px solid rgba(234,227,217,.6);
        cursor: pointer;
        transition: background .14s;
    }

        .policy-row:last-child {
            border-bottom: none;
        }

        .policy-row:hover {
            background: rgba(201,150,10,.04);
        }

    .policy-ico {
        width: 32px;
        height: 32px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .82rem;
        flex-shrink: 0;
    }

    .ship-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        border-radius: 14px;
        background: var(--card);
        border: 1px solid var(--sand);
        transition: border-color .15s;
    }

        .ship-row:hover {
            border-color: rgba(201,150,10,.35);
        }

    .ship-ico {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .88rem;
        flex-shrink: 0;
    }

    .coupon {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        border-radius: 10px;
        border: 1.5px dashed rgba(201,150,10,.5);
        font-size: .73rem;
        font-weight: 600;
        color: #8C6A00;
        background: rgba(201,150,10,.05);
        cursor: pointer;
        transition: all .15s;
        letter-spacing: .02em;
    }

        .coupon:hover {
            background: rgba(201,150,10,.12);
            border-color: var(--gold);
            transform: translateY(-1px);
        }

    .tab-rail {
        display: flex;
        gap: 4px;
        border-bottom: 2px solid var(--sand);
        margin-bottom: 28px;
    }

    .tab-btn {
        padding: 10px 22px;
        border: none;
        background: transparent;
        font-family: 'Outfit', sans-serif;
        font-size: .84rem;
        font-weight: 600;
        color: var(--muted);
        cursor: pointer;
        border-bottom: 3px solid transparent;
        margin-bottom: -2px;
        transition: all .18s;
        border-radius: 8px 8px 0 0;
    }

        .tab-btn.on {
            color: var(--ink);
            border-bottom-color: var(--gold);
            background: rgba(201,150,10,.05);
        }

        .tab-btn:hover:not(.on) {
            color: var(--ink);
            background: rgba(13,11,8,.03);
        }

    .spec-row {
        display: flex;
        padding: 11px 0;
        border-bottom: 1px solid rgba(234,227,217,.7);
        align-items: baseline;
    }

        .spec-row:last-child {
            border-bottom: none;
        }

    .spec-l {
        width: 150px;
        flex-shrink: 0;
        font-size: .81rem;
        color: var(--muted);
        font-weight: 500;
    }

    .spec-v {
        font-size: .81rem;
        font-weight: 600;
        color: var(--ink);
    }

    .rbar {
        height: 5px;
        border-radius: 4px;
        background: var(--sand);
        overflow: hidden;
    }

    .rfill {
        height: 100%;
        border-radius: 4px;
        background: linear-gradient(90deg, var(--gold), var(--gold2));
        animation: barIn .8s ease both;
    }

    .rv-card {
        padding: 20px;
        border-radius: 16px;
        background: var(--card);
        border: 1px solid var(--sand);
        margin-bottom: 12px;
        transition: box-shadow .2s;
    }

        .rv-card:hover {
            box-shadow: 0 4px 20px rgba(13,11,8,.07);
        }

    /* Review skeleton */
    .rv-skel {
        padding: 20px;
        border-radius: 16px;
        background: var(--card);
        border: 1px solid var(--sand);
        margin-bottom: 12px;
    }

    .bk-card {
        display: block;
        text-decoration: none;
        color: inherit;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid var(--sand);
        background: var(--card);
        transition: all .25s cubic-bezier(.22,1,.36,1);
        position: relative;
    }

        .bk-card::before {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 16px;
            background: linear-gradient(135deg, rgba(201,150,10,.06), transparent);
            opacity: 0;
            transition: opacity .25s;
            z-index: 1;
        }

        .bk-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 16px 40px rgba(13,11,8,.12);
            border-color: rgba(201,150,10,.3);
        }

            .bk-card:hover::before {
                opacity: 1;
            }

    .bk-img {
        overflow: hidden;
    }

        .bk-img img {
            width: 100%;
            aspect-ratio: 3/4;
            object-fit: cover;
            display: block;
            transition: transform .4s;
        }

    .bk-card:hover .bk-img img {
        transform: scale(1.06);
    }

    .toast-wrap {
        position: fixed;
        bottom: 24px;
        right: 24px;
        padding: 13px 20px;
        border-radius: 14px;
        font-size: .84rem;
        font-weight: 500;
        z-index: 10000;
        display: flex;
        align-items: center;
        gap: 10px;
        box-shadow: 0 10px 32px rgba(13,11,8,.22);
        animation: toastIn .25s cubic-bezier(.22,1,.36,1) both;
        backdrop-filter: blur(16px);
        background: rgba(26,21,17,.92);
        color: #fff;
        border: 1px solid rgba(255,255,255,.1);
    }

    .nav-a {
        color: rgba(13,11,8,.5);
        text-decoration: none;
        font-size: .85rem;
        font-weight: 500;
        padding: 6px 14px;
        border-radius: 8px;
        transition: all .15s;
    }

        .nav-a:hover {
            color: var(--ink);
            background: rgba(13,11,8,.05);
        }

        .nav-a.active {
            color: var(--gold);
        }

    .ft-a {
        display: flex;
        align-items: center;
        gap: 6px;
        color: rgba(255,255,255,.3);
        text-decoration: none;
        font-size: .8rem;
        margin-bottom: 9px;
        transition: color .14s;
    }

        .ft-a:hover {
            color: var(--gold2);
        }

    .ornament {
        display: flex;
        align-items: center;
        gap: 12px;
        color: var(--pale);
        font-size: .7rem;
    }

        .ornament::before, .ornament::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--sand);
        }

    .price-section {
        background: linear-gradient(135deg, #FFFBF3 0%, #FFF8EB 100%);
        border: 1px solid rgba(201,150,10,.2);
        border-radius: 18px;
        padding: 20px;
        position: relative;
        overflow: hidden;
    }

        .price-section::before {
            content: '';
            position: absolute;
            top: -30px;
            right: -30px;
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(201,150,10,.14) 0%, transparent 70%);
        }

    .section-accent {
        display: inline-block;
        width: 3px;
        height: 22px;
        background: linear-gradient(180deg, var(--gold), var(--gold2));
        border-radius: 2px;
        flex-shrink: 0;
    }

    .img-overlay-tag {
        position: absolute;
        bottom: 14px;
        right: 14px;
        padding: 5px 10px;
        background: rgba(13,11,8,.68);
        backdrop-filter: blur(10px);
        border-radius: 8px;
        color: #fff;
        font-size: .68rem;
        font-weight: 600;
        letter-spacing: .04em;
    }

    .author-chip {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 5px 12px 5px 5px;
        background: var(--surface);
        border: 1px solid var(--sand);
        border-radius: 50px;
        font-size: .8rem;
        font-weight: 600;
        color: var(--ink);
        text-decoration: none;
        transition: all .15s;
    }

        .author-chip:hover {
            border-color: var(--gold);
            background: rgba(201,150,10,.05);
            color: #8C6A00;
        }

    .author-chip-avatar {
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--gold), var(--gold2));
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: .72rem;
        font-weight: 700;
    }

    .stars {
        color: var(--gold2);
        letter-spacing: -.5px;
    }

    .stars-muted {
        color: var(--sand);
    }

    .rating-big {
        font-family: 'Playfair Display', serif;
        font-size: 4.5rem;
        font-weight: 700;
        color: var(--ink);
        line-height: 1;
    }

    /* CTA banner - gợi ý đánh giá qua đơn hàng */
    .rv-cta {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 16px 20px;
        border-radius: 14px;
        background: linear-gradient(135deg, rgba(201,150,10,.07), rgba(201,150,10,.03));
        border: 1.5px dashed rgba(201,150,10,.35);
        margin-bottom: 24px;
    }
</style>

<!-- TOP STRIP -->
<div style="background:#0D0B08;" class="py-1.5">
    <div class="max-w-7xl mx-auto px-5 flex justify-between items-center">
        <div class="flex items-center gap-5" style="color:rgba(255,255,255,.38);font-size:.73rem;">
            <span class="flex items-center gap-1.5"><i class="bi bi-telephone-fill" style="color:var(--gold2);font-size:.62rem;"></i>0901 234 567</span>
            <span class="hidden sm:flex items-center gap-1.5"><i class="bi bi-envelope-fill" style="color:var(--gold2);font-size:.62rem;"></i>bookstore@gmail.com</span>
        </div>
        <a href="#" class="text-xs no-underline flex items-center gap-1.5" style="color:rgba(255,255,255,.32);">
            <i class="bi bi-box-seam" style="font-size:.62rem;"></i>Theo dõi đơn hàng
        </a>
    </div>
</div>

<!-- NAVBAR -->
<nav class="py-3 sticky top-0 z-50" style="background:var(--fog);border-bottom:1px solid var(--sand);backdrop-filter:blur(24px);">
    <div class="max-w-7xl mx-auto px-5 flex items-center gap-4">
        <a href="/" class="no-underline flex items-center gap-2.5 mr-auto lg:mr-0 flex-shrink-0"
           style="font-family:'Playfair Display',serif;font-size:1.5rem;color:var(--ink);letter-spacing:-.01em;">
            <div class="w-9 h-9 rounded-[11px] flex items-center justify-center text-white text-sm flex-shrink-0"
                 style="background:linear-gradient(135deg, var(--gold) 0%, var(--gold2) 100%);box-shadow:0 3px 10px rgba(201,150,10,.35);">
                <i class="bi bi-book-half"></i>
            </div>
            Book<span style="color:var(--gold);">Store</span>
        </a>
        <div class="hidden lg:flex items-center gap-0.5 mx-auto">
            @foreach (var (href, label) in new[] { ("/", "Trang Chủ"), ("/categories", "Danh Mục"), ("/books/new", "Sách Mới"), ("/books/bestseller", "Bán Chạy") })
            {
                <a href="@href" class="nav-a">@label</a>
            }
        </div>
        <div class="flex items-center gap-2 flex-shrink-0">
            <a href="/cart" class="relative w-9 h-9 rounded-[10px] flex items-center justify-center text-sm no-underline"
               style="background:var(--surface);border:1px solid var(--sand);color:var(--ink);">
                <i class="bi bi-bag"></i>
                @if (cartCount > 0)
                {
                    <span class="absolute -top-1.5 -right-1.5 text-white text-[.5rem] w-4 h-4 rounded-full flex items-center justify-center font-bold"
                          style="background:var(--coral);">@cartCount</span>
                }
            </a>
            @if (!isLoggedIn)
            {
                <a href="/login" class="flex items-center gap-2 text-white rounded-[10px] px-4 py-[8px] text-sm font-semibold no-underline" style="background:var(--ink);">
                    <i class="bi bi-person text-sm"></i><span class="hidden sm:inline">Đăng nhập</span>
                </a>
            }
            else
            {
                <div class="relative">
                    <button class="w-9 h-9 rounded-[10px] flex items-center justify-center text-white text-[.72rem] font-bold cursor-pointer border-0"
                            style="background:linear-gradient(135deg,var(--gold),var(--gold2));box-shadow:0 2px 8px rgba(201,150,10,.3);"
                            @onclick="ToggleDropdown">
                        @GetInitials(userFullName)
                    </button>
                    @if (showDropdown)
                    {
                        <div class="absolute top-[calc(100%+10px)] right-0 rounded-2xl min-w-[210px] z-[9999] overflow-hidden"
                             style="background:var(--surface);border:1px solid var(--sand);box-shadow:0 16px 48px rgba(13,11,8,.16);animation:dropIn .2s cubic-bezier(.22,1,.36,1) both;">
                            <div class="px-4 py-3.5 border-b" style="border-color:var(--sand);">
                                <div class="text-sm font-semibold truncate" style="color:var(--ink);">@userFullName</div>
                                <div class="text-xs truncate mt-0.5" style="color:var(--muted);">@userEmail</div>
                            </div>
                            <div style="padding:6px;">
                                <a href="/profile" class="flex items-center gap-2.5 px-3 py-2 text-sm no-underline rounded-xl" style="color:var(--muted);"
                                   onmouseover="this.style.background='rgba(201,150,10,.07)'" onmouseout="this.style.background=''">
                                    <i class="bi bi-person-circle" style="color:var(--gold);"></i>Hồ sơ của tôi
                                </a>
                                <a href="/profile?tab=orders" class="flex items-center gap-2.5 px-3 py-2 text-sm no-underline rounded-xl" style="color:var(--muted);"
                                   onmouseover="this.style.background='rgba(201,150,10,.07)'" onmouseout="this.style.background=''">
                                    <i class="bi bi-bag-check" style="color:var(--gold);"></i>Đơn hàng
                                </a>
                                <div style="height:1px;background:var(--sand);margin:6px 0;"></div>
                                <button class="flex items-center gap-2.5 px-3 py-2 w-full text-left text-sm rounded-xl bg-transparent border-0 cursor-pointer" style="color:var(--muted);"
                                        @onclick="Logout" onmouseover="this.style.background='#FDF2F2'" onmouseout="this.style.background=''">
                                    <i class="bi bi-box-arrow-right" style="color:var(--coral);"></i>Đăng xuất
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</nav>

<!-- BREADCRUMB -->
<div class="py-2.5" style="background:var(--surface);border-bottom:1px solid var(--sand);">
    <div class="max-w-7xl mx-auto px-5">
        <div class="flex items-center gap-1.5 flex-wrap" style="font-size:.75rem;color:var(--muted);">
            <a href="/" class="no-underline font-medium" style="color:var(--gold);">Trang chủ</a>
            <i class="bi bi-chevron-right" style="font-size:.48rem;color:var(--pale);"></i>
            <a href="/categories" class="no-underline font-medium" style="color:var(--gold);">Danh mục</a>
            @if (book != null)
            {
                <i class="bi bi-chevron-right" style="font-size:.48rem;color:var(--pale);"></i>
                <a href="/categories/@book.CategoryId" class="no-underline font-medium" style="color:var(--gold);">@book.CategoryName</a>
            }
            <i class="bi bi-chevron-right" style="font-size:.48rem;color:var(--pale);"></i>
            <span class="truncate max-w-[220px] font-semibold" style="color:var(--ink);">@(book?.BookTitle ?? "Chi tiết sách")</span>
        </div>
    </div>
</div>

@if (isLoading)
{
    <section class="py-12" style="background:var(--surface);">
        <div class="max-w-7xl mx-auto px-5 flex flex-col lg:flex-row gap-10">
            <div class="w-full lg:w-[300px] flex-shrink-0">
                <div class="skel rounded-[20px] mb-3" style="aspect-ratio:3/4;"></div>
                <div class="flex gap-2">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="skel flex-1 rounded-[12px]" style="aspect-ratio:3/4;"></div>
                    }
                </div>
            </div>
            <div class="flex-1 flex flex-col gap-4 pt-2">
                <div class="skel h-5 w-28 rounded-full"></div>
                <div class="skel h-10 w-3/4 rounded-xl"></div>
                <div class="skel h-4 w-56 rounded-lg"></div>
                <div class="skel h-14 w-48 mt-3 rounded-2xl"></div>
                <div class="skel h-10 w-72 mt-2 rounded-full"></div>
                <div class="flex gap-3 mt-4">
                    <div class="skel h-13 flex-1 rounded-[14px]"></div>
                    <div class="skel h-13 flex-1 rounded-[14px]"></div>
                </div>
            </div>
        </div>
    </section>
}
else if (book == null)
{
    <section class="py-40 text-center" style="background:var(--surface);">
        <div style="font-size:4rem;margin-bottom:20px;">📚</div>
        <h2 class="mb-3" style="font-family:'Playfair Display',serif;font-size:2rem;color:var(--ink);">Không tìm thấy sách</h2>
        <p class="text-sm mb-8" style="color:var(--muted);">Sách không tồn tại hoặc đã bị xóa.</p>
        <a href="/" class="inline-flex items-center gap-2 no-underline rounded-[12px] px-7 py-3.5 font-semibold text-sm text-white" style="background:var(--ink);">
            <i class="bi bi-arrow-left"></i>Về trang chủ
        </a>
    </section>
}
else
{
    <!-- HERO SECTION -->
    <section class="py-10 pb-14" style="background:var(--surface);">
        <div class="max-w-7xl mx-auto px-5">
            <div class="flex flex-col lg:flex-row gap-10 xl:gap-14 items-start">

                <!-- LEFT: Image panel -->
                <div class="w-full lg:w-[300px] flex-shrink-0 a1">
                    <div class="img-stage">
                        <img src="@GetSafeUrl(currentImageUrl, FallbackImg)" alt="@book.BookTitle" />
                        @if (book.Quantity == 0)
                        {
                            <div class="absolute inset-0 flex items-center justify-center" style="background:rgba(13,11,8,.54);">
                                <span class="text-white font-semibold text-sm px-5 py-2.5 rounded-[10px]" style="background:var(--coral);letter-spacing:.04em;">Hết hàng</span>
                            </div>
                        }
                        @if (book.Quantity is > 0 and <= 5)
                        {
                            <div class="float-badge text-white" style="background:rgba(201,69,44,.85);backdrop-filter:blur(8px);">🔥 Sắp hết</div>
                        }
                        <div class="img-overlay-tag">
                            <i class="bi bi-images" style="font-size:.6rem;margin-right:4px;"></i>@(activeThumb + 1) / @bookImages.Count
                        </div>
                    </div>

                    <div class="thumb-strip">
                        @for (int i = 0; i < bookImages.Count; i++)
                        {
                            var idx = i; var url = bookImages[i];
                            <div class="thumb @(activeThumb == idx ? "on" : "")" @onclick="() => SelectThumb(idx, url)">
                                <img src="@GetSafeUrl(url, FallbackImg)" loading="lazy" alt="Ảnh @(i+1)" />
                            </div>
                        }
                    </div>

                    <div class="flex items-center gap-3 mt-6 mb-3">
                        <span class="text-sm font-medium" style="color:var(--muted);">Số lượng</span>
                        <div class="qty">
                            <button class="qty-btn" @onclick="DecreaseQty" disabled="@(qty <= 1)"><i class="bi bi-dash"></i></button>
                            <div class="qty-num">@qty</div>
                            <button class="qty-btn" @onclick="IncreaseQty" disabled="@(qty >= book.Quantity)"><i class="bi bi-plus"></i></button>
                        </div>
                        @if (book.Quantity > 0)
                        {
                            <span class="text-xs" style="color:var(--pale);">/ @book.Quantity có sẵn</span>
                        }
                    </div>

                    <div class="flex gap-2.5 mb-6">
                        <button class="btn-cart" @onclick="AddToCart" disabled="@(book.Quantity == 0 || isAddingCart)">
                            @if (isAddingCart)
                            {
                                <i class="bi bi-arrow-repeat" style="animation:spin 1s linear infinite;display:inline-block;"></i>
                            }
                            else
                            {
                                <i class="bi bi-cart-plus"></i>

                                <span>Thêm</span>
                            }
                        </button>
                        <button class="btn-buy" @onclick="BuyNow" disabled="@(book.Quantity == 0)">
                            <i class="bi bi-lightning-charge-fill"></i><span>Mua ngay</span>
                        </button>
                        <button class="btn-wish @(isWishlisted ? "on" : "")" @onclick="ToggleWishlist" title="Yêu thích">
                            <i class="bi @(isWishlisted ? "bi-heart-fill" : "bi-heart")"></i>
                        </button>
                    </div>

                    <div class="info-card">
                        <div class="info-card-head">Cam kết của BookStore</div>
                        @foreach (var (ico, bg, clr, title, sub) in new[]{
                    ("bi-truck",        "rgba(21,101,192,.1)", "#1565C0", "Giao hàng nhanh & uy tín", "Toàn quốc 2–3 ngày làm việc"),
                    ("bi-arrow-repeat", "rgba(45,106,79,.1)",  "#2D6A4F", "Đổi trả miễn phí",         "Trong vòng 7 ngày"),
                    ("bi-shield-check", "rgba(201,150,10,.1)", "#8C6A00", "Hàng chính hãng",          "Cam kết 100% chính hãng"),
                    ("bi-headset",      "rgba(201,68,68,.1)",  "#C94444", "Hỗ trợ 24/7",              "Hotline: 0901 234 567"),
                    })
                        {
                            <div class="policy-row">
                                <div class="policy-ico" style="background:@bg; color:@clr;"><i class="bi @ico"></i></div>
                                <div class="flex-1 min-w-0">
                                    <div class="text-xs font-semibold" style="color:var(--ink);">@title</div>
                                    <div class="text-xs mt-0.5" style="color:var(--muted);">@sub</div>
                                </div>
                                <i class="bi bi-chevron-right flex-shrink-0" style="font-size:.58rem;color:var(--pale);"></i>
                            </div>
                        }
                    </div>
                </div>

                <!-- RIGHT: Info -->
                <div class="flex-1 min-w-0 a2">
                    <div class="flex items-center gap-2 flex-wrap mb-4">
                        <span class="pill pill-cat"><i class="bi bi-bookmark-fill" style="font-size:.62rem;"></i>@book.CategoryName</span>
                    </div>

                    <h1 style="font-family:'Playfair Display',serif;font-size:clamp(1.7rem,3.2vw,2.3rem);color:var(--ink);line-height:1.2;font-weight:700;margin:0 0 14px;">
                        @book.BookTitle
                    </h1>

                    <div class="flex flex-wrap items-center gap-2 mb-4">
                        @if (!string.IsNullOrEmpty(book.AuthorName))
                        {
                            <a href="#" class="author-chip">
                                <div class="author-chip-avatar">@book.AuthorName[0]</div>@book.AuthorName
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(book.Publisher))
                        {
                            <span class="pill pill-cat" style="border-style:solid;">
                                <i class="bi bi-building" style="font-size:.6rem;"></i>@book.Publisher
                            </span>
                        }
                        @if (book.PublishYear > 0)
                        {
                            <span class="pill pill-cat" style="border-style:solid;">
                                <i class="bi bi-calendar3" style="font-size:.6rem;"></i>@book.PublishYear
                            </span>
                        }
                    </div>

                    <!-- Stars + stats — dynamic từ reviews -->
                    <div class="flex items-center gap-3 mb-6 flex-wrap" style="font-size:.83rem;">
                        <div class="flex items-center gap-1.5">
                            @((MarkupString)RenderStars(averageRating))
                            <span class="font-semibold text-sm" style="color:var(--ink);">@averageRating.ToString("F1")</span>
                        </div>
                        <span style="color:var(--pale);">·</span>
                        <span style="color:var(--muted);">@reviews.Count đánh giá</span>
                        <span style="color:var(--pale);">·</span>
                        <span style="color:var(--muted);">Đã bán <strong style="color:var(--ink);">342</strong></span>
                    </div>

                    <div class="price-section mb-5">
                        <div class="flex items-end gap-3 flex-wrap mb-3">
                            <div class="price-main">@book.Price.ToString("#,##0")<span style="font-size:1.4rem;font-weight:600;"> đ</span></div>
                        </div>
                        <div class="text-xs mb-3" style="color:#8C6A00;">
                            <i class="bi bi-info-circle" style="font-size:.68rem;margin-right:4px;"></i>Chính sách khuyến mãi áp dụng tại BookStore
                        </div>
                        @if (book.Quantity > 5)
                        {
                            <span class="pill pill-ok"><i class="bi bi-check-circle-fill" style="font-size:.62rem;"></i>Còn hàng · @book.Quantity cuốn</span>
                        }
                        else if (book.Quantity > 0)
                        {
                            <span class="pill pill-low"><i class="bi bi-exclamation-triangle-fill" style="font-size:.62rem;"></i>Chỉ còn @book.Quantity cuốn</span>
                        }
                        else
                        {
                            <span class="pill pill-out"><i class="bi bi-x-circle-fill" style="font-size:.62rem;"></i>Hết hàng</span>
                        }
                    </div>

                    <div class="mb-5">
                        <div class="text-xs font-semibold uppercase tracking-widest mb-2.5" style="color:var(--muted);">Vận chuyển</div>
                        <div class="flex flex-col gap-2">
                            <div class="ship-row">
                                <div class="ship-ico" style="background:rgba(21,101,192,.1);color:#1565C0;"><i class="bi bi-send-fill"></i></div>
                                <div>
                                    <div class="text-sm font-semibold" style="color:var(--ink);">Giao hàng tiêu chuẩn</div>
                                    <div class="text-xs mt-0.5" style="color:var(--muted);">Dự kiến 2–3 ngày · Miễn phí từ 150.000đ</div>
                                </div>
                                <div class="ml-auto text-xs font-semibold" style="color:var(--forest);">Miễn phí</div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-6">
                        <div class="text-xs font-semibold uppercase tracking-widest mb-2.5" style="color:var(--muted);">Mã ưu đãi</div>
                        <div class="flex gap-2 flex-wrap">
                            @foreach (var c in new[] { "Giảm 10k đơn từ 100k", "Giảm 20k đơn từ 200k", "Freeship toàn quốc" })
                            {
                                <div class="coupon"><i class="bi bi-ticket-perforated-fill" style="font-size:.68rem;"></i>@c</div>
                            }
                        </div>
                    </div>

                    <div class="info-card">
                        <div class="info-card-head">Thông tin chi tiết</div>
                        <div class="info-card-body pt-2">
                            <table class="dtable">
                                @foreach (var (lbl, val) in new[]{
                            ("Nhà cung cấp",  book.Publisher ?? "—"),
                            ("Tác giả",       book.AuthorName),
                            ("Nhà xuất bản",  book.Publisher ?? "—"),
                            ("Năm xuất bản",  book.PublishYear > 0 ? book.PublishYear.ToString() : "—"),
                            ("Hình thức bìa", "Bìa mềm"),
                            ("Tồn kho",       book.Quantity + " cuốn"),
                            })
                                {
                                    <tr><td>@lbl</td><td>@val</td></tr>
                                }
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- TABS SECTION -->
    <section class="py-10" style="background:#FFFFFF;border-top:1px solid var(--sand);">
        <div class="max-w-4xl mx-auto px-5">
            <div class="tab-rail">
                <button class="tab-btn @(activeTab=="desc"?"on":"")" @onclick='()=>SwitchTab("desc")'>Mô tả sách</button>
                <button class="tab-btn @(activeTab=="spec"?"on":"")" @onclick='()=>SwitchTab("spec")'>Thông số</button>
                <button class="tab-btn @(activeTab=="review"?"on":"")" @onclick='()=>SwitchTab("review")'>
                    Đánh giá @(reviews.Count > 0 ? $"({reviews.Count})" : "")
                </button>
            </div>

            @if (activeTab == "desc")
            {
                <div style="animation:fadeIn .22s ease;">
                    @if (!string.IsNullOrEmpty(book.Description))
                    {
                        <div class="text-sm leading-[1.95]" style="color:#3C2D1E;">
                            @((MarkupString)book.Description.Replace("\n", "<br/>"))
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-16 rounded-2xl" style="background:var(--surface);border:2px dashed var(--sand);">
                            <div class="text-5xl mb-4 opacity-20">📖</div>
                            <p class="text-sm m-0" style="color:var(--muted);">Chưa có mô tả cho sách này.</p>
                        </div>
                    }
                </div>
            }
            else if (activeTab == "spec")
            {
                <div style="animation:fadeIn .22s ease;">
                    @foreach (var (lbl, val) in new[]{
            ("Tên sách",     book.BookTitle),
            ("Tác giả",      book.AuthorName),
            ("Danh mục",     book.CategoryName),
            ("Nhà xuất bản", book.Publisher ?? "—"),
            ("Năm xuất bản", book.PublishYear > 0 ? book.PublishYear.ToString() : "—"),
            ("Tồn kho",      book.Quantity + " cuốn"),
            ("Giá bán",      book.Price.ToString("#,##0") + "đ"),
            })
                    {
                        <div class="spec-row"><div class="spec-l">@lbl</div><div class="spec-v">@val</div></div>
                    }
                </div>
            }
            else
            {
                <!-- ══ REVIEW TAB ══ -->
                <div style="animation:fadeIn .22s ease;">

                    @if (isLoadingReviews)
                    {
                        <!-- Skeleton loader -->
                        <div class="flex gap-10 mb-8 p-6 rounded-2xl" style="background:var(--surface);border:1px solid var(--sand);">
                            <div class="skel w-24 h-24 rounded-2xl flex-shrink-0"></div>
                            <div class="flex-1 flex flex-col gap-3">
                                <div class="skel h-4 w-full rounded-lg"></div>
                                <div class="skel h-4 w-full rounded-lg"></div>
                                <div class="skel h-4 w-3/4 rounded-lg"></div>
                            </div>
                        </div>
                        @for (int i = 0; i < 3; i++)
                        {
                            <div class="rv-skel">
                                <div class="flex gap-3 mb-3">
                                    <div class="skel w-10 h-10 rounded-full flex-shrink-0"></div>
                                    <div class="flex-1 flex flex-col gap-2">
                                        <div class="skel h-4 w-40 rounded-lg"></div>
                                        <div class="skel h-3 w-28 rounded-lg"></div>
                                    </div>
                                </div>
                                <div class="skel h-4 w-full rounded-lg mb-2" style="margin-left:52px;"></div>
                                <div class="skel h-4 w-2/3 rounded-lg" style="margin-left:52px;"></div>
                            </div>
                        }
                    }
                    else
                    {
                        <!-- Rating Summary -->
                        @if (reviews.Count > 0)
                        {
                            <div class="flex gap-10 mb-8 flex-wrap items-center p-6 rounded-2xl" style="background:var(--surface);border:1px solid var(--sand);">
                                <div class="text-center">
                                    <div class="rating-big">@averageRating.ToString("F1")</div>
                                    <div class="my-2" style="font-size:1.3rem;">@((MarkupString)RenderStars(averageRating))</div>
                                    <div class="text-xs" style="color:var(--muted);">@reviews.Count đánh giá</div>
                                </div>
                                <div class="flex-1 min-w-[160px]">
                                    @foreach (var star in new[] { 5, 4, 3, 2, 1 })
                                    {
                                        var count = reviews.Count(r => r.Rating == star);
                                        var pct = reviews.Count > 0 ? (int)Math.Round(count * 100.0 / reviews.Count) : 0;
                                        <div class="flex items-center gap-3 mb-2.5">
                                            <span class="text-xs w-5 text-right font-medium" style="color:var(--muted);">@(star)★</span>
                                            <div class="flex-1 rbar"><div class="rfill" style="width:@(pct)%;"></div></div>
                                            <span class="text-xs w-7 font-medium" style="color:var(--muted);">@(pct)%</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <!-- CTA: hướng dẫn đánh giá qua trang đơn hàng -->
                        <div class="rv-cta">
                            <div class="w-10 h-10 rounded-[11px] flex items-center justify-center flex-shrink-0"
                                 style="background:rgba(201,150,10,.12);color:var(--gold);">
                                <i class="bi bi-bag-check-fill"></i>
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="text-sm font-semibold mb-0.5" style="color:var(--ink);">Bạn đã mua cuốn sách này?</div>
                                <div class="text-xs" style="color:var(--muted);">Vào trang đơn hàng để gửi đánh giá sau khi đơn hoàn thành.</div>
                            </div>
                            <a href="/profile?tab=orders"
                               class="inline-flex items-center gap-1.5 px-4 py-2 rounded-[10px] text-xs font-bold no-underline flex-shrink-0 transition-all"
                               style="background:var(--ink);color:#fff;"
                               onmouseover="this.style.filter='brightness(1.15)'" onmouseout="this.style.filter=''">
                                <i class="bi bi-arrow-right-circle"></i>Đơn hàng
                            </a>
                        </div>

                        <!-- Review list -->
                        @if (reviews.Count == 0)
                        {
                            <div class="text-center py-16 rounded-2xl" style="background:var(--surface);border:2px dashed var(--sand);">
                                <div style="font-size:3rem;margin-bottom:12px;opacity:.25;">⭐</div>
                                <p class="text-sm font-semibold mb-1" style="color:var(--ink);">Chưa có đánh giá nào</p>
                                <p class="text-xs" style="color:var(--muted);">Hãy là người đầu tiên đánh giá cuốn sách này!</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var rv in reviews)
                            {
                                <div class="rv-card">
                                    <div class="flex items-start gap-3 mb-3">
                                        <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold flex-shrink-0"
                                             style="background:linear-gradient(135deg,var(--gold),var(--gold2));font-size:.9rem;">
                                            @(rv.UserName?.Length > 0 ? rv.UserName[0].ToString().ToUpper() : "?")
                                        </div>
                                        <div class="flex-1">
                                            <div class="flex items-center justify-between flex-wrap gap-1">
                                                <span class="font-semibold text-sm" style="color:var(--ink);">@rv.UserName</span>
                                                <span class="text-xs" style="color:var(--pale);">@rv.ReviewDate.ToString("dd/MM/yyyy")</span>
                                            </div>
                                            <div class="flex items-center gap-2 mt-1">
                                                <span class="stars" style="font-size:.88rem;">@((MarkupString)RenderStars(rv.Rating))</span>
                                                <span class="text-xs font-semibold px-2 py-0.5 rounded-full" style="background:rgba(45,106,79,.1);color:var(--forest);">✓ Đã mua</span>
                                            </div>
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(rv.Comment))
                                    {
                                        <p class="text-sm leading-[1.8] m-0" style="color:#3C2D1E;padding-left:52px;">@rv.Comment</p>
                                    }
                                </div>
                            }
                        }
                    }
                </div>
            }
        </div>
    </section>

    <!-- RELATED BOOKS -->
    @if (relatedBooks.Count > 0)
    {
        <section class="py-12" style="background:var(--surface);border-top:1px solid var(--sand);">
            <div class="max-w-7xl mx-auto px-5">
                <div class="flex items-end justify-between mb-8 flex-wrap gap-4">
                    <div class="flex items-start gap-3">
                        <div class="section-accent mt-1.5"></div>
                        <div>
                            <div class="text-xs font-bold uppercase tracking-widest mb-1.5" style="color:var(--gold);">Cùng danh mục</div>
                            <h2 style="font-family:'Playfair Display',serif;font-size:1.9rem;color:var(--ink);margin:0;font-weight:700;line-height:1.1;">Sách liên quan</h2>
                        </div>
                    </div>
                    <a href="/categories/@book.CategoryId"
                       class="inline-flex items-center gap-2 no-underline rounded-[12px] border px-5 py-2.5 text-sm font-semibold"
                       style="border-color:var(--sand);color:var(--ink);background:var(--card);"
                       onmouseover="this.style.borderColor='var(--gold)';this.style.color='#8C6A00'"
                       onmouseout="this.style.borderColor='var(--sand)';this.style.color='var(--ink)'">
                        Xem tất cả <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
                <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
                    @foreach (var rb in relatedBooks)
                    {
                        <a href="/book/@rb.BookId" class="bk-card">
                            <div class="bk-img"><img src="@GetSafeUrl(rb.ImageUrl, FallbackImg)" alt="@rb.BookTitle" loading="lazy" /></div>
                            <div class="p-3.5" style="position:relative;z-index:2;">
                                <div class="text-xs font-bold uppercase tracking-wider mb-1.5" style="color:var(--gold);">@rb.CategoryName</div>
                                <div class="font-semibold text-sm leading-snug mb-1"
                                     style="color:var(--ink);font-family:'Playfair Display',serif;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                    @rb.BookTitle
                                </div>
                                <div class="text-xs mb-2.5" style="color:var(--muted);">@rb.AuthorName</div>
                                <div class="font-bold text-sm" style="color:var(--coral);">@rb.Price.ToString("#,##0")đ</div>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </section>
    }
}

