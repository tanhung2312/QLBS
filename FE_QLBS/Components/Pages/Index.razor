        {
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5">
                @for (int s = 0; s < 8; s++)
                {
                    <div class="rounded-2xl overflow-hidden border border-[#EDE8DF] bg-white">
                        <div class="skel h-[220px] w-full" style="border-radius:0;"></div>
                        <div class="p-4 space-y-2.5">
                            <div class="skel h-3 w-1/3 rounded"></div>
                            <div class="skel h-4 w-3/4 rounded"></div>
                            <div class="skel h-3 w-1/2 rounded"></div>
                            <div class="skel h-9 rounded-xl mt-3"></div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (!newBooks.Any())
        {
            <div class="text-center py-20"><div class="text-6xl opacity-40 mb-4">📭</div><p class="text-[#9B8B7A] text-[.9rem]">Chưa có sách nào.</p></div>
        }
        else
        {
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5">
                @foreach (var book in newBooks)
                {
                    var bookId = book.BookId;
                    <div class="book-card-div" @onclick="() => GoToBook(bookId)">
                        <div class="relative overflow-hidden" style="height:210px;">
                            <img src="@book.ImageUrl" alt="@book.BookTitle" loading="lazy"
                                 class="w-full h-full object-cover transition-transform duration-500" />
                            <div class="absolute inset-0" style="background:linear-gradient(180deg,transparent 45%,rgba(26,18,8,.65) 100%);"></div>
                            @if (book.IsBestSeller)
                            {
                                <span class="absolute top-2.5 left-2.5 text-white text-[.58rem] font-bold tracking-wide uppercase px-2 py-0.5 rounded-full"
                                      style="background:rgba(192,57,43,.82);backdrop-filter:blur(8px);">Best Seller</span>
                            }
                            <span class="absolute top-2.5 right-2.5 text-white text-[.58rem] font-bold px-2 py-0.5 rounded-full"
                                  style="background:rgba(122,158,126,.82);backdrop-filter:blur(8px);">Mới</span>
                            <div class="absolute bottom-0 inset-x-0 px-3.5 pb-3 flex items-end justify-between">
                                <div class="font-serif font-bold text-white text-[1.1rem]" style="text-shadow:0 1px 10px rgba(0,0,0,.6);">
                                    @book.Price.ToString("#,##0")<span class="text-[.58em] font-normal ml-0.5">đ</span>
                                </div>
                                <button class="w-8 h-8 rounded-full flex items-center justify-center border-0 cursor-pointer transition-all text-[.8rem] text-white hover:scale-110"
                                        style="background:rgba(255,255,255,.15);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.25) !important;"
                                        @onclick="() => ToggleWishlist(bookId)"
                                        @onclick:stopPropagation="true">
                                    <i class="bi @(wishlist.Contains(bookId)?"bi-heart-fill text-red-300":"bi-heart")"></i>
                                </button>
                            </div>
                        </div>
                        <div class="px-4 pt-3.5 pb-4" style="background:rgba(255,255,255,.75);backdrop-filter:blur(12px);">
                            <div class="text-[#D4860B] text-[.63rem] font-bold uppercase tracking-widest mb-1">@book.CategoryName</div>
                            <div class="font-serif font-bold text-[#1A1208] text-[.97rem] leading-snug mb-1.5"
                                 style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                @book.BookTitle
                            </div>
                            <div class="flex items-center gap-1 mb-3">
                                <span style="color:#F5A623;font-size:.8rem;letter-spacing:-.5px;line-height:1;">★★★★</span><span style="color:#C4B8A8;font-size:.8rem;line-height:1;">★</span>
                                <span class="text-[#9B8B7A] text-[.68rem] ml-1">4.2 (128)</span>
                            </div>
                            <button class="w-full flex items-center justify-center gap-1.5 text-white border-0 rounded-xl py-2.5 text-[.79rem] font-semibold cursor-pointer transition-all duration-300 hover:-translate-y-0.5"
                                    style="background:linear-gradient(135deg,#6B4C2A,#9B6E3A);box-shadow:0 3px 14px rgba(107,76,42,.25);font-family:'Plus Jakarta Sans',sans-serif;"
                                    @onclick="() => AddToCart(bookId)"
                                    @onclick:stopPropagation="true">
                                <i class="bi bi-bag-plus text-[.8rem]"></i> Thêm vào giỏ
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

