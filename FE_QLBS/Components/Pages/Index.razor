                    </div>BookStore
                </a>
                <p class="text-[.85rem] leading-[1.75] text-white/40 max-w-[230px] mb-6">Nơi quy tụ kho tàng tri thức nhân loại. Kết nối bạn với hàng chục nghìn đầu sách chất lượng.</p>
                @foreach (var (ic, txt) in new[] { ("geo-alt-fill", "123 Nguyễn Huệ, Quận 1, TP.HCM"), ("telephone-fill", "0901 234 567"), ("envelope-fill", "bookstore@gmail.com") })
                {
                    <div class="flex items-start gap-3 text-[.82rem] text-white/45 mb-2">
                        <i class="bi bi-@ic text-[#D4860B] mt-0.5 flex-shrink-0"></i><span>@txt</span>
                    </div>
                }
            </div>
            <div>
                <div class="font-serif font-bold text-white text-[1rem] mb-5 pb-3 border-b" style="border-color:rgba(212,134,11,.3);">Danh mục sách</div>
                @foreach (var cat in categories)
                {
                    <a href="/category/@cat.Slug" class="footer-lnk"><i class="bi bi-chevron-right"></i>@cat.Name</a>
                }
            </div>
            <div>
                <div class="font-serif font-bold text-white text-[1rem] mb-5 pb-3 border-b" style="border-color:rgba(212,134,11,.3);">Hỗ trợ khách hàng</div>
                @foreach (var (href, lbl) in new[] { ("/guide", "Hướng dẫn mua hàng"), ("/return-policy", "Chính sách đổi trả"), ("/shipping", "Vận chuyển"), ("/payment", "Thanh toán"), ("/faq", "Câu hỏi thường gặp"), ("/contact", "Liên hệ chúng tôi") })
                {
                    <a href="@href" class="footer-lnk"><i class="bi bi-chevron-right"></i>@lbl</a>
                }
            </div>
            <div>
                <div class="font-serif font-bold text-white text-[1rem] mb-5 pb-3 border-b" style="border-color:rgba(212,134,11,.3);">Kết nối với chúng tôi</div>
                <div class="flex gap-2.5 flex-wrap mb-7">
                    @foreach (var ic in new[] { "facebook", "instagram", "youtube", "tiktok" })
                    {
                        <a href="#" class="w-9 h-9 rounded-full flex items-center justify-center text-white/55 text-sm no-underline hover:text-white hover:bg-[#D4860B] transition-all"
                           style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);">
                            <i class="bi bi-@ic"></i>
                        </a>
                    }
                </div>
                <div class="font-serif font-bold text-white text-[.95rem] mb-3">Nhận thông báo mới</div>
                <p class="text-white/40 text-[.8rem] mb-4 leading-relaxed">Đăng ký để nhận ưu đãi và sách mới mỗi tuần.</p>
                <div class="flex rounded-xl overflow-hidden" style="border:1px solid rgba(255,255,255,.12);">
                    <input type="email" @bind="newsletterEmail" placeholder="Email của bạn..."
                           class="flex-1 bg-white/[0.06] text-white text-[.82rem] px-4 py-2.5 border-0 outline-none placeholder-white/30 focus:bg-white/10 transition-colors" />
                    <button @onclick="SubscribeNewsletter" class="px-4 text-white text-sm border-0 cursor-pointer flex-shrink-0 transition-opacity hover:opacity-85"
                            style="background:linear-gradient(135deg,#D4860B,#F5A623);">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(newsletterMessage))
                {
                    <p class="mt-2.5 text-[.78rem] text-[#96CEB4] flex items-center gap-1.5">
                        <i class="bi bi-check-circle-fill"></i>@newsletterMessage
                    </p>
                }
            </div>
        </div>
        <div class="border-t py-6 flex flex-col md:flex-row items-center justify-between gap-3" style="border-color:rgba(255,255,255,.06);">
            <p class="text-[.78rem] text-white/28 m-0">&copy; @DateTime.Now.Year BookStore. Tất cả quyền được bảo lưu.</p>
            <div class="flex items-center gap-4">
                <a href="/terms" class="text-white/28 no-underline text-[.78rem] hover:text-white/55 transition-colors">Điều khoản</a>
                <span class="text-white/15">|</span>
                <a href="/privacy" class="text-white/28 no-underline text-[.78rem] hover:text-white/55 transition-colors">Bảo mật</a>
            </div>
        </div>
    </div>
</footer>

@if (showToast)
{
    <div class="toast-anim fixed bottom-6 left-1/2 text-white px-6 py-3.5 rounded-2xl text-[.86rem] font-medium z-[9999] flex items-center gap-2.5 whitespace-nowrap"
         style="transform:translateX(-50%);background:rgba(26,18,8,.95);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.08);box-shadow:0 12px 40px rgba(0,0,0,.4);">
        <i class="bi bi-check-circle-fill text-[#96CEB4]"></i>
        @toastMessage
    </div>
}

@code {
    private bool isLoggedIn = false;
    private string userFullName = "";
    private string userEmail = "";
    private string accessToken = "";
    private bool showDropdown = false;
    private string searchKeyword = "";
    private int cartCount = 0;
    private bool isLoadingNew = true;
    private bool isLoadingCats = true;
    private string newsletterEmail = "";
    private string newsletterMessage = "";
    private bool showToast = false;
    private string toastMessage = "";
    private HashSet<int> wishlist = new();
    private int activeSlide = 0;
    private System.Threading.Timer? carouselTimer;
    private int currentUserId = 0;

    private record BookViewModel(int BookId, string BookTitle, string AuthorName, string CategoryName, decimal Price, string ImageUrl, bool IsBestSeller);
    private record CategoryViewModel(int CategoryId, string Name, string Icon, string BgColor, string Slug, int BookCount, string? Description);

    private List<BookViewModel> newBooks = new();
    private List<BookViewModel> bestSellerBooks = new();
    private List<CategoryViewModel> categories = new();

    protected override void OnInitialized()
    {
        carouselTimer = new System.Threading.Timer(async _ =>
        {
            activeSlide = (activeSlide + 1) % 3;
            await InvokeAsync(StateHasChanged);
        }, null, 5000, 5000);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var token = await JS.InvokeAsync<string?>("localStorage.getItem", "accessToken");
        var fullName = await JS.InvokeAsync<string?>("localStorage.getItem", "userFullName");
        var email = await JS.InvokeAsync<string?>("localStorage.getItem", "userEmail");
        var userIdStr = await JS.InvokeAsync<string?>("localStorage.getItem", "userId");

        if (!string.IsNullOrEmpty(token) && !string.IsNullOrEmpty(fullName))
        {
            if (!IsTokenExpired(token))
            {
                isLoggedIn = true;
                userFullName = fullName;
                userEmail = email ?? "";
                accessToken = token;
                if (int.TryParse(userIdStr, out var uid))
                    currentUserId = uid;
            }
            else
            {
                foreach (var k in new[] { "accessToken", "userFullName", "userEmail", "userId" })
                    await JS.InvokeVoidAsync("localStorage.removeItem", k);
            }
        }

        await Task.WhenAll(LoadCategoriesFromApi(), LoadNewBooks(), LoadBestSellerBooks());

        if (isLoggedIn && currentUserId > 0)
            await LoadWishlist();

        StateHasChanged();
    }

    private async Task LoadWishlist()
    {
        try
        {
            var request = new HttpRequestMessage(HttpMethod.Get, $"api/FavoriteBook/{currentUserId}");
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", accessToken);
            var resp = await Http.SendAsync(request);
            if (resp.IsSuccessStatusCode)
            {
                var result = await resp.Content.ReadFromJsonAsync<FavoriteBookListApiDto>();
                if (result?.Items != null)
                    wishlist = result.Items.Select(i => i.BookId).ToHashSet();
            }
        }
        catch { }
    }

    private static bool IsTokenExpired(string token)
    {
        try
        {
            var parts = token.Split('.');
            if (parts.Length != 3) return true;
            var payload = parts[1];
            payload = payload.PadRight(payload.Length + (4 - payload.Length % 4) % 4, '=');
            var json = System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(payload));
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("exp", out var exp))
                return DateTimeOffset.FromUnixTimeSeconds(exp.GetInt64()) <= DateTimeOffset.UtcNow;
            return true;
        }
        catch { return true; }
    }

    public void Dispose() { carouselTimer?.Dispose(); }

    private void PrevSlide() { activeSlide = (activeSlide + 2) % 3; carouselTimer?.Change(5000, 5000); }
    private void NextSlide() { activeSlide = (activeSlide + 1) % 3; carouselTimer?.Change(5000, 5000); }
    private void GoSlide(int i) { activeSlide = i; carouselTimer?.Change(5000, 5000); }

    private async Task LoadCategoriesFromApi()
    {
        isLoadingCats = true;
        try
        {
            var result = await Http.GetFromJsonAsync<List<ApiCategoryDto>>("api/Category");
            if (result != null)
            {
                var icons = new[] { "📖", "📈", "💻", "🧠", "🌟", "🏛️", "🎨", "🔬", "⚖️", "🍳", "🏃", "🌍" };
                var bgs = new[] { "#FFF0F0", "#F0FFFD", "#F0FAFF", "#F0FFF6", "#FFFDF0", "#FDF0FF", "#FFF8F0", "#F0F8FF", "#FFF0F8", "#F5FFF0", "#FFF5F0", "#F0FFFF" };
                categories = result.Select((c, i) => new CategoryViewModel(c.CategoryId, c.CategoryName, icons[i % icons.Length], bgs[i % bgs.Length], Slugify(c.CategoryName), 0, c.Description)).ToList();
            }
        }
        catch { }
        finally { isLoadingCats = false; }
    }

    private async Task LoadNewBooks()
    {
        isLoadingNew = true;
        try
        {
            var result = await Http.GetFromJsonAsync<List<ApiBookDto>>("api/book");
            if (result != null)
                newBooks = result.OrderByDescending(b => b.BookId).Take(8)
                    .Select(b => new BookViewModel(b.BookId, b.BookTitle ?? "Không rõ", b.AuthorName ?? "Không rõ", b.CategoryName ?? "Khác", b.Price,
                        !string.IsNullOrEmpty(b.ImageUrl) ? b.ImageUrl : "https://images.unsplash.com/photo-1544947950-fa07a98d237f?w=300&h=400&fit=crop", b.IsBestSeller)).ToList();
        }
        catch { }
        finally { isLoadingNew = false; }
    }

    private async Task LoadBestSellerBooks()
    {
        try
        {
            var result = await Http.GetFromJsonAsync<List<ApiBookDto>>("api/book/top-selling?top=8");
            if (result != null && result.Any())
                bestSellerBooks = result.Select(b => new BookViewModel(b.BookId, b.BookTitle ?? "Không rõ", b.AuthorName ?? "Không rõ", b.CategoryName ?? "Khác", b.Price,
                    !string.IsNullOrEmpty(b.ImageUrl) ? b.ImageUrl : "https://images.unsplash.com/photo-1512820790803-83ca734da794?w=300&h=400&fit=crop", true)).ToList();
        }
        catch { }
    }

    private class ApiBookDto { public int BookId { get; set; } public string? BookTitle { get; set; } public string? AuthorName { get; set; } public string? CategoryName { get; set; } public decimal Price { get; set; } public string? ImageUrl { get; set; } public bool IsBestSeller { get; set; } }
    private class ApiCategoryDto { public int CategoryId { get; set; } public string CategoryName { get; set; } = ""; public string? Description { get; set; } }
    private class ApiErrorDto { public string? Message { get; set; } }

    private static string Slugify(string name)
    {
        if (string.IsNullOrEmpty(name)) return "";
        return name.ToLower()
            .Replace("đ", "d").Replace("à", "a").Replace("á", "a").Replace("ả", "a").Replace("ã", "a").Replace("ạ", "a")
            .Replace("ă", "a").Replace("ằ", "a").Replace("ắ", "a").Replace("ẳ", "a").Replace("ẵ", "a").Replace("ặ", "a")
            .Replace("â", "a").Replace("ầ", "a").Replace("ấ", "a").Replace("ẩ", "a").Replace("ẫ", "a").Replace("ậ", "a")
            .Replace("è", "e").Replace("é", "e").Replace("ẻ", "e").Replace("ẽ", "e").Replace("ẹ", "e")
            .Replace("ê", "e").Replace("ề", "e").Replace("ế", "e").Replace("ể", "e").Replace("ễ", "e").Replace("ệ", "e")
            .Replace("ì", "i").Replace("í", "i").Replace("ỉ", "i").Replace("ĩ", "i").Replace("ị", "i")
            .Replace("ò", "o").Replace("ó", "o").Replace("ỏ", "o").Replace("õ", "o").Replace("ọ", "o")
            .Replace("ô", "o").Replace("ồ", "o").Replace("ố", "o").Replace("ổ", "o").Replace("ỗ", "o").Replace("ộ", "o")
            .Replace("ơ", "o").Replace("ờ", "o").Replace("ớ", "o").Replace("ở", "o").Replace("ỡ", "o").Replace("ợ", "o")
            .Replace("ù", "u").Replace("ú", "u").Replace("ủ", "u").Replace("ũ", "u").Replace("ụ", "u")
            .Replace("ư", "u").Replace("ừ", "u").Replace("ứ", "u").Replace("ử", "u").Replace("ữ", "u").Replace("ự", "u")
            .Replace("ỳ", "y").Replace("ý", "y").Replace("ỷ", "y").Replace("ỹ", "y").Replace("ỵ", "y")
            .Replace(" ", "-").Replace("--", "-");
    }

    private async Task AddToCart(int bookId)
    {
        if (!isLoggedIn || string.IsNullOrEmpty(accessToken)) { Navigation.NavigateTo("/login"); return; }
        var book = newBooks.FirstOrDefault(b => b.BookId == bookId) ?? bestSellerBooks.FirstOrDefault(b => b.BookId == bookId);
        try
        {
            var request = new HttpRequestMessage(HttpMethod.Post, "api/cart/add");
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", accessToken);
            request.Content = JsonContent.Create(new { bookId, quantity = 1 });
            var resp = await Http.SendAsync(request);
            if (resp.IsSuccessStatusCode) { cartCount++; await ShowToast($"Đã thêm '{book?.BookTitle}' vào giỏ hàng!"); }
            else
            {
                var raw = await resp.Content.ReadAsStringAsync();
                string errorMsg = $"Lỗi {(int)resp.StatusCode}";
                if (!string.IsNullOrWhiteSpace(raw))
                {
                    try { var err = System.Text.Json.JsonSerializer.Deserialize<ApiErrorDto>(raw, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }); errorMsg = err?.Message ?? errorMsg; }
                    catch { errorMsg = raw[..Math.Min(raw.Length, 80)]; }
                }
                await ShowToast(errorMsg);
            }
        }
        catch (Exception ex) { await ShowToast($"Lỗi kết nối: {ex.Message}"); }
    }

    private void GoToBook(int bookId) { Navigation.NavigateTo("/book/" + bookId); }

    private async Task ToggleWishlist(int bookId)
    {
        if (!isLoggedIn || string.IsNullOrEmpty(accessToken))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        if (wishlist.Contains(bookId))
        {
            // Xóa khỏi yêu thích
            try
            {
                var request = new HttpRequestMessage(HttpMethod.Delete,
                    $"api/FavoriteBook/{currentUserId}/{bookId}");
                request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", accessToken);
                var resp = await Http.SendAsync(request);
                if (resp.IsSuccessStatusCode)
                {
                    wishlist.Remove(bookId);
                    await ShowToast("Đã xóa khỏi danh sách yêu thích.");
                }
                else
                {
                    var err = await ReadErrorAsync(resp);
                    await ShowToast(err);
                }
            }
            catch (Exception ex) { await ShowToast($"Lỗi kết nối: {ex.Message}"); }
        }
        else
        {
            // Thêm vào yêu thích
            try
            {
                var request = new HttpRequestMessage(HttpMethod.Post, "api/FavoriteBook");
                request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", accessToken);
                request.Content = JsonContent.Create(new { userId = currentUserId, bookId });
                var resp = await Http.SendAsync(request);
                if (resp.IsSuccessStatusCode)
                {
                    wishlist.Add(bookId);
                    await ShowToast("Đã thêm vào danh sách yêu thích! ❤️");
                }
                else
                {
                    var err = await ReadErrorAsync(resp);
                    await ShowToast(err);
                }
            }
            catch (Exception ex) { await ShowToast($"Lỗi kết nối: {ex.Message}"); }
        }
    }

    private async Task SubscribeNewsletter()
    {
        if (string.IsNullOrWhiteSpace(newsletterEmail)) return;
        newsletterMessage = "Đăng ký thành công! Cảm ơn bạn.";
        newsletterEmail = "";
        await Task.CompletedTask;
    }

    private async Task ShowToast(string message) { toastMessage = message; showToast = true; StateHasChanged(); await Task.Delay(3000); showToast = false; StateHasChanged(); }
    private void ToggleDropdown() => showDropdown = !showDropdown;

    private async Task Logout()
    {
        foreach (var k in new[] { "accessToken", "refreshToken", "userEmail", "userFullName", "userId" })
            await JS.InvokeVoidAsync("localStorage.removeItem", k);
        isLoggedIn = false; userFullName = ""; userEmail = ""; accessToken = "";
        currentUserId = 0; wishlist.Clear(); showDropdown = false;
        Navigation.NavigateTo("/", forceLoad: true);
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1 ? parts[0][..1].ToUpper() : $"{parts[0][..1]}{parts[^1][..1]}".ToUpper();
    }

    private async Task<string> ReadErrorAsync(HttpResponseMessage resp)
    {
        try
        {
            var raw = await resp.Content.ReadAsStringAsync();
            if (!string.IsNullOrWhiteSpace(raw))
            {
                var err = System.Text.Json.JsonSerializer.Deserialize<ApiErrorDto>(raw,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                return err?.Message ?? $"Lỗi {(int)resp.StatusCode}";
            }
        }
        catch { }
        return $"Lỗi {(int)resp.StatusCode}";
    }

    // Thêm DTO cho wishlist response
    private class FavoriteBookListApiDto
    {
        public int TotalCount { get; set; }
        public List<FavoriteBookItemApiDto>? Items { get; set; }
    }
    private class FavoriteBookItemApiDto
    {
        public int BookId { get; set; }
        public string? BookTitle { get; set; }
        public string? AuthorName { get; set; }
        public string? CategoryName { get; set; }
        public decimal Price { get; set; }
        public string? CoverImageUrl { get; set; }
        public DateTime MarkedDate { get; set; }
    }
}
