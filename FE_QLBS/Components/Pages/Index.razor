<section class="py-20 bg-[#FAF7F2]">
    <div class="max-w-7xl mx-auto px-5">
        <div class="text-center mb-14">
            <div class="inline-flex items-center gap-1.5 text-[#D4860B] text-[.72rem] font-bold tracking-[.14em] uppercase px-3.5 py-1.5 rounded-full mb-3"
                 style="background:rgba(212,134,11,.10);border:1px solid rgba(212,134,11,.2);">
                <span class="w-1.5 h-1.5 rounded-full bg-[#D4860B]" style="animation:pulse-dot 2s ease-in-out infinite;display:inline-block;"></span>
                Cam kết
            </div>
            <h2 class="font-serif font-bold text-[#1A1208] leading-tight" style="font-size:clamp(1.8rem,3vw,2.5rem);">Tại sao chọn BookStore?</h2>
            <div class="flex items-center justify-center gap-3 mt-4 mb-4">
                <div class="w-12 h-[3px] bg-[#D4860B] rounded-full"></div>
                <div class="w-3 h-[3px] rounded-full opacity-50" style="background:#F5A623;"></div>
            </div>
            <p class="text-[#7A6A5A] text-[.9rem] max-w-lg mx-auto">Cam kết mang đến trải nghiệm mua sách tốt nhất — chất lượng, nhanh chóng, tin cậy.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            @foreach (var (ico, title, desc, bg) in new[]{
            ("bi-journals","50.000+ Đầu sách","Kho sách phong phú từ văn học, khoa học đến kỹ năng sống và công nghệ.","#FFF8F0"),
            ("bi-truck","Giao hàng nhanh","Giao hàng toàn quốc trong 24–48h. Miễn phí vận chuyển cho đơn hàng từ 150K.","#F0FFF6"),
            ("bi-shield-check","Cam kết chất lượng","100% sách chính hãng, nguồn gốc rõ ràng. Đổi trả dễ dàng trong 7 ngày.","#F0F8FF"),
            ("bi-headset","Hỗ trợ 24/7","Đội ngũ tư vấn sẵn sàng hỗ trợ bạn bất cứ lúc nào, mọi ngày trong năm.","#FDF0FF"),
            })
            {
                <div class="bg-white rounded-2xl p-7 border border-[#EDE8DF] transition-all duration-300 hover:-translate-y-2 hover:shadow-lg hover:border-[#D4860B]/40 group"
                     style="box-shadow:0 2px 16px rgba(107,76,42,.07);">
                    <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-5 transition-transform duration-300 group-hover:scale-110" style="background:@bg;">
                        <i class="bi @ico text-[#D4860B] text-[1.3rem]"></i>
                    </div>
                    <div class="font-serif font-bold text-[#1A1208] text-[1.05rem] mb-2">@title</div>
                    <p class="text-[#9B8B7A] text-[.84rem] leading-[1.7] m-0">@desc</p>
                </div>
            }
        </div>
        <div class="mt-14 rounded-2xl p-8 grid grid-cols-2 lg:grid-cols-4 gap-6 text-center"
             style="background:linear-gradient(135deg,#6B4C2A,#3D2B1F);">
            @foreach (var (num, label, sub) in new[] { ("50K+", "Đầu sách", "Cập nhật hàng tuần"), ("200K+", "Khách hàng", "Tin tưởng sử dụng"), ("4.9", "Điểm đánh giá", "Trên 5 sao"), ("24h", "Giao hàng", "Toàn quốc") })
            {
                <div>
                    <div class="font-serif font-bold text-[2.2rem] leading-none mb-1"
                         style="background:linear-gradient(135deg,#F5A623,#D4860B);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
                        @num
                    </div>
                    <div class="text-white font-semibold text-[.9rem] mb-0.5">@label</div>
                    <div class="text-white/45 text-[.72rem]">@sub</div>
                </div>
            }
        </div>
    </div>
</section>

<!-- NEWSLETTER -->
<section class="py-20 bg-[#FFFDF8]">
    <div class="max-w-2xl mx-auto px-5 text-center">
        <div class="inline-flex items-center gap-1.5 text-[#D4860B] text-[.72rem] font-bold tracking-[.14em] uppercase px-3.5 py-1.5 rounded-full mb-5"
             style="background:rgba(212,134,11,.10);border:1px solid rgba(212,134,11,.2);">
            <span class="w-1.5 h-1.5 rounded-full bg-[#D4860B]" style="animation:pulse-dot 2s ease-in-out infinite;display:inline-block;"></span>
            Bản tin sách
        </div>
        <h2 class="font-serif font-bold text-[#1A1208] leading-tight mb-4" style="font-size:clamp(1.8rem,3vw,2.4rem);">Nhận thông báo sách mới mỗi tuần</h2>
        <p class="text-[#7A6A5A] text-[.95rem] leading-relaxed mb-8">Đăng ký để nhận thông báo về các đầu sách mới nhất, ưu đãi độc quyền và gợi ý đọc sách theo sở thích của bạn.</p>
        <div class="flex gap-3 max-w-md mx-auto flex-wrap sm:flex-nowrap">
            <input type="email" @bind="newsletterEmail" placeholder="Địa chỉ email của bạn..."
                   class="flex-1 px-5 py-3.5 rounded-xl border border-[#EDE8DF] bg-white outline-none text-[.9rem] text-[#1A1208] transition-all"
                   style="box-shadow:0 2px 12px rgba(107,76,42,.06);"
                   onfocus="this.style.borderColor='#D4860B';this.style.boxShadow='0 0 0 3px rgba(212,134,11,.12)'"
                   onblur="this.style.borderColor='';this.style.boxShadow='0 2px 12px rgba(107,76,42,.06)'" />
            <button @onclick="SubscribeNewsletter"
                    class="px-7 py-3.5 text-white font-semibold rounded-xl border-0 cursor-pointer text-[.9rem] transition-all hover:-translate-y-0.5 whitespace-nowrap flex-shrink-0"
                    style="background:linear-gradient(135deg,#6B4C2A,#8B6040);box-shadow:0 4px 16px rgba(107,76,42,.3);font-family:'Plus Jakarta Sans',sans-serif;">
                <i class="bi bi-send-fill mr-1.5 text-sm"></i> Đăng ký
            </button>
        </div>
        @if (!string.IsNullOrEmpty(newsletterMessage))
        {
            <div class="mt-4 inline-flex items-center gap-2 text-[.84rem] font-medium text-green-700 bg-green-50 border border-green-200 px-4 py-2 rounded-full">
                <i class="bi bi-check-circle-fill text-green-600"></i> @newsletterMessage
            </div>
        }
        <p class="mt-4 text-[#C4B8A8] text-[.75rem]">Không có spam. Có thể hủy đăng ký bất cứ lúc nào.</p>
    </div>
</section>

