@page "/"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Net.Http.Headers
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Trang Chủ - BookStore</PageTitle>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;0,800;1,600&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<script src="https://cdn.tailwindcss.com"></script>

<script>
    tailwind.config = {
        theme: {
            extend: {
                colors: {
                    cream:    '#FAF7F2',
                    'warm-white': '#FFFDF8',
                    ink:      '#1A1208',
                    brown:    '#6B4C2A',
                    amber:    '#D4860B',
                    'amber-lt':'#F5A623',
                    sand:     '#EDE8DF',
                    muted:    '#9B8B7A',
                    pale:     '#C4B8A8',
                    sage:     '#7A9E7E',
                    rust:     '#C0392B',
                },
                fontFamily: {
                    serif: ['"Playfair Display"', 'Georgia', 'serif'],
                    sans:  ['"Plus Jakarta Sans"', 'sans-serif'],
                },
            }
        }
    }
</script>

<style>
    *, *::before, *::after {
        box-sizing: border-box;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background: #FAF7F2;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
    }

    ::-webkit-scrollbar {
        width: 5px;
    }

    ::-webkit-scrollbar-track {
        background: #FAF7F2;
    }

    ::-webkit-scrollbar-thumb {
        background: #EDE8DF;
        border-radius: 10px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: #D4860B;
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(20px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0)
        }

        50% {
            transform: translateY(-12px)
        }
    }

    @@keyframes floatR1 {
        0%, 100% {
            transform: translateY(0) rotate(-9deg)
        }

        50% {
            transform: translateY(-12px) rotate(-9deg)
        }
    }

    @@keyframes floatR2 {
        0%, 100% {
            transform: translateY(0) rotate(7deg)
        }

        50% {
            transform: translateY(-12px) rotate(7deg)
        }
    }

    @@keyframes shimmer {
        to {
            background-position: -200% 0
        }
    }

    @@keyframes toastUp {
        from {
            opacity: 0;
            transform: translateX(-50%) translateY(16px)
        }

        to {
            opacity: 1;
            transform: translateX(-50%) translateY(0)
        }
    }

    @@keyframes pulse-dot {
        0%, 100% {
            transform: scale(1);
            opacity: 1
        }

        50% {
            transform: scale(1.5);
            opacity: .6
        }
    }

    @@keyframes dropIn {
        from {
            opacity: 0;
            transform: translateY(-8px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    .anim-fade-up {
        animation: fadeUp .5s ease both;
    }

    .float-main {
        animation: float 6s ease-in-out infinite;
    }

    .float-r1 {
        animation: floatR1 7s ease-in-out .5s infinite;
    }

    .float-r2 {
        animation: floatR2 8s ease-in-out 1s infinite;
    }

    .toast-anim {
        animation: toastUp .35s ease both;
    }

    .drop-in {
        animation: dropIn .18s ease both;
    }

    .skel {
        background: linear-gradient(90deg,#EDE8DF 25%,#F5F1EC 50%,#EDE8DF 75%);
        background-size: 200% 100%;
        animation: shimmer 1.4s infinite;
        border-radius: 8px;
    }

    .hero-carousel-item {
        display: none;
    }

        .hero-carousel-item.active {
            display: flex;
        }

    .nav-u {
        position: relative;
    }

        .nav-u::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            right: 0;
            height: 2px;
            background: #D4860B;
            border-radius: 2px;
            transform: scaleX(0);
            transition: transform .2s ease;
        }

        .nav-u:hover::after, .nav-u.active::after {
            transform: scaleX(1);
        }

    /* Book card — dùng div thay a để stopPropagation hoạt động đúng */
    .book-card-div {
        display: block;
        text-decoration: none;
        color: inherit;
        position: relative;
        border-radius: 16px;
        overflow: hidden;
        transition: transform .3s, box-shadow .3s;
        background: rgba(255,255,255,.6);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(237,232,223,.8);
        box-shadow: 0 4px 24px rgba(107,76,42,.07);
        cursor: pointer;
    }

        .book-card-div:hover {
            transform: translateY(-8px);
            box-shadow: 0 16px 48px rgba(107,76,42,.16) !important;
        }

    .footer-lnk {
        display: flex;
        align-items: center;
        gap: 6px;
        color: rgba(255,255,255,.4);
        text-decoration: none;
        font-size: .84rem;
        margin-bottom: 9px;
        transition: color .15s;
    }

        .footer-lnk:hover {
            color: #F5A623;
        }

        .footer-lnk i {
            font-size: .65rem;
            color: rgba(212,134,11,.5);
        }

        .footer-lnk:hover i {
            color: #D4860B;
        }
</style>

<!-- TOP BAR -->
<div style="background:linear-gradient(90deg,#5A3D20,#6B4C2A,#7A5A34);" class="text-white/75 text-[0.78rem] py-1.5">
    <div class="max-w-7xl mx-auto px-5 flex justify-between items-center flex-wrap gap-2">
        <div class="flex items-center gap-4">
            <span class="flex items-center gap-1.5"><i class="bi bi-telephone-fill text-[#F5A623] text-[0.7rem]"></i>0901 234 567</span>
            <span class="hidden sm:inline opacity-50">|</span>
            <span class="hidden sm:flex items-center gap-1.5"><i class="bi bi-envelope-fill text-[#F5A623] text-[0.7rem]"></i>bookstore@gmail.com</span>
        </div>
        <div class="flex items-center gap-5">
            <a href="#" class="text-white/70 no-underline hover:text-[#F5A623] transition-colors flex items-center gap-1"><i class="bi bi-box-seam text-[0.7rem]"></i> Theo dõi đơn hàng</a>
            <a href="#" class="hidden sm:flex items-center gap-1 text-white/70 no-underline hover:text-[#F5A623] transition-colors"><i class="bi bi-book text-[0.7rem]"></i> Cẩm nang đọc sách</a>
        </div>
    </div>
</div>

<!-- NAVBAR -->
<nav class="bg-[#FFFDF8]/95 border-b border-[#EDE8DF] py-3 sticky top-0 z-50"
     style="backdrop-filter:blur(20px);box-shadow:0 1px 0 rgba(107,76,42,.06),0 4px 24px rgba(107,76,42,.06);">
    <div class="max-w-7xl mx-auto px-5 flex items-center gap-4">
        <a href="/" class="font-serif font-bold text-[#6B4C2A] no-underline flex items-center gap-2.5 mr-auto lg:mr-0 flex-shrink-0"
           style="font-family:'Playfair Display',serif;font-size:1.55rem;letter-spacing:-.5px;">
            <div class="w-9 h-9 rounded-[10px] flex items-center justify-center text-white text-[1rem] flex-shrink-0"
                 style="background:linear-gradient(135deg,#D4860B,#F5A623);box-shadow:0 4px 12px rgba(212,134,11,.35);">
                <i class="bi bi-book-half"></i>
            </div>
            Book<span style="color:#D4860B;">Store</span>
        </a>
        <div class="hidden lg:flex items-center gap-0.5 mx-auto">
            <a href="/" class="nav-u active text-[#D4860B] font-medium text-[.88rem] px-3 py-2 rounded-lg no-underline whitespace-nowrap">Trang Chủ</a>
            <a href="#categories" class="nav-u text-[#1A1208]/65 hover:text-[#1A1208] font-medium text-[.88rem] px-3 py-2 rounded-lg no-underline transition-colors whitespace-nowrap">Danh Mục</a>
            <a href="#new-books" class="nav-u text-[#1A1208]/65 hover:text-[#1A1208] font-medium text-[.88rem] px-3 py-2 rounded-lg no-underline transition-colors whitespace-nowrap">Sách Mới</a>
            <a href="#best-sellers" class="nav-u text-[#1A1208]/65 hover:text-[#1A1208] font-medium text-[.88rem] px-3 py-2 rounded-lg no-underline transition-colors whitespace-nowrap">Bán Chạy</a>
            <a href="#contact" class="nav-u text-[#1A1208]/65 hover:text-[#1A1208] font-medium text-[.88rem] px-3 py-2 rounded-lg no-underline transition-colors whitespace-nowrap">Liên Hệ</a>
        </div>
        <div class="relative hidden md:block flex-shrink-0">
            <i class="bi bi-search absolute left-3.5 top-1/2 -translate-y-1/2 text-[#C4B8A8] text-sm pointer-events-none"></i>
            <input type="text" @bind="searchKeyword" @bind:event="oninput"
                   placeholder="Tìm sách, tác giả..."
                   class="border border-[#EDE8DF] rounded-full py-2 pr-4 pl-9 text-[.84rem] bg-[#FAF7F2] outline-none w-[220px] text-[#1A1208]"
                   style="transition:width .3s,border-color .2s,box-shadow .2s;"
                   onfocus="this.style.width='270px';this.style.borderColor='#D4860B';this.style.boxShadow='0 0 0 3px rgba(212,134,11,.12)';this.style.background='#fff'"
                   onblur="this.style.width='220px';this.style.borderColor='';this.style.boxShadow='';this.style.background=''" />
        </div>
        <div class="flex items-center gap-2 flex-shrink-0">
            <a href="/wishlist" class="w-9 h-9 rounded-[10px] bg-[#FAF7F2] border border-[#EDE8DF] flex items-center justify-center text-[#6B4C2A] text-sm no-underline hover:border-[#D4860B] hover:text-[#D4860B] hover:bg-[#D4860B]/10 transition-all">
                <i class="bi bi-heart"></i>
            </a>
            <a href="/cart" class="relative w-9 h-9 rounded-[10px] bg-[#FAF7F2] border border-[#EDE8DF] flex items-center justify-center text-[#6B4C2A] text-sm no-underline hover:border-[#D4860B] hover:text-[#D4860B] hover:bg-[#D4860B]/10 transition-all">
                <i class="bi bi-bag"></i>
                @if (cartCount > 0)
                {
                    <span class="absolute -top-1.5 -right-1.5 bg-[#C0392B] text-white text-[.55rem] w-4 h-4 rounded-full flex items-center justify-center font-bold border border-white">@cartCount</span>
                }
            </a>
            @if (!isLoggedIn)
            {
                <a href="/login" class="flex items-center gap-2 bg-[#1A1208] text-white rounded-full px-5 py-2 text-[.84rem] font-semibold no-underline hover:bg-[#D4860B] transition-colors ml-1"
                   style="box-shadow:0 2px 10px rgba(26,18,8,.2);">
                    <i class="bi bi-person text-sm"></i><span class="hidden sm:inline">Đăng nhập</span>
                </a>
            }
            else
            {
                <div class="relative">
                    <button class="w-9 h-9 rounded-full flex items-center justify-center text-white text-[.78rem] font-bold cursor-pointer border-0 transition-all"
                            style="background:linear-gradient(135deg,#D4860B,#F5A623);box-shadow:0 2px 10px rgba(212,134,11,.3);"
                            @onclick="ToggleDropdown">
                        @GetInitials(userFullName)
                    </button>
                    @if (showDropdown)
                    {
                        <div class="drop-in absolute top-[calc(100%+10px)] right-0 bg-[#FFFDF8] border border-[#EDE8DF] rounded-2xl min-w-[210px] z-[9999] overflow-hidden"
                             style="box-shadow:0 8px 32px rgba(107,76,42,.14);">
                            <div class="px-4 py-3.5 border-b border-[#EDE8DF]" style="background:linear-gradient(135deg,rgba(212,134,11,.06),transparent);">
                                <div class="text-[.88rem] font-bold text-[#1A1208] truncate max-w-[170px]">@userFullName</div>
                                <div class="text-[.72rem] text-[#9B8B7A] truncate max-w-[170px]">@userEmail</div>
                            </div>
                            <a href="/profile" class="flex items-center gap-2.5 px-4 py-2.5 text-[.84rem] font-medium text-[#9B8B7A] no-underline hover:bg-[#D4860B]/10 hover:text-[#6B4C2A] transition-colors">
                                <i class="bi bi-person-circle text-[#D4860B] text-[.88rem] w-4 text-center"></i> Hồ sơ của tôi
                            </a>
                            <a href="/orders" class="flex items-center gap-2.5 px-4 py-2.5 text-[.84rem] font-medium text-[#9B8B7A] no-underline hover:bg-[#D4860B]/10 hover:text-[#6B4C2A] transition-colors">
                                <i class="bi bi-bag-check text-[#D4860B] text-[.88rem] w-4 text-center"></i> Đơn hàng
                            </a>
                            <a href="/wishlist" class="flex items-center gap-2.5 px-4 py-2.5 text-[.84rem] font-medium text-[#9B8B7A] no-underline hover:bg-[#D4860B]/10 hover:text-[#6B4C2A] transition-colors">
                                <i class="bi bi-heart text-[#D4860B] text-[.88rem] w-4 text-center"></i> Yêu thích
                            </a>
                            <div class="h-px bg-[#EDE8DF] my-1"></div>
                            <button class="flex items-center gap-2.5 px-4 py-2.5 w-full text-left text-[.84rem] font-medium text-[#9B8B7A] bg-transparent border-0 cursor-pointer hover:bg-red-50 hover:text-[#C0392B] transition-colors"
                                    @onclick="Logout">
                                <i class="bi bi-box-arrow-right text-[#C0392B] text-[.88rem] w-4 text-center"></i> Đăng xuất
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</nav>

<!-- HERO CAROUSEL -->
<section style="background:#1A1208;">
    <div class="relative overflow-hidden">
        @for (int si = 0; si < 3; si++)
        {
            var idx = si;
            var slideBg = idx == 0 ? "linear-gradient(145deg,#1A1208 0%,#3D2B1F 45%,#6B4C2A 100%)"
            : idx == 1 ? "linear-gradient(145deg,#0B1622 0%,#163350 45%,#2563A8 100%)"
            : "linear-gradient(145deg,#180808 0%,#3D1010 45%,#7B2020 100%)";
            <div class="hero-carousel-item @(idx==activeSlide?"active":"") min-h-[560px] lg:min-h-[620px] items-center relative overflow-hidden"
                 style="background:@slideBg;">
                <div class="absolute rounded-full pointer-events-none" style="width:500px;height:500px;top:-100px;right:-50px;background:rgba(212,134,11,.10);filter:blur(80px);z-index:1;"></div>
                <div class="absolute rounded-full pointer-events-none" style="width:300px;height:300px;bottom:-80px;left:10%;background:rgba(212,134,11,.06);filter:blur(60px);z-index:1;"></div>
                <div class="max-w-7xl mx-auto px-5 w-full py-16 relative" style="z-index:2;">
                    <div class="flex items-center gap-8">
                        <div class="w-full lg:w-[55%]">
                            @if (idx == 0)
                            {
                                <div class="inline-flex items-center gap-1.5 text-[#F5A623] text-[.72rem] font-bold tracking-[.12em] uppercase px-4 py-1.5 rounded-full mb-5"
                                     style="background:rgba(212,134,11,.18);border:1px solid rgba(212,134,11,.35);">
                                    <span class="w-1.5 h-1.5 rounded-full bg-[#F5A623]" style="animation:pulse-dot 2s ease-in-out infinite;display:inline-block;"></span>
                                    Khuyến mãi đặc biệt
                                </div>
                                <h1 class="font-serif font-bold text-white leading-[1.1] mb-5" style="font-size:clamp(2.4rem,5.5vw,4rem);">
                                    Khám phá thế giới<br />qua từng <em class="not-italic" style="background:linear-gradient(135deg,#F5A623,#D4860B);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">trang sách</em>
                                </h1>
                                <p class="text-white/65 leading-relaxed mb-8 max-w-[480px] text-[1.05rem]">
                                    Hơn 50.000 đầu sách từ khắp nơi trên thế giới.<br />
                                    <span class="text-white/85 font-medium">Giảm đến 40%</span> cho đơn hàng đầu tiên.
                                </p>
                                <div class="flex flex-wrap gap-3 mb-10">
                                    <a href="#new-books" class="flex items-center gap-2 text-white font-bold px-7 py-3 rounded-full no-underline text-[.92rem] transition-all hover:-translate-y-0.5"
                                       style="background:linear-gradient(135deg,#D4860B,#F5A623);box-shadow:0 8px 28px rgba(212,134,11,.45);">
                                        <i class="bi bi-bag-plus"></i>Mua ngay
                                    </a>
                                    <a href="#categories" class="text-white/85 px-7 py-3 rounded-full font-medium text-[.92rem] no-underline hover:text-white transition-all"
                                       style="border:1.5px solid rgba(255,255,255,.25);background:rgba(255,255,255,.07);backdrop-filter:blur(10px);">
                                        Khám phá
                                    </a>
                                </div>
                                <div class="flex gap-4 flex-wrap">
                                    @foreach (var (num, lbl) in new[] { ("50K+", "Đầu sách"), ("200K+", "Khách hàng"), ("4.9★", "Đánh giá") })
                                    {
                                        <div class="text-center px-5 py-3 rounded-xl min-w-[80px]"
                                             style="background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);backdrop-filter:blur(10px);">
                                            <div class="font-serif text-[1.6rem] font-bold leading-none mb-1"
                                                 style="background:linear-gradient(135deg,#F5A623,#D4860B);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
                                                @num
                                            </div>
                                            <div class="text-white/45 text-[.68rem] tracking-wide uppercase">@lbl</div>
                                        </div>
                                    }
                                </div>
                            }
                            else if (idx == 1)
                            {
                                <div class="inline-flex items-center gap-1.5 text-[#F5A623] text-[.72rem] font-bold tracking-[.12em] uppercase px-4 py-1.5 rounded-full mb-5"
                                     style="background:rgba(212,134,11,.18);border:1px solid rgba(212,134,11,.35);">
                                    Sách Công Nghệ
                                </div>
                                <h1 class="font-serif font-bold text-white leading-[1.1] mb-5" style="font-size:clamp(2.4rem,5.5vw,4rem);">
                                    Nâng tầm kỹ năng<br />với <em class="not-italic" style="background:linear-gradient(135deg,#F5A623,#D4860B);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">sách lập trình</em>
                                </h1>
                                <p class="text-white/65 leading-relaxed mb-8 max-w-[480px] text-[1.05rem]">Bộ sưu tập sách công nghệ chọn lọc. <span class="text-white/85 font-medium">Giảm 30%</span> toàn danh mục tuần này.</p>
                                <a href="#" class="inline-flex items-center gap-2 text-white font-bold px-7 py-3 rounded-full no-underline text-[.92rem] hover:-translate-y-0.5 transition-all"
                                   style="background:linear-gradient(135deg,#D4860B,#F5A623);box-shadow:0 8px 28px rgba(212,134,11,.45);">
                                    <i class="bi bi-lightning-fill"></i>Xem ngay
                                </a>
                            }
                            else
                            {
                                <div class="inline-flex items-center gap-1.5 text-[#F5A623] text-[.72rem] font-bold tracking-[.12em] uppercase px-4 py-1.5 rounded-full mb-5"
                                     style="background:rgba(212,134,11,.18);border:1px solid rgba(212,134,11,.35);">
                                    Sách bán chạy
                                </div>
                                <h1 class="font-serif font-bold text-white leading-[1.1] mb-5" style="font-size:clamp(2.4rem,5.5vw,4rem);">
                                    Bestseller tháng<br /><em class="not-italic" style="background:linear-gradient(135deg,#F5A623,#D4860B);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">vừa cập nhật</em>
                                </h1>
                                <p class="text-white/65 leading-relaxed mb-8 max-w-[480px] text-[1.05rem]">Những cuốn sách hay nhất được độc giả yêu thích. <span class="text-white/85 font-medium">Miễn phí vận chuyển</span> từ 150K.</p>
                                <a href="#best-sellers" class="inline-flex items-center gap-2 text-white font-bold px-7 py-3 rounded-full no-underline text-[.92rem] hover:-translate-y-0.5 transition-all"
                                   style="background:linear-gradient(135deg,#D4860B,#F5A623);box-shadow:0 8px 28px rgba(212,134,11,.45);">
                                    <i class="bi bi-trophy-fill"></i>Xem bestseller
                                </a>
                            }
                        </div>
                        @if (idx == 0)
                        {
                            <div class="hidden lg:flex flex-1 justify-center items-center">
                                <div class="relative" style="width:300px;height:360px;">
                                    <img class="float-r1 absolute rounded-2xl object-cover opacity-55" src="https://images.unsplash.com/photo-1544947950-fa07a98d237f?w=300&h=400&fit=crop" style="width:165px;height:248px;top:22px;left:22px;z-index:1;box-shadow:0 24px 64px rgba(0,0,0,.55);" alt="" />
                                    <img class="float-r2 absolute rounded-2xl object-cover opacity-65" src="https://images.unsplash.com/photo-1512820790803-83ca734da794?w=300&h=400&fit=crop" style="width:160px;height:244px;top:28px;left:96px;z-index:2;box-shadow:0 24px 64px rgba(0,0,0,.55);" alt="" />
                                    <img class="float-main absolute rounded-2xl object-cover" src="https://images.unsplash.com/photo-1543002588-bfa74002ed7e?w=300&h=400&fit=crop" style="width:190px;height:270px;top:45px;left:55px;z-index:3;box-shadow:0 24px 64px rgba(0,0,0,.55);" alt="" />
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
        <button @onclick="PrevSlide" class="absolute left-5 top-1/2 -translate-y-1/2 w-11 h-11 rounded-full flex items-center justify-center text-white border-0 cursor-pointer z-20 transition-all hover:bg-white/25"
                style="background:rgba(255,255,255,.10);border:1.5px solid rgba(255,255,255,.2) !important;backdrop-filter:blur(10px);">
            <i class="bi bi-chevron-left"></i>
        </button>
        <button @onclick="NextSlide" class="absolute right-5 top-1/2 -translate-y-1/2 w-11 h-11 rounded-full flex items-center justify-center text-white border-0 cursor-pointer z-20 transition-all hover:bg-white/25"
                style="background:rgba(255,255,255,.10);border:1.5px solid rgba(255,255,255,.2) !important;backdrop-filter:blur(10px);">
            <i class="bi bi-chevron-right"></i>
        </button>
        <div class="absolute bottom-5 left-1/2 -translate-x-1/2 flex items-center gap-2 z-20">
            @for (int d = 0; d < 3; d++)
            {
                var di = d;
                <button @onclick="@(()=>GoSlide(di))"
                        class="@(di==activeSlide?"w-7 h-2 bg-[#D4860B]":"w-2 h-2 bg-white/35 hover:bg-white/60") rounded-full border-0 cursor-pointer transition-all duration-300"></button>
            }
        </div>
    </div>
</section>

