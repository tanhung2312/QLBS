@page "/orders"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Đơn Hàng Của Tôi - BookStore</PageTitle>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap');

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(20px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    @@keyframes shimmer {
        0% {
            background-position: -200% 0
        }

        100% {
            background-position: 200% 0
        }
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg)
        }
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateX(30px)
        }

        to {
            opacity: 1;
            transform: translateX(0)
        }
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1)
        }

        50% {
            transform: scale(1.05)
        }
    }

    @@keyframes popIn {
        0% {
            opacity: 0;
            transform: scale(.85) translateY(6px)
        }

        70% {
            transform: scale(1.04) translateY(-2px)
        }

        100% {
            opacity: 1;
            transform: scale(1) translateY(0)
        }
    }

    .font-cormorant {
        font-family: 'Cormorant Garamond', serif;
    }

    .font-jakarta {
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .fade-up-1 {
        animation: fadeUp .5s cubic-bezier(.4,0,.2,1) .05s both;
    }

    .fade-up-2 {
        animation: fadeUp .5s cubic-bezier(.4,0,.2,1) .12s both;
    }

    .fade-up-3 {
        animation: fadeUp .5s cubic-bezier(.4,0,.2,1) .18s both;
    }

    .skel {
        background: linear-gradient(90deg,#EDE8DF 25%,#FFFDF8 50%,#EDE8DF 75%);
        background-size: 200% 100%;
        animation: shimmer 1.4s infinite;
        border-radius: 6px;
    }

    .status-delivered {
        background: rgba(46,125,82,.1);
        color: #2E7D52;
    }

    .status-shipping {
        background: rgba(212,134,11,.1);
        color: #D4860B;
    }

    .status-pending {
        background: rgba(37,99,168,.1);
        color: #2563A8;
    }

    .status-cancelled {
        background: rgba(192,57,43,.1);
        color: #C0392B;
    }

    .order-row:hover {
        background: rgba(250,247,242,.9) !important;
    }

    .order-row-new {
        background: rgba(212,134,11,.05) !important;
    }

    .order-row-completed {
        background: rgba(46,125,82,.02) !important;
    }

    .tab-pill {
        position: relative;
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 10px 18px;
        font-size: .84rem;
        font-weight: 600;
        white-space: nowrap;
        cursor: pointer;
        border-bottom: 2.5px solid transparent;
        transition: all .2s;
        color: #9B8B7A;
        text-decoration: none;
    }

        .tab-pill.active {
            color: #D4860B;
            border-bottom-color: #D4860B;
        }

        .tab-pill:hover:not(.active) {
            color: #6B4C2A;
        }

    .pf-toast {
        animation: slideIn .25s ease both;
    }

    ::-webkit-scrollbar {
        width: 4px;
    }

    ::-webkit-scrollbar-thumb {
        background: #DDD5C8;
        border-radius: 10px;
    }

    .stat-card {
        background: #FFFDF8;
        border: 1px solid #EDE8DF;
        border-radius: 16px;
        padding: 18px 22px;
        display: flex;
        align-items: center;
        gap: 14px;
        transition: box-shadow .2s, transform .2s;
        cursor: pointer;
    }

        .stat-card:hover {
            box-shadow: 0 6px 24px rgba(107,76,42,.12);
            transform: translateY(-2px);
        }

        .stat-card.active-stat {
            border-color: #D4860B;
            background: rgba(212,134,11,.04);
            box-shadow: 0 4px 20px rgba(212,134,11,.15);
        }

    .detail-btn {
        width: 28px;
        height: 28px;
        border-radius: 8px;
        background: #FAF7F2;
        border: 1px solid #EDE8DF;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #9B8B7A;
        font-size: .75rem;
        text-decoration: none;
        transition: all .2s;
    }

        .detail-btn:hover {
            border-color: #D4860B;
            color: #D4860B;
            background: rgba(212,134,11,.08);
        }

    /* ── Review CTA button ── */
    .review-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 11px;
        border-radius: 8px;
        font-size: .71rem;
        font-weight: 700;
        border: 1.5px solid rgba(212,134,11,.35);
        background: rgba(212,134,11,.07);
        color: #D4860B;
        text-decoration: none;
        cursor: pointer;
        transition: all .18s;
        white-space: nowrap;
        font-family: 'Plus Jakarta Sans', sans-serif;
        animation: popIn .4s cubic-bezier(.22,1,.36,1) both;
    }

        .review-btn:hover {
            background: linear-gradient(135deg,#D4860B,#F5A623);
            color: #fff;
            border-color: #D4860B;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(212,134,11,.32);
        }

        .review-btn i {
            font-size: .68rem;
        }

    /* ── Completed row highlight ── */
    .completed-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #2E7D52;
        display: inline-block;
        margin-right: 4px;
        flex-shrink: 0;
        box-shadow: 0 0 0 3px rgba(46,125,82,.15);
    }

    /* ── Pagination ── */
    .pg-btn {
        width: 36px;
        height: 36px;
        border-radius: 9px;
        font-size: .82rem;
        font-weight: 600;
        border: 1.5px solid #EDE8DF;
        background: #FFFDF8;
        color: #9B8B7A;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all .15s;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

        .pg-btn:hover {
            border-color: #D4860B;
            color: #D4860B;
            background: rgba(212,134,11,.07);
        }

        .pg-btn.pg-on {
            border-color: #D4860B;
            background: #D4860B;
            color: #fff;
        }

        .pg-btn.pg-off {
            opacity: .4;
            cursor: not-allowed;
            pointer-events: none;
        }
</style>

<div class="font-jakarta bg-[#FAF7F2] min-h-screen text-[#1A1208]">

    <!-- TOP BAR -->
    <div style="background:linear-gradient(90deg,#5A3D20,#6B4C2A,#7A5A34);" class="text-white/85 text-[0.78rem] py-[7px]">
        <div class="max-w-[1100px] mx-auto px-6 flex justify-between items-center flex-wrap gap-2">
            <div class="flex items-center gap-4">
                <span class="flex items-center gap-1.5"><i class="bi bi-telephone-fill text-[#F5A623] text-[0.7rem]"></i>0901 234 567</span>
                <span class="opacity-40 hidden sm:inline">|</span>
                <span class="hidden sm:flex items-center gap-1.5"><i class="bi bi-envelope-fill text-[#F5A623] text-[0.7rem]"></i>bookstore@@gmail.com</span>
            </div>
            <a href="#" class="text-[rgba(255,221,167,.75)] no-underline hover:text-[rgba(255,221,167,1)] transition-colors flex items-center gap-1">
                <i class="bi bi-box-seam text-[0.7rem]"></i> Theo dõi đơn hàng
            </a>
        </div>
    </div>

    <!-- NAVBAR -->
    <nav class="bg-[#FFFDF8]/95 border-b border-[#EDE8DF] py-3 sticky top-0 z-50"
         style="backdrop-filter:blur(20px);box-shadow:0 1px 0 rgba(107,76,42,.06),0 4px 24px rgba(107,76,42,.06);">
        <div class="max-w-[1100px] mx-auto px-6 flex items-center gap-4">
            <a href="/" class="font-cormorant text-[1.75rem] font-bold text-[#6B4C2A] no-underline flex items-center gap-2.5 mr-auto" style="letter-spacing:-.5px;">
                <div class="w-9 h-9 rounded-[10px] flex items-center justify-center text-white text-base flex-shrink-0"
                     style="background:linear-gradient(135deg,#D4860B,#F5A623);box-shadow:0 4px 12px rgba(212,134,11,.35);">
                    <i class="bi bi-book-half"></i>
                </div>
                Book<span class="text-[#D4860B]">Store</span>
            </a>
            <div class="flex items-center gap-2 flex-shrink-0">
                <a href="/cart" class="relative w-9 h-9 rounded-full bg-[#FAF7F2] border border-[#EDE8DF] flex items-center justify-center text-[#6B4C2A] text-sm no-underline hover:bg-[#D4860B] hover:text-white transition-colors">
                    <i class="bi bi-bag"></i>
                </a>
                @if (!isLoggedIn)
                {
                    <a href="/login" class="flex items-center gap-2 bg-[#1A1208] text-white rounded-full px-5 py-[0.45rem] text-[0.84rem] font-semibold no-underline hover:bg-[#D4860B] transition-colors ml-1">
                        <i class="bi bi-person text-sm"></i><span class="hidden sm:inline">Đăng nhập</span>
                    </a>
                }
                else
                {
                    <div class="relative ml-1">
                        <button @onclick="ToggleDropdown" title="@userFullName"
                                class="w-9 h-9 rounded-full flex items-center justify-center text-white text-[.78rem] font-bold cursor-pointer border-2 transition-all hover:scale-105"
                                style="background:linear-gradient(135deg,#D4860B,#F5A623);border-color:rgba(212,134,11,.35);box-shadow:0 2px 10px rgba(212,134,11,.3);">
                            @GetInitials(userFullName)
                        </button>
                        @if (showDropdown)
                        {
                            <div class="absolute top-[calc(100%+10px)] right-0 bg-[#FFFDF8] border border-[#EDE8DF] rounded-[14px] min-w-[210px] z-[9999] overflow-hidden"
                                 style="box-shadow:0 8px 32px rgba(107,76,42,.14);">
                                <div class="px-4 py-3.5 border-b border-[#EDE8DF]" style="background:linear-gradient(135deg,rgba(212,134,11,.06),transparent);">
                                    <div class="text-[.88rem] font-bold text-[#1A1208] truncate">@userFullName</div>
                                    <div class="text-[.72rem] text-[#9B8B7A] truncate">@userEmail</div>
                                </div>
                                <a href="/profile" class="flex items-center gap-2.5 px-4 py-2.5 text-[.84rem] font-medium text-[#7A6A5A] no-underline hover:bg-[rgba(212,134,11,.08)] hover:text-[#6B4C2A] transition-colors">
                                    <i class="bi bi-person-circle text-[#D4860B] w-4 text-center"></i> Hồ sơ
                                </a>
                                <a href="/orders" class="flex items-center gap-2.5 px-4 py-2.5 text-[.84rem] font-medium text-[#D4860B] bg-[rgba(212,134,11,.06)] no-underline">
                                    <i class="bi bi-bag-check-fill text-[#D4860B] w-4 text-center"></i> Đơn hàng
                                </a>
                                <div class="h-px bg-[#EDE8DF] my-1"></div>
                                <button @onclick="Logout" class="w-full flex items-center gap-2.5 px-4 py-2.5 text-[.84rem] font-medium text-[#7A6A5A] hover:bg-[rgba(192,57,43,.07)] hover:text-[#C0392B] transition-colors border-none bg-transparent cursor-pointer" style="font-family:inherit;text-align:left;">
                                    <i class="bi bi-box-arrow-right text-[#C0392B] w-4 text-center"></i> Đăng xuất
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </nav>

    <!-- HEADER BANNER -->
    <div class="relative overflow-hidden pt-12 pb-8"
         style="background:linear-gradient(140deg,#1A1208 0%,#3D2B1F 45%,#6B4C2A 100%);">
        <div class="absolute pointer-events-none rounded-full"
             style="width:500px;height:400px;top:-100px;right:5%;background:rgba(212,134,11,.1);filter:blur(80px);"></div>
        <div class="relative z-10 max-w-[1100px] mx-auto px-6 fade-up-1">
            <div class="flex items-center gap-2 text-white/45 text-[.76rem] mb-5">
                <a href="/" class="hover:text-white/70 transition-colors no-underline text-white/45">Trang chủ</a>
                <i class="bi bi-chevron-right text-[.6rem]"></i>
                <a href="/profile" class="hover:text-white/70 transition-colors no-underline text-white/45">Hồ sơ</a>
                <i class="bi bi-chevron-right text-[.6rem]"></i>
                <span class="text-[#F5A623]">Đơn hàng</span>
            </div>
            <div class="flex items-center gap-5">
                <div class="w-14 h-14 rounded-[16px] flex items-center justify-center text-2xl flex-shrink-0"
                     style="background:rgba(212,134,11,.15);border:1px solid rgba(212,134,11,.3);">
                    <i class="bi bi-bag-check-fill text-[#F5A623]"></i>
                </div>
                <div>
                    <h1 class="font-cormorant text-[2.1rem] font-bold text-white leading-tight mb-1">Đơn hàng của tôi</h1>
                    <div class="flex items-center gap-2.5 flex-wrap">
                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[.78rem] font-medium text-white/75"
                              style="background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);">
                            <i class="bi bi-bag text-[#F5A623] text-[.72rem]"></i>
                            @(isLoadingOrders ? "Đang tải..." : $"{realOrders.Count} đơn hàng")
                        </span>
                        @if (PendingReviewCount > 0)
                        {
                            <span class="inline-flex items-center gap-1.5 px-3 py-[3px] rounded-full text-[.72rem] font-bold"
                                  style="background:rgba(212,134,11,.2);border:1px solid rgba(212,134,11,.4);color:#F5A623;animation:pulse 2s ease-in-out infinite;">
                                <i class="bi bi-star-fill text-[.6rem]"></i>
                                @PendingReviewCount đơn chờ đánh giá
                            </span>
                        }
                        <span class="inline-flex items-center gap-1.5 px-3 py-[3px] rounded-full text-[.72rem] font-medium"
                              style="background:rgba(46,125,82,.2);border:1px solid rgba(46,125,82,.3);color:#4CAF82;">
                            <span class="w-1.5 h-1.5 rounded-full bg-[#4CAF82] inline-block @(isConnected?"":"opacity-40")"></span>
                            @(isConnected ? "Real-time" : "Đang kết nối...")
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- STAT CARDS -->
    <div class="max-w-[1100px] mx-auto px-6 fade-up-2">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 py-6">
            @{
                var statDefs = new (string icon, string iconBg, string iconColor, string label, string tabKey)[]
                {
            ("bi-bag-check",    "rgba(212,134,11,.12)", "#D4860B", "Tất cả",    "all"),
            ("bi-hourglass",    "rgba(37,99,168,.1)",   "#2563A8", "Chờ xử lý", "pending"),
            ("bi-truck",        "rgba(212,134,11,.1)",  "#D4860B", "Đang giao", "shipping"),
            ("bi-check-circle", "rgba(46,125,82,.1)",   "#2E7D52", "Đã giao",   "delivered"),
                };
            }
            @foreach (var s in statDefs)
            {
                var k = s.tabKey;
                var cnt = k switch
                {
                    "pending" => realOrders.Count(o => o.OrderStatusName is "Chờ xử lý" or "Đang đóng gói" or "Đã xác nhận"),
                    "shipping" => realOrders.Count(o => o.OrderStatusName == "Đang giao hàng"),
                    "delivered" => realOrders.Count(o => o.OrderStatusName == "Hoàn thành"),
                    _ => realOrders.Count
                };
                <div class="stat-card @(orderTab==k?"active-stat":"")" @onclick="@(() => SetTab(k))">
                    <div class="w-10 h-10 rounded-[12px] flex items-center justify-center text-base flex-shrink-0"
                         style="background:@s.iconBg;color:@s.iconColor;">
                        <i class="bi @s.icon"></i>
                    </div>
                    <div>
                        <div class="font-cormorant text-[1.6rem] font-bold text-[#1A1208] leading-none">@cnt</div>
                        <div class="text-[.72rem] text-[#9B8B7A] font-medium mt-0.5">@s.label</div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- MAIN TABLE CARD -->
    <div class="max-w-[1100px] mx-auto px-6 pb-20 fade-up-3">
        <div class="bg-[#FFFDF8] border border-[#EDE8DF] rounded-[20px] overflow-hidden"
             style="box-shadow:0 4px 24px rgba(107,76,42,.09);">

            <!-- TAB BAR -->
            <div class="flex border-b border-[#EDE8DF] px-4 overflow-x-auto bg-[#FFFDF8]" style="scrollbar-width:none;">
                @foreach (var (key, lbl) in new[] { ("all", "Tất cả"), ("pending", "Chờ xử lý"), ("shipping", "Đang giao"), ("delivered", "Đã giao"), ("cancelled", "Đã huỷ") })
                {
                    var k = key;
                    var cnt = k switch
                    {
                        "pending" => realOrders.Count(o => o.OrderStatusName is "Chờ xử lý" or "Đang đóng gói" or "Đã xác nhận"),
                        "shipping" => realOrders.Count(o => o.OrderStatusName == "Đang giao hàng"),
                        "delivered" => realOrders.Count(o => o.OrderStatusName == "Hoàn thành"),
                        "cancelled" => realOrders.Count(o => o.OrderStatusName == "Đã hủy"),
                        _ => realOrders.Count
                    };
                    <div @onclick="@(() => SetTab(k))" class="tab-pill @(orderTab==k?"active":"")">
                        @lbl
                        @if (cnt > 0)
                        {
                            <span class="@(orderTab==k?"bg-[#D4860B] text-white":"bg-[rgba(212,134,11,.1)] text-[#D4860B]") text-[.64rem] font-extrabold px-1.5 py-[1px] rounded-full transition-colors">
                                @cnt
                            </span>
                        }
                    </div>
                }
            </div>

            <!-- TABLE -->
            @if (isLoadingOrders)
            {
                <div class="p-6 flex flex-col gap-3">
                    @for (int i = 0; i < 5; i++)
                    {
                        <div class="skel h-14 w-full rounded-[10px]"></div>
                    }
                </div>
            }
            else if (!GetFilteredOrders().Any())
            {
                <div class="text-center py-20 text-[#9B8B7A]">
                    <i class="bi bi-bag-x text-[3rem] opacity-25 block mb-3"></i>
                    <p class="font-cormorant text-[1.2rem] font-semibold text-[#6B4C2A] mb-1">Không có đơn hàng nào</p>
                    <p class="text-[.84rem]">Thử chọn bộ lọc khác hoặc khám phá sách mới</p>
                    <a href="/" class="inline-flex items-center gap-2 mt-5 px-6 py-2.5 rounded-full text-white text-[.84rem] font-semibold no-underline"
                       style="background:linear-gradient(135deg,#D4860B,#F5A623);box-shadow:0 4px 16px rgba(212,134,11,.3);">
                        <i class="bi bi-book"></i> Khám phá sách
                    </a>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full" style="border-collapse:collapse;min-width:560px;">
                        <thead>
                            <tr style="background:linear-gradient(90deg,#FAF7F2,#FFFDF8);">
                                @foreach (var h in new[] { "Mã đơn", "Ngày đặt", "Tổng tiền", "Trạng thái", "Thao tác" })
                                {
                                    <th class="text-left text-[.67rem] font-bold tracking-wider uppercase text-[#9B8B7A] px-5 py-3.5 border-b border-[#EDE8DF] whitespace-nowrap">@h</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in PagedOrders())
                            {
                                bool isCompleted = order.OrderStatusName == "Hoàn thành";
                                <tr class="order-row transition-colors @(order.IsNew ? "order-row-new" : isCompleted ? "order-row-completed" : "")">

                                    <!-- Mã đơn -->
                                    <td class="px-5 py-4 border-b border-[rgba(237,232,223,.5)]">
                                        <div class="text-[.87rem] font-bold text-[#6B4C2A]">#@order.OrderId</div>
                                        @if (!string.IsNullOrEmpty(order.GhnOrderCode))
                                        {
                                            <div class="text-[.69rem] font-mono text-[#9B8B7A] mt-0.5">@order.GhnOrderCode</div>
                                        }
                                    </td>

                                    <!-- Ngày đặt -->
                                    <td class="px-5 py-4 text-[.8rem] text-[#7A6A5A] border-b border-[rgba(237,232,223,.5)] whitespace-nowrap">
                                        <div>@order.OrderDate.ToString("dd/MM/yyyy")</div>
                                        <div class="text-[.7rem] text-[#9B8B7A]">@order.OrderDate.ToString("HH:mm")</div>
                                    </td>

                                    <!-- Tổng tiền + số lượng + thanh toán -->
                                    <td class="px-5 py-4 border-b border-[rgba(237,232,223,.5)]">
                                        <div class="text-[.9rem] font-bold text-[#1A1208]">@order.TotalAmount.ToString("#,##0")đ</div>
                                        <div class="text-[.7rem] text-[#9B8B7A] mt-0.5">@order.TotalQuantity cuốn</div>
                                        <span class="text-[.7rem] font-semibold @(order.PaymentStatus=="Đã thanh toán"?"text-[#2E7D52]":"text-[#D4860B]")">
                                            @order.PaymentStatus
                                        </span>
                                    </td>

                                    <!-- Trạng thái -->
                                    <td class="px-5 py-4 border-b border-[rgba(237,232,223,.5)]">
                                        <span class="inline-flex items-center gap-1 px-2.5 py-[3px] rounded-full text-[.7rem] font-bold @GetStatusClass(order.OrderStatusName)">
                                            ● @order.OrderStatusName
                                        </span>
                                        @if (order.IsNew)
                                        {
                                            <span class="block mt-1 text-[.63rem] font-extrabold text-[#D4860B] tracking-wide">MỚI</span>
                                        }
                                    </td>

                                    <!-- Thao tác: Đánh giá + Chi tiết -->
                                    <td class="px-5 py-4 border-b border-[rgba(237,232,223,.5)]">
                                        <div class="flex items-center gap-2 flex-wrap">
                                            @if (isCompleted)
                                            {
                                                @if (order.HasReviewed)
                                                {
                                                    <div class="inline-flex items-center gap-1 px-2 py-[3px] rounded-full text-[.66rem] font-bold"
                                                         style="background:rgba(46,125,82,.08);color:#2E7D52;border:1px solid rgba(46,125,82,.2);">
                                                        <i class="bi bi-patch-check-fill" style="font-size:.6rem;"></i>Đã đánh giá
                                                    </div>
                                                }
                                                else
                                                {
                                                    <a href="/order/@order.OrderId#review" class="review-btn">
                                                        <i class="bi bi-star-fill"></i>Đánh giá
                                                    </a>
                                                }
                                            }
                                            <a href="/order/@order.OrderId" class="detail-btn" title="Xem chi tiết">
                                                <i class="bi bi-chevron-right"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- PAGINATION -->
                <div class="px-5 py-4 border-t border-[#EDE8DF] flex flex-col sm:flex-row items-center justify-between gap-3"
                     style="background:linear-gradient(90deg,#FAF7F2,#FFFDF8);">
                    <span class="text-[.78rem] text-[#9B8B7A]">
                        Hiển thị <strong class="text-[#6B4C2A]">@PgFrom–@PgTo</strong> / <strong class="text-[#6B4C2A]">@PgTotal</strong> đơn
                        &nbsp;·&nbsp;
                        Tổng: <strong class="text-[#6B4C2A]">@PgSum.ToString("#,##0")đ</strong>
                    </span>

                    @if (TotalPages > 1)
                    {
                        <div class="flex items-center gap-1.5">
                            <button class="pg-btn @(currentPage<=1?"pg-off":"")" @onclick="@(()=>{if(currentPage>1)currentPage--;})">
                                <i class="bi bi-chevron-left" style="font-size:.72rem;"></i>
                            </button>
                            @for (int p = 1; p <= TotalPages; p++)
                            {
                                var pg = p;
                                if (pg == 1 || pg == TotalPages || (pg >= currentPage - 1 && pg <= currentPage + 1))
                                {
                                    <button class="pg-btn @(pg==currentPage?"pg-on":"")" @onclick="@(()=>currentPage=pg)">@pg</button>
                                }
                                else if (pg == currentPage - 2 || pg == currentPage + 2)
                                {
                                    <span style="color:#C4B8A8;padding:0 2px;font-size:.82rem;">…</span>
                                }
                            }
                            <button class="pg-btn @(currentPage>=TotalPages?"pg-off":"")" @onclick="@(()=>{if(currentPage<TotalPages)currentPage++;})">
                                <i class="bi bi-chevron-right" style="font-size:.72rem;"></i>
                            </button>
                        </div>

                        <div class="flex items-center gap-2 text-[.78rem] text-[#9B8B7A]">
                            <span>Hiển thị</span>
                            <select @bind="PageSize" @bind:after="ResetPage"
                                    style="border:1.5px solid #EDE8DF;border-radius:8px;padding:4px 8px;font-size:.78rem;font-family:inherit;color:#6B4C2A;background:#FFFDF8;outline:none;cursor:pointer;">
                                <option value="5">5</option>
                                <option value="10">10</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                            </select>
                            <span>/ trang</span>
                        </div>
                    }
                </div>

                <!-- BANNER: đơn hoàn thành chờ đánh giá -->
                @if (PendingReviewCount > 0 && (orderTab == "all" || orderTab == "delivered"))
                {
                    <div class="mx-5 mb-5 mt-1 rounded-[14px] px-5 py-4 flex items-center gap-4 flex-wrap"
                         style="background:linear-gradient(135deg,rgba(212,134,11,.08),rgba(245,166,35,.05));border:1.5px solid rgba(212,134,11,.22);">
                        <div class="w-9 h-9 rounded-[10px] flex items-center justify-center flex-shrink-0"
                             style="background:rgba(212,134,11,.15);color:#D4860B;font-size:.9rem;">
                            <i class="bi bi-star-fill"></i>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="text-[.86rem] font-bold text-[#6B4C2A]">
                                Bạn có @PendingReviewCount đơn hàng chờ đánh giá
                            </div>
                            <div class="text-[.76rem] text-[#9B8B7A] mt-0.5">
                                Chia sẻ cảm nhận để giúp người mua khác và nhận điểm thưởng từ BookStore
                            </div>
                        </div>
                        <button @onclick='@(() => SetTab("delivered"))'
                                class="flex-shrink-0 px-4 py-2 rounded-[10px] text-[.8rem] font-bold border-none cursor-pointer text-white"
                                style="background:linear-gradient(135deg,#D4860B,#F5A623);box-shadow:0 3px 12px rgba(212,134,11,.3);font-family:inherit;">
                            <i class="bi bi-star mr-1"></i>Xem đơn cần đánh giá
                        </button>
                    </div>
                }
            }
        </div>

        <div class="mt-5 flex justify-start">
            <a href="/profile" class="inline-flex items-center gap-2 text-[.82rem] font-medium text-[#9B8B7A] no-underline hover:text-[#6B4C2A] transition-colors">
                <i class="bi bi-arrow-left text-[.8rem]"></i> Quay lại hồ sơ
            </a>
        </div>
    </div>

    <!-- TOAST -->
    <div class="fixed bottom-6 right-6 z-[99999] flex flex-col gap-2 pointer-events-none">
        @foreach (var t in toasts)
        {
            <div class="pf-toast pointer-events-auto flex items-center gap-2.5 px-[18px] py-3 rounded-[12px] text-white text-[.84rem] font-medium min-w-[280px] @(t.Type=="success"?"bg-[#2E7D52]":"bg-[#C0392B]")"
                 style="box-shadow:0 20px 60px rgba(107,76,42,.2);">
                <i class="bi @(t.Type=="success"?"bi-check-circle-fill":"bi-exclamation-circle-fill")"></i>@t.Message
            </div>
        }
    </div>
</div>

@code {
    private bool isLoggedIn = false, showDropdown = false, isLoadingOrders = true, isConnected = false;
    private string userFullName = "", userEmail = "", accessToken = "";
    private string orderTab = "all";
    private int currentUserId = 0;
    private List<ToastItem> toasts = new();
    private List<OrderHistoryItem> realOrders = new();
    private HubConnection? hubConnection;

    // ── Computed properties ────────────────────────────────────────────
    private int PendingReviewCount =>
        realOrders.Count(o => o.OrderStatusName == "Hoàn thành" && !o.HasReviewed);

    // ── Pagination ─────────────────────────────────────────────────────
    private int currentPage = 1;
    private int _pageSize = 10;
    private int PageSize { get => _pageSize; set { _pageSize = value; currentPage = 1; _filteredCache = null; } }
    private void ResetPage() { currentPage = 1; _filteredCache = null; }

    private List<OrderHistoryItem>? _filteredCache;
    private string _filteredCacheTab = "";

    private List<OrderHistoryItem> FilteredCache()
    {
        if (_filteredCache == null || _filteredCacheTab != orderTab)
        { _filteredCache = GetFilteredOrders(); _filteredCacheTab = orderTab; }
        return _filteredCache;
    }

    private List<OrderHistoryItem> PagedOrders() =>
        FilteredCache().Skip((currentPage - 1) * PageSize).Take(PageSize).ToList();

    private int TotalPages => (int)Math.Ceiling(FilteredCache().Count / (double)PageSize);
    private int PgTotal => FilteredCache().Count;
    private int PgFrom => PgTotal == 0 ? 0 : (currentPage - 1) * PageSize + 1;
    private int PgTo => Math.Min(currentPage * PageSize, PgTotal);
    private decimal PgSum => FilteredCache().Sum(o => o.TotalAmount);

    // ── Lifecycle ──────────────────────────────────────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        accessToken = await JS.InvokeAsync<string?>("localStorage.getItem", "accessToken") ?? "";
        userFullName = await JS.InvokeAsync<string?>("localStorage.getItem", "userFullName") ?? "";
        userEmail = await JS.InvokeAsync<string?>("localStorage.getItem", "userEmail") ?? "";
        var userIdStr = await JS.InvokeAsync<string?>("localStorage.getItem", "userId") ?? "";

        if (!string.IsNullOrEmpty(accessToken) && !string.IsNullOrEmpty(userFullName))
        {
            isLoggedIn = true;
            Http.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", accessToken);
        }

        if (!int.TryParse(userIdStr, out currentUserId))
            currentUserId = ParseUserIdFromToken();

        await LoadOrders();
        await ConnectSignalRAsync();
        StateHasChanged();
    }

    // ── SignalR ────────────────────────────────────────────────────────
    private async Task ConnectSignalRAsync()
    {
        if (string.IsNullOrEmpty(accessToken)) return;
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl("https://localhost:7213/notificationHub", options =>
                    { options.AccessTokenProvider = () => Task.FromResult<string?>(accessToken); })
                .WithAutomaticReconnect(new[] { TimeSpan.Zero, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(10) })
                .Build();

            hubConnection.On<OrderStatusUpdateDto>("ReceiveOrderStatus", async (dto) =>
            {
                await InvokeAsync(async () =>
                {
                    var order = realOrders.FirstOrDefault(o => o.OrderId == dto.OrderId);
                    if (order != null)
                    {
                        order.OrderStatusName = dto.NewStatus;
                        order.IsNew = true;
                        if (dto.NewStatus == "Hoàn thành") order.PaymentStatus = "Đã thanh toán";
                    }
                    _filteredCache = null;
                    await ShowToast($"🔔 {dto.Message}", "success");
                    StateHasChanged();
                    await Task.Delay(5000);
                    if (order != null) order.IsNew = false;
                    StateHasChanged();
                });
            });

            hubConnection.Reconnecting += _ => { isConnected = false; InvokeAsync(StateHasChanged); return Task.CompletedTask; };
            hubConnection.Reconnected += _ => { isConnected = true; InvokeAsync(StateHasChanged); return Task.CompletedTask; };
            hubConnection.Closed += _ => { isConnected = false; InvokeAsync(StateHasChanged); return Task.CompletedTask; };

            await hubConnection.StartAsync();
            isConnected = true;

            var userId = GetUserIdFromToken();
            if (!string.IsNullOrEmpty(userId))
                await hubConnection.InvokeAsync("JoinRoom", userId, "User");
        }
        catch (Exception ex) { Console.WriteLine($"[SignalR] Lỗi: {ex.Message}"); }
    }

    // ── Load ───────────────────────────────────────────────────────────
    private async Task LoadOrders()
    {
        isLoadingOrders = true;
        try
        {
            var req = new HttpRequestMessage(HttpMethod.Get, "api/order/history");
            req.Headers.Authorization = new AuthenticationHeaderValue("Bearer", accessToken);
            var resp = await Http.SendAsync(req);
            if (resp.IsSuccessStatusCode)
            {
                var result = await resp.Content.ReadFromJsonAsync<List<OrderHistoryItem>>();
                realOrders = result ?? new();
            }
            else { await ShowToast($"Lỗi {(int)resp.StatusCode}: Không thể tải đơn hàng", "error"); }
        }
        catch (Exception ex) { await ShowToast($"Lỗi kết nối: {ex.Message}", "error"); }
        finally { isLoadingOrders = false; }
    }

    // ── Helpers ────────────────────────────────────────────────────────
    private void SetTab(string tab) { orderTab = tab; currentPage = 1; _filteredCache = null; }
    private void ToggleDropdown() => showDropdown = !showDropdown;

    private List<OrderHistoryItem> GetFilteredOrders() => orderTab switch
    {
        "pending" => realOrders.Where(o => o.OrderStatusName is "Chờ xử lý" or "Đang đóng gói" or "Đã xác nhận").ToList(),
        "shipping" => realOrders.Where(o => o.OrderStatusName == "Đang giao hàng").ToList(),
        "delivered" => realOrders.Where(o => o.OrderStatusName == "Hoàn thành").ToList(),
        "cancelled" => realOrders.Where(o => o.OrderStatusName == "Đã hủy").ToList(),
        _ => realOrders
    };

    private static string GetStatusClass(string s) => s switch
    {
        "Hoàn thành" => "status-delivered",
        "Đang giao hàng" => "status-shipping",
        "Chờ xử lý" => "status-pending",
        "Đang đóng gói" => "status-pending",
        "Đã xác nhận" => "status-pending",
        "Đã hủy" => "status-cancelled",
        _ => ""
    };

    private async Task ShowToast(string message, string type = "success")
    {
        var t = new ToastItem { Message = message, Type = type };
        toasts.Add(t); StateHasChanged();
        await Task.Delay(3500);
        toasts.Remove(t); StateHasChanged();
    }

    private async Task Logout()
    {
        if (hubConnection != null) await hubConnection.DisposeAsync();
        foreach (var k in new[] { "accessToken", "refreshToken", "userEmail", "userFullName", "userId" })
            await JS.InvokeVoidAsync("localStorage.removeItem", k);
        Navigation.NavigateTo("/", forceLoad: true);
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection != null) await hubConnection.DisposeAsync();
    }

    private string GetUserIdFromToken()
    {
        try
        {
            if (string.IsNullOrEmpty(accessToken)) return "";
            var parts = TokenParts(accessToken);
            if (parts == null) return "";
            var doc = System.Text.Json.JsonDocument.Parse(parts);
            foreach (var claim in new[] { "sub", "nameid", "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier" })
                if (doc.RootElement.TryGetProperty(claim, out var v)) return v.GetString() ?? "";
            return "";
        }
        catch { return ""; }
    }

    private int ParseUserIdFromToken()
        => int.TryParse(GetUserIdFromToken(), out var id) ? id : 0;

    private static string? TokenParts(string token)
    {
        try
        {
            var parts = token.Split('.');
            if (parts.Length < 2) return null;
            var p = parts[1];
            switch (p.Length % 4) { case 2: p += "=="; break; case 3: p += "="; break; }
            p = p.Replace('-', '+').Replace('_', '/');
            return System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(p));
        }
        catch { return null; }
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        var p = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return p.Length == 1 ? p[0][..1].ToUpper() : $"{p[0][..1]}{p[^1][..1]}".ToUpper();
    }

    // ── Models ─────────────────────────────────────────────────────────
    public class OrderHistoryItem
    {
        public int OrderId { get; set; }
        public DateTime OrderDate { get; set; }
        public decimal TotalAmount { get; set; }
        public int TotalQuantity { get; set; }
        public byte OrderStatus { get; set; }
        public string OrderStatusName { get; set; } = "";
        public string PaymentStatus { get; set; } = "";
        public string PaymentMethod { get; set; } = "";
        public string? GhnOrderCode { get; set; }
        public bool IsNew { get; set; } = false;

        // API nên trả thêm field này — nếu chưa có thì mặc định false
        public bool HasReviewed { get; set; } = false;
    }

    private class OrderStatusUpdateDto
    {
        public int OrderId { get; set; }
        public string NewStatus { get; set; } = "";
        public string Message { get; set; } = "";
    }

    public class ToastItem
    {
        public string Message { get; set; } = "";
        public string Type { get; set; } = "success";
    }
}
