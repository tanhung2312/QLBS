@page "/wishlist"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Net.Http.Headers
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Sách Yêu Thích - BookStore</PageTitle>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

<style>
    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(18px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    @@keyframes shimmer {
        0% {
            background-position: -200% 0
        }

        100% {
            background-position: 200% 0
        }
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateX(30px)
        }

        to {
            opacity: 1;
            transform: translateX(0)
        }
    }

    .font-cormorant {
        font-family: 'Cormorant Garamond', serif;
    }

    .font-jakarta {
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .skel {
        background: linear-gradient(90deg, #EDE8DF 25%, #FFFDF8 50%, #EDE8DF 75%);
        background-size: 200% 100%;
        animation: shimmer 1.4s infinite;
        border-radius: 6px;
    }

    .wish-card:hover .wish-img {
        transform: scale(1.07);
    }

    .wish-img {
        transition: transform .5s cubic-bezier(.4,0,.2,1);
    }

    .wish-card:hover .wish-del {
        opacity: 1 !important;
    }

    .toast-item {
        animation: slideIn .25s ease both;
    }

    ::-webkit-scrollbar {
        width: 4px;
    }

    ::-webkit-scrollbar-thumb {
        background: #DDD5C8;
        border-radius: 10px;
    }
</style>

<div class="font-jakarta bg-[#FAF7F2] min-h-screen text-[#1A1208]">

    <!-- TOP BAR -->
    <div style="background:linear-gradient(90deg,#5A3D20,#6B4C2A,#7A5A34);" class="text-white/80 text-[0.78rem] py-[7px]">
        <div class="max-w-[1200px] mx-auto px-6 flex justify-between items-center gap-2">
            <div class="flex items-center gap-4">
                <span class="flex items-center gap-1.5">
                    <i class="bi bi-telephone-fill text-[#F5A623] text-[0.7rem]"></i>0901 234 567
                </span>
                <span class="hidden sm:flex items-center gap-1.5 opacity-75">
                    <i class="bi bi-envelope-fill text-[#F5A623] text-[0.7rem]"></i>bookstore@gmail.com
                </span>
            </div>
            <a href="/profile" class="text-[rgba(255,221,167,.75)] no-underline hover:text-[rgba(255,221,167,1)] transition-colors flex items-center gap-1 text-[.75rem]">
                <i class="bi bi-person text-[0.7rem]"></i> Hồ sơ của tôi
            </a>
        </div>
    </div>

    <!-- NAVBAR -->
    <nav class="bg-[#FFFDF8]/95 border-b border-[#EDE8DF] py-3 sticky top-0 z-50"
         style="backdrop-filter:blur(20px);box-shadow:0 1px 0 rgba(107,76,42,.06),0 4px 24px rgba(107,76,42,.06);">
        <div class="max-w-[1200px] mx-auto px-6 flex items-center gap-4">
            <a href="/" class="font-cormorant text-[1.75rem] font-bold text-[#6B4C2A] no-underline flex items-center gap-2.5 mr-auto">
                <div class="w-9 h-9 rounded-[10px] flex items-center justify-center text-white text-base"
                     style="background:linear-gradient(135deg,#D4860B,#F5A623);box-shadow:0 4px 12px rgba(212,134,11,.35);">
                    <i class="bi bi-book-half"></i>
                </div>
                Book<span class="text-[#D4860B]">Store</span>
            </a>
            <a href="/cart" class="relative w-9 h-9 rounded-full bg-[#FAF7F2] border border-[#EDE8DF] flex items-center justify-center text-[#6B4C2A] no-underline hover:bg-[#D4860B] hover:text-white transition-colors">
                <i class="bi bi-bag"></i>
            </a>
            <a href="/profile" class="flex items-center gap-2 bg-[#1A1208] text-white rounded-full px-4 py-[0.42rem] text-[0.82rem] font-semibold no-underline hover:bg-[#D4860B] transition-colors ml-1">
                <i class="bi bi-person"></i> Hồ sơ
            </a>
        </div>
    </nav>

    <!-- PAGE HEADER -->
    <div class="max-w-[1200px] mx-auto px-6 pt-9 pb-6" style="animation:fadeUp .4s ease both;">
        <div class="flex items-center justify-between flex-wrap gap-4">
            <div>
                <div class="flex items-center gap-2 mb-1.5">
                    <a href="/" class="text-[.78rem] text-[#9B8B7A] no-underline hover:text-[#D4860B] transition-colors">Trang chủ</a>
                    <span class="text-[#DDD5C8]">›</span>
                    <a href="/profile" class="text-[.78rem] text-[#9B8B7A] no-underline hover:text-[#D4860B] transition-colors">Hồ sơ</a>
                    <span class="text-[#DDD5C8]">›</span>
                    <span class="text-[.78rem] text-[#D4860B] font-medium">Yêu thích</span>
                </div>
                <h1 class="font-cormorant text-[2rem] font-bold text-[#1A1208] flex items-center gap-3">
                    <div class="w-10 h-10 rounded-[12px] flex items-center justify-center text-[1rem]"
                         style="background:rgba(192,57,43,.1);color:#E57373;">
                        <i class="bi bi-heart-fill"></i>
                    </div>
                    Sách yêu thích
                </h1>
                <p class="text-[.84rem] text-[#9B8B7A] mt-1">Những cuốn sách bạn đã lưu để đọc sau</p>
            </div>

            @if (!isLoading && wishlistBooks.Any())
            {
                <div class="flex items-center gap-3 flex-wrap">
                    <span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full text-[.78rem] font-semibold text-[#D4860B]"
                          style="background:rgba(212,134,11,.1);border:1.5px solid rgba(212,134,11,.2);">
                        <i class="bi bi-heart-fill text-[.65rem]"></i> @wishlistBooks.Count cuốn
                    </span>
                    <div class="flex items-center gap-2 bg-white border border-[#DDD5C8] rounded-full px-4 py-2 text-[.83rem] transition-all focus-within:border-[#D4860B] focus-within:shadow-[0_0_0_3px_rgba(212,134,11,.1)]">
                        <i class="bi bi-search text-[#9B8B7A] text-[.8rem]"></i>
                        <input type="text" placeholder="Tìm trong danh sách..." @bind="searchText" @bind:event="oninput"
                               class="outline-none bg-transparent text-[#1A1208] w-[180px] font-jakarta text-[.83rem]" />
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- CONTENT -->
    <div class="max-w-[1200px] mx-auto px-6 pb-20">

        @if (isLoading)
        {
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4" style="animation:fadeUp .4s .1s ease both;">
                @for (int s = 0; s < 10; s++)
                {
                    <div class="border border-[#EDE8DF] rounded-[16px] overflow-hidden bg-white">
                        <div class="skel h-[200px] w-full" style="border-radius:0;"></div>
                        <div class="p-3.5 flex flex-col gap-2">
                            <div class="skel h-2.5 w-1/3 rounded"></div>
                            <div class="skel h-3.5 w-4/5 rounded"></div>
                            <div class="skel h-2.5 w-1/2 rounded"></div>
                            <div class="skel h-3.5 w-1/3 rounded mt-1"></div>
                            <div class="flex gap-1.5 mt-2">
                                <div class="skel h-8 flex-1 rounded-[8px]"></div>
                                <div class="skel h-8 flex-1 rounded-[8px]"></div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (!wishlistBooks.Any())
        {
            <div class="text-center py-20" style="animation:fadeUp .5s ease both;">
                <div class="w-24 h-24 rounded-full mx-auto mb-6 flex items-center justify-center"
                     style="background:rgba(192,57,43,.07);border:2.5px dashed rgba(192,57,43,.2);">
                    <i class="bi bi-heart text-[2.5rem] text-[#E57373] opacity-40"></i>
                </div>
                <div class="font-cormorant text-[1.6rem] font-bold text-[#6B4C2A] mb-2">Chưa có sách yêu thích</div>
                <p class="text-[.84rem] text-[#9B8B7A] mb-8 max-w-[300px] mx-auto leading-relaxed">
                    Hãy thêm những cuốn sách bạn yêu thích để dễ dàng tìm lại sau!
                </p>
                <a href="/"
                   class="inline-flex items-center gap-2 px-7 py-3 rounded-full text-white text-[.88rem] font-semibold no-underline hover:-translate-y-0.5 transition-all"
                   style="background:linear-gradient(135deg,#D4860B,#F5A623);box-shadow:0 6px 20px rgba(212,134,11,.35);">
                    <i class="bi bi-book"></i> Khám phá sách
                </a>
            </div>
        }
        else
        {
            @if (!FilteredBooks.Any())
            {
                <div class="text-center py-16 text-[#9B8B7A]" style="animation:fadeUp .3s ease both;">
                    <i class="bi bi-search text-[2rem] opacity-30 block mb-2.5"></i>
                    <p class="text-[.9rem]">Không tìm thấy sách nào khớp với "@searchText"</p>
                    <button @onclick="ClearSearch"
                            class="mt-4 text-[.82rem] text-[#D4860B] bg-transparent border-none cursor-pointer underline font-jakarta">
                        Xóa tìm kiếm
                    </button>
                </div>
            }
            else
            {
                <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4" style="animation:fadeUp .4s .05s ease both;">
                    @foreach (var book in FilteredBooks)
                    {
                        var bookId = book.BookId;
                        <div class="wish-card group border border-[#EDE8DF] rounded-[16px] overflow-hidden bg-white transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_12px_40px_rgba(107,76,42,.15)] hover:border-[rgba(212,134,11,.4)]">

                            <!-- Ảnh -->
                            <div class="relative h-[200px] overflow-hidden bg-[#FAF7F2]">
                                <img src="@book.ImageUrl" alt="@book.Title" loading="lazy"
                                     class="wish-img w-full h-full object-cover" />
                                <div class="absolute inset-0"
                                     style="background:linear-gradient(180deg,transparent 45%,rgba(26,18,8,.65) 100%);"></div>

                                <!-- Nút xóa (hiện khi hover) -->
                                <button @onclick="() => RemoveWishlist(bookId)"
                                        class="wish-del absolute top-2.5 right-2.5 w-8 h-8 rounded-full flex items-center justify-center text-white text-[.75rem] border-none cursor-pointer transition-all hover:bg-[#C0392B] hover:scale-110"
                                        style="opacity:0;background:rgba(26,18,8,.65);backdrop-filter:blur(8px);"
                                        title="Xóa khỏi yêu thích">
                                    <i class="bi bi-x-lg"></i>
                                </button>

                                <!-- Giá -->
                                <div class="absolute bottom-0 inset-x-0 px-3 pb-2.5">
                                    <div class="font-cormorant text-[1.2rem] font-bold text-white"
                                         style="text-shadow:0 1px 8px rgba(0,0,0,.5);">
                                        @book.Price.ToString("#,##0")<span class="text-[.6em] font-normal opacity-80">đ</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Info -->
                            <div class="p-3.5">
                                <div class="text-[.62rem] text-[#D4860B] font-bold uppercase tracking-widest mb-0.5 truncate">
                                    @book.Category
                                </div>
                                <div class="text-[.84rem] font-semibold text-[#1A1208] leading-snug mb-1"
                                     style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;min-height:2.5em;">
                                    @book.Title
                                </div>
                                <div class="text-[.72rem] text-[#9B8B7A] mb-3 flex items-center gap-1 truncate">
                                    <i class="bi bi-person text-[.65rem] flex-shrink-0"></i>@book.Author
                                </div>

                                <div class="flex gap-1.5">
                                    <button @onclick="@(() => Navigation.NavigateTo($"/book/{bookId}"))"
                                            class="flex-1 rounded-[9px] py-[7px] text-[#6B4C2A] text-[.74rem] font-semibold border border-[#DDD5C8] bg-[#FAF7F2] cursor-pointer flex items-center justify-center gap-1 hover:border-[#D4860B] hover:text-[#D4860B] hover:bg-[rgba(212,134,11,.06)] transition-all">
                                        <i class="bi bi-eye text-[.7rem]"></i> Xem
                                    </button>
                                    <button @onclick="@(() => AddToCart(bookId, book.Title))"
                                            class="flex-1 rounded-[9px] py-[7px] text-white text-[.74rem] font-semibold border-none cursor-pointer flex items-center justify-center gap-1 hover:-translate-y-0.5 transition-all"
                                            style="background:linear-gradient(135deg,#6B4C2A,#9B6E3A);box-shadow:0 3px 10px rgba(107,76,42,.2);">
                                        <i class="bi bi-bag-plus text-[.7rem]"></i> Thêm
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>

    <!-- TOAST -->
    <div class="fixed bottom-6 right-6 z-[99999] flex flex-col gap-2 pointer-events-none">
        @foreach (var t in toasts)
        {
            <div class="toast-item pointer-events-auto flex items-center gap-2.5 px-[18px] py-3 rounded-[12px] text-white text-[.84rem] font-medium min-w-[260px] @(t.Type=="success"?"bg-[#2E7D52]":"bg-[#C0392B]")"
                 style="box-shadow:0 8px 30px rgba(107,76,42,.2);">
                <i class="bi @(t.Type=="success"?"bi-check-circle-fill":"bi-exclamation-circle-fill")"></i>
                @t.Message
            </div>
        }
    </div>
</div>

@code {
    private List<WishBookModel> FilteredBooks => string.IsNullOrWhiteSpace(searchText)
        ? wishlistBooks
        : wishlistBooks.Where(b =>
            b.Title.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
            b.Author.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
            b.Category.Contains(searchText, StringComparison.OrdinalIgnoreCase)).ToList();

    private List<WishBookModel> wishlistBooks = new();
    private List<ToastItem> toasts = new();
    private bool isLoading = true;
    private string searchText = string.Empty;
    private string accessToken = string.Empty;
    private int currentUserId = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        accessToken = await JS.InvokeAsync<string?>("localStorage.getItem", "accessToken") ?? "";
        var userIdStr = await JS.InvokeAsync<string?>("localStorage.getItem", "userId") ?? "";

        if (string.IsNullOrEmpty(accessToken))
        {
            Navigation.NavigateTo("/login?returnUrl=/wishlist");
            return;
        }

        Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", accessToken);

        if (!int.TryParse(userIdStr, out currentUserId))
            currentUserId = ParseUserIdFromToken();

        await LoadWishlist();
        StateHasChanged();
    }

    private async Task LoadWishlist()
    {
        isLoading = true;
        try
        {
            var req = new HttpRequestMessage(HttpMethod.Get, $"api/FavoriteBook/{currentUserId}");
            req.Headers.Authorization = new AuthenticationHeaderValue("Bearer", accessToken);
            var resp = await Http.SendAsync(req);

            if (resp.IsSuccessStatusCode)
            {
                var result = await resp.Content.ReadFromJsonAsync<FavoriteBookListDto>();
                if (result?.Items != null)
                {
                    wishlistBooks = result.Items.Select(i => new WishBookModel(
                        i.BookId,
                        i.BookTitle ?? "Không rõ",
                        i.AuthorName ?? "Không rõ",
                        i.CategoryName ?? "Khác",
                        i.Price,
                        !string.IsNullOrEmpty(i.CoverImageUrl)
                            ? i.CoverImageUrl
                            : "https://images.unsplash.com/photo-1544947950-fa07a98d237f?w=300&h=400&fit=crop"
                    )).ToList();
                }
            }
            else
            {
                await ShowToast("Không thể tải danh sách yêu thích", "error");
            }
        }
        catch (Exception ex) { await ShowToast("Lỗi: " + ex.Message, "error"); }
        finally { isLoading = false; }
    }

    private async Task RemoveWishlist(int bookId)
    {
        try
        {
            var req = new HttpRequestMessage(HttpMethod.Delete, $"api/FavoriteBook/{currentUserId}/{bookId}");
            req.Headers.Authorization = new AuthenticationHeaderValue("Bearer", accessToken);
            var resp = await Http.SendAsync(req);
            if (resp.IsSuccessStatusCode)
            {
                wishlistBooks.RemoveAll(b => b.BookId == bookId);
                await ShowToast("Đã xóa khỏi yêu thích");
            }
            else { await ShowToast("Xóa thất bại", "error"); }
        }
        catch (Exception ex) { await ShowToast("Lỗi: " + ex.Message, "error"); }
    }

    private async Task AddToCart(int bookId, string title)
    {
        try
        {
            var req = new HttpRequestMessage(HttpMethod.Post, "api/cart/add");
            req.Headers.Authorization = new AuthenticationHeaderValue("Bearer", accessToken);
            req.Content = JsonContent.Create(new { bookId, quantity = 1 });
            var resp = await Http.SendAsync(req);
            if (resp.IsSuccessStatusCode)
                await ShowToast($"Đã thêm '{title}' vào giỏ hàng!");
            else
                await ShowToast("Thêm vào giỏ thất bại", "error");
        }
        catch (Exception ex) { await ShowToast("Lỗi: " + ex.Message, "error"); }
    }

    private void ClearSearch() => searchText = string.Empty;

    private async Task ShowToast(string msg, string type = "success")
    {
        var t = new ToastItem { Message = msg, Type = type };
        toasts.Add(t); StateHasChanged();
        await Task.Delay(3500);
        toasts.Remove(t); StateHasChanged();
    }

    private string GetUserIdFromToken()
    {
        try
        {
            if (string.IsNullOrEmpty(accessToken)) return "";
            var parts = accessToken.Split('.');
            if (parts.Length < 2) return "";
            var p = parts[1];
            switch (p.Length % 4) { case 2: p += "=="; break; case 3: p += "="; break; }
            p = p.Replace('-', '+').Replace('_', '/');
            var json = System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(p));
            var doc = System.Text.Json.JsonDocument.Parse(json);
            foreach (var claim in new[] { "sub", "nameid", "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier" })
                if (doc.RootElement.TryGetProperty(claim, out var v)) return v.GetString() ?? "";
            return "";
        }
        catch { return ""; }
    }

    private int ParseUserIdFromToken() =>
        int.TryParse(GetUserIdFromToken(), out var id) ? id : 0;

    // ── Models ──
    private class FavoriteBookListDto
    {
        public int TotalCount { get; set; }
        public List<FavoriteBookItemDto>? Items { get; set; }
    }

    private class FavoriteBookItemDto
    {
        public int BookId { get; set; }
        public string? BookTitle { get; set; }
        public string? AuthorName { get; set; }
        public string? CategoryName { get; set; }
        public decimal Price { get; set; }
        public string? CoverImageUrl { get; set; }
    }

    public record WishBookModel(int BookId, string Title, string Author, string Category, decimal Price, string ImageUrl);
    public class ToastItem { public string Message { get; set; } = ""; public string Type { get; set; } = "success"; }
}
