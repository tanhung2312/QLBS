        <div class="flex flex-wrap justify-between items-center py-5 mt-8 border-t gap-3"
             style="border-color:rgba(255,255,255,.07);">
            <p class="text-xs m-0" style="color:rgba(255,255,255,.28);">&copy; @DateTime.Now.Year BookStore. Tất cả quyền được bảo lưu.</p>
        </div>
    </div>
</footer>

@code {
    private bool isSuccess = true;
    private string orderId = "";
    private string reason = "";
    private string errorCode = "";

    private bool isLoggedIn = false;
    private string userFullName = "";
    private string userEmail = "";
    private bool showDropdown = false;

    // Confetti data
    private record ConfettiItem(double Left, string Color, int Size, string Round, double Delay, double Duration);
    private List<ConfettiItem> confettiItems = new();

    private static readonly string[] ConfettiColors = { "#D4860B", "#F5A623", "#6B4C2A", "#2E7D32", "#1a73e8", "#E74C3C", "#F5A623" };

    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        isSuccess = query["success"]?.ToLower() == "true";
        orderId = query["orderId"] ?? "";
        reason = query["reason"] ?? "";
        errorCode = query["code"] ?? "";

        // Strip timestamp from orderId if format is "id_timestamp"
        if (orderId.Contains('_'))
            orderId = orderId.Split('_')[0];

        // Generate confetti only for success
        if (isSuccess)
        {
            var rng = new Random(42);
            for (int i = 0; i < 28; i++)
            {
                confettiItems.Add(new ConfettiItem(
                    Left: rng.NextDouble() * 100,
                    Color: ConfettiColors[rng.Next(ConfettiColors.Length)],
                    Size: rng.Next(6, 12),
                    Round: rng.Next(2) == 0 ? "50%" : "2px",
                    Delay: rng.NextDouble() * .8,
                    Duration: 1.2 + rng.NextDouble() * .8
                ));
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        userFullName = await JS.InvokeAsync<string?>("localStorage.getItem", "userFullName") ?? "";
        userEmail = await JS.InvokeAsync<string?>("localStorage.getItem", "userEmail") ?? "";
        if (!string.IsNullOrEmpty(userFullName)) isLoggedIn = true;
        StateHasChanged();
    }

    private string GetFailReason() => reason switch
    {
        "invalid_signature" => "Chữ ký không hợp lệ",
        "update_failed" => "Cập nhật đơn hàng thất bại",
        "vnpay_error" => $"Lỗi VNPay (code: {errorCode})",
        _ => "Giao dịch bị từ chối"
    };

    private void ToggleDropdown() => showDropdown = !showDropdown;

    private static string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1 ? parts[0][..1].ToUpper() : $"{parts[0][..1]}{parts[^1][..1]}".ToUpper();
    }
}
