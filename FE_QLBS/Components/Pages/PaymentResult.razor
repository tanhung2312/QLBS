            <div>
                <div class="text-xs font-bold uppercase tracking-widest mb-4" style="color:rgba(255,255,255,.35);">Liên hệ</div>
                @foreach (var (ico, txt) in new[] { ("bi-geo-alt-fill", "123 Nguyễn Huệ, Quận 1, TP.HCM"), ("bi-telephone-fill", "0901 234 567"), ("bi-envelope-fill", "bookstore@gmail.com") })
                {
                    <div class="flex items-start gap-2.5 mb-2 text-xs" style="color:rgba(255,255,255,.45);">
